---
import Layout from '../layouts/Layout.astro'
import { projects } from '../data/projects'

const ikeaProjects = projects.filter((p) => p.company === 'IKEA Global')
---

<Layout
  title="IKEA Global — Pablo Suzarte"
  description="7 projects spanning journey orchestration, AI-driven research, coaching platforms, and the future of Service Design at IKEA."
  lang="en"
>
  <header class="project-nav">
    <div class="project-nav-inner">
      <a href="/" class="nav-back">&larr; Back</a>
      <a href="/" class="nav-logo">PS</a>
      <span class="nav-breadcrumb">IKEA Global</span>
    </div>
  </header>

  <section class="hub-hero">
    <div class="container">
      <p class="hub-eyebrow">Senior Product UX Designer &middot; Service Design &middot; May 2022 &mdash; Present</p>
      <h1 class="hub-title">IKEA Global</h1>
      <p class="hub-tagline">
        Four years of designing how people, teams, and AI work together at enterprise scale.
        From AI-powered customer research to global communities of practice &mdash; every project
        here is about turning complexity into clarity.
      </p>
      <div class="hub-stats">
        <div class="stat-card">
          <span class="stat-value">7</span>
          <span class="stat-label">Projects</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">20K+</span>
          <span class="stat-label">Data points analyzed</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">18</span>
          <span class="stat-label">Countries impacted</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">1,800+</span>
          <span class="stat-label">Users on tools I designed</span>
        </div>
      </div>
    </div>
  </section>

  <section class="hub-projects">
    <div class="container">
      <div class="projects-grid">
        {
          ikeaProjects.map((project, i) => (
            <a href={`/projects/${project.slug}`} class="project-card">
              <div class="card-index">0{i + 1}</div>
              <div class="card-content">
                <p class="card-period">{project.period}</p>
                <h2 class="card-title">{project.title}</h2>
                <p class="card-tagline">{project.tagline}</p>
                <div class="card-metric">
                  <span class="card-metric-value">{project.heroMetrics[0].value}</span>
                  <span class="card-metric-label">{project.heroMetrics[0].label}</span>
                </div>
              </div>
              <span class="card-arrow">&rarr;</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="hub-cta">
    <div class="container">
      <div class="cta-card">
        <p class="cta-text">Want to see how these projects connect?</p>
        <a href="/#experience" class="btn-primary">&larr; Back to portfolio</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* NAV */
  .project-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(8, 8, 15, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .project-nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-back {
    font-size: 0.875rem;
    color: var(--muted);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-back:hover {
    color: var(--accent);
  }

  .nav-logo {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  .nav-breadcrumb {
    font-size: 0.8rem;
    color: var(--muted);
  }

  /* HERO */
  .hub-hero {
    padding: 10rem 0 5rem;
    background: radial-gradient(
      ellipse 80% 60% at 50% 0%,
      rgba(100, 255, 218, 0.04) 0%,
      transparent 70%
    );
  }

  .hub-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    animation: fadeUp 0.6s ease both;
  }

  .hub-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.05;
    color: var(--text);
    margin-bottom: 1.25rem;
    animation: fadeUp 0.6s 0.1s ease both;
  }

  .hub-tagline {
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 620px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    animation: fadeUp 0.6s 0.2s ease both;
  }

  .hub-stats {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    animation: fadeUp 0.6s 0.3s ease both;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    min-width: 110px;
  }

  .stat-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .stat-label {
    font-size: 0.7rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* PROJECTS GRID */
  .hub-projects {
    padding: 4rem 0 6rem;
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project-card {
    display: grid;
    grid-template-columns: 3.5rem 1fr 2rem;
    gap: 1.5rem;
    align-items: center;
    padding: 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .project-card:hover {
    border-color: rgba(100, 255, 218, 0.3);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(100, 255, 218, 0.06);
  }

  .card-index {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent);
    opacity: 0.4;
    line-height: 1;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-period {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }

  .card-tagline {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
    max-width: 600px;
  }

  .card-metric {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .card-metric-value {
    font-size: 1rem;
    font-weight: 700;
    color: var(--accent);
  }

  .card-metric-label {
    font-size: 0.7rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .card-arrow {
    font-size: 1.25rem;
    color: var(--muted);
    transition: all 0.2s;
  }

  .project-card:hover .card-arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  /* CTA */
  .hub-cta {
    padding: 0 0 6rem;
  }

  .cta-card {
    text-align: center;
    padding: 3rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .cta-text {
    font-size: 1rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    background: var(--accent);
    color: var(--bg);
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.2s;
    letter-spacing: 0.01em;
  }

  .btn-primary:hover {
    background: #8fffea;
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(100, 255, 218, 0.15);
  }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .hub-stats {
      gap: 0.75rem;
    }

    .stat-card {
      min-width: 0;
      flex: 1 1 calc(50% - 0.75rem);
      padding: 1rem;
    }

    .project-card {
      grid-template-columns: 1fr 1.5rem;
      padding: 1.5rem;
      gap: 1rem;
    }

    .card-index {
      display: none;
    }

    .project-nav-inner .nav-breadcrumb {
      display: none;
    }
  }
</style>
