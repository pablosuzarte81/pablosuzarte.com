---
import Layout from '../../layouts/Layout.astro'
import { projects } from '../../data/projects'
import type { ProjectCase } from '../../data/projects'

export async function getStaticPaths() {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }))
}

interface Props {
  project: ProjectCase
}

const { project } = Astro.props
const nextProject = project.nextProjectSlug
  ? (projects.find((p) => p.slug === project.nextProjectSlug) ?? null)
  : null
---

<Layout title={`${project.title} — Pablo Suzarte`} description={project.tagline} lang="en">
  <!-- BACK NAV -->
  <header class="project-nav">
    <div class="project-nav-inner">
      <a href="/" class="nav-back">← Back</a>
      <a href="/" class="nav-logo">PS</a>
      <span class="nav-breadcrumb">{project.company}</span>
    </div>
  </header>

  <!-- HERO -->
  <section class="project-hero">
    <div class="container">
      <p class="project-meta">{project.company} · {project.role} · {project.period}</p>
      <h1 class="project-title">{project.title}</h1>
      <p class="project-tagline">{project.tagline}</p>
      <div class="hero-metrics">
        {
          project.heroMetrics.map((m) => (
            <div class="metric-card">
              <span class="metric-value">{m.value}</span>
              <span class="metric-label">{m.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- OVERVIEW -->
  <section class="section">
    <div class="container section-grid">
      <div class="section-label">
        <span class="label-num">01</span>
        <h2 class="section-title">Overview</h2>
        <div class="accent-line"></div>
      </div>
      <div class="section-body">
        <div class="overview-grid">
          <div class="overview-card">
            <p class="card-label">Business Need</p>
            <p>{project.businessNeed}</p>
          </div>
          <div class="overview-card">
            <p class="card-label">User Need</p>
            <p>{project.userNeed}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MY ROLE -->
  <section class="section section-alt">
    <div class="container section-grid">
      <div class="section-label">
        <span class="label-num">02</span>
        <h2 class="section-title">My Role</h2>
        <div class="accent-line"></div>
      </div>
      <div class="section-body">
        <p class="role-title">{project.roleTitle}</p>
        <ul class="highlights-list">
          {project.responsibilities.map((r) => <li>{r}</li>)}
        </ul>
        <div class="owned-collab-grid">
          <div>
            <p class="card-label">What I owned</p>
            <ul class="plain-list">
              {project.owned.map((o) => <li>{o}</li>)}
            </ul>
          </div>
          <div>
            <p class="card-label">What was collaborative</p>
            <ul class="plain-list">
              {project.collaborated.map((c) => <li>{c}</li>)}
            </ul>
          </div>
        </div>
        <p class="team-context">{project.teamContext}</p>
      </div>
    </div>
  </section>

  <!-- PROBLEM FRAMING -->
  <section class="section">
    <div class="container section-grid">
      <div class="section-label">
        <span class="label-num">03</span>
        <h2 class="section-title">Problem Framing</h2>
        <div class="accent-line"></div>
      </div>
      <div class="section-body">
        <blockquote class="hmw-statement">
          {project.challengeStatement}
        </blockquote>
        <p class="discovery-note">{project.problemDiscovery}</p>
      </div>
    </div>
  </section>

  <!-- RESEARCH -->
  <section class="section section-alt">
    <div class="container section-grid">
      <div class="section-label">
        <span class="label-num">04</span>
        <h2 class="section-title">Research</h2>
        <div class="accent-line"></div>
      </div>
      <div class="section-body">
        <div class="research-grid">
          {
            project.researchMethods.map((m) => (
              <div class="research-card">
                <p class="research-method">{m.method}</p>
                <p class="research-detail">{m.detail}</p>
              </div>
            ))
          }
        </div>
        <div class="workshops-list">
          <p class="card-label">Workshops</p>
          {
            project.workshops.map((w) => (
              <div class="workshop-item">
                <span class="workshop-type">{w.type}</span>
                <span class="workshop-participants">{w.participants}</span>
              </div>
            ))
          }
        </div>
        <p class="research-note">{project.dataAnalysisApproach}</p>
        <p class="research-note">{project.sharingSessions}</p>
      </div>
    </div>
  </section>

  <!-- SYNTHESIS -->
  <section class="section">
    <div class="container section-grid">
      <div class="section-label">
        <span class="label-num">05</span>
        <h2 class="section-title">Synthesis</h2>
        <div class="accent-line"></div>
      </div>
      <div class="section-body">
        <div class="insights-list">
          {
            project.insights.map((insight, i) => (
              <div class="insight-row">
                <span class="insight-num">0{i + 1}</span>
                <p class="insight-text">{insight}</p>
              </div>
            ))
          }
        </div>
        <div class="opportunities-grid">
          {
            project.opportunities.map((opp) => (
              <div class="opp-card">
                <p class="opp-text">{opp.opportunity}</p>
                <p class="opp-impact">
                  <span class="card-label">Impact: </span>{opp.impact}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- DESIGN PROCESS -->
  <section class="section section-alt">
    <div class="container section-grid">
      <div class="section-label">
        <span class="label-num">06</span>
        <h2 class="section-title">Design Process</h2>
        <div class="accent-line"></div>
      </div>
      <div class="section-body">
        <div class="timeline">
          {
            project.designSteps.map((step, i) => (
              <div class="timeline-item">
                <div class="timeline-marker">
                  <div class="timeline-dot" />
                  {i < project.designSteps.length - 1 && <div class="timeline-line" />}
                </div>
                <div class="timeline-card">
                  <p class="phase-name">{step.phase}</p>
                  <p class="phase-desc">{step.description}</p>
                  {step.stakeholderMoment && (
                    <div class="stakeholder-callout">
                      <p class="callout-label">Stakeholder alignment</p>
                      <p class="callout-text">{step.stakeholderMoment}</p>
                    </div>
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- IMPACT -->
  <section class="section">
    <div class="container section-grid">
      <div class="section-label">
        <span class="label-num">07</span>
        <h2 class="section-title">Impact</h2>
        <div class="accent-line"></div>
      </div>
      <div class="section-body">
        <div class="outcome-metrics">
          {
            project.outcomeMetrics.map((m) => (
              <div class="outcome-card">
                <span class="outcome-value">{m.value}</span>
                <span class="outcome-label">{m.label}</span>
                <span class="outcome-context">{m.context}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- NEXT / BACK -->
  <section class="section section-alt">
    <div class="container">
      {
        nextProject ? (
          <div class="next-project-card">
            <span class="next-label">Next project →</span>
            <p class="next-meta">{nextProject.company}</p>
            <h3 class="next-title">{nextProject.title}</h3>
            <a href={`/projects/${nextProject.slug}`} class="btn-primary">
              View case study →
            </a>
          </div>
        ) : (
          <div class="back-link-wrap">
            <a href="/#work" class="back-link">← Back to all work</a>
          </div>
        )
      }
    </div>
  </section>
</Layout>

<style>
  /* ── LAYOUT ── */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section {
    padding: 7rem 0;
  }

  .section-alt {
    background: var(--surface);
  }

  .section-grid {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* ── SECTION LABELS ── */
  .section-label {
    position: sticky;
    top: 100px;
  }

  .label-num {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .accent-line {
    width: 32px;
    height: 2px;
    background: var(--accent);
    border-radius: 1px;
  }

  .section-body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ── NAV ── */
  .project-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(8, 8, 15, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .project-nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-back {
    font-size: 0.875rem;
    color: var(--muted-light);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-back:hover {
    color: var(--accent);
  }

  .nav-logo {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  .nav-breadcrumb {
    font-size: 0.8rem;
    color: var(--muted);
  }

  /* ── HERO ── */
  .project-hero {
    padding: 10rem 0 6rem;
    background: radial-gradient(
      ellipse 80% 60% at 50% 0%,
      rgba(100, 255, 218, 0.04) 0%,
      transparent 70%
    );
  }

  .project-meta {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    animation: fadeUp 0.6s ease both;
  }

  .project-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--text);
    margin-bottom: 1rem;
    animation: fadeUp 0.6s 0.1s ease both;
  }

  .project-tagline {
    font-size: 1.1rem;
    color: var(--muted-light);
    max-width: 600px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    animation: fadeUp 0.6s 0.2s ease both;
  }

  .hero-metrics {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    animation: fadeUp 0.6s 0.3s ease both;
  }

  .metric-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    min-width: 110px;
  }

  .metric-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .metric-label {
    font-size: 0.75rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ── SHARED CARD LABEL ── */
  .card-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  /* ── OVERVIEW ── */
  .overview-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .overview-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
  }

  .overview-card p:last-child {
    font-size: 0.95rem;
    color: var(--muted-light);
    line-height: 1.65;
  }

  /* ── MY ROLE ── */
  .role-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--accent);
  }

  .highlights-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .highlights-list li {
    font-size: 0.875rem;
    color: var(--muted-light);
    padding-left: 1rem;
    position: relative;
  }

  .highlights-list li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.7rem;
    top: 0.15em;
  }

  .owned-collab-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .plain-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .plain-list li {
    font-size: 0.875rem;
    color: var(--muted-light);
    padding-left: 1rem;
    position: relative;
  }

  .plain-list li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.7rem;
    top: 0.15em;
  }

  .team-context {
    font-size: 0.9rem;
    color: var(--muted);
    font-style: italic;
  }

  /* ── PROBLEM FRAMING ── */
  .hmw-statement {
    border-left: 3px solid var(--accent);
    padding: 1.25rem 1.5rem;
    margin: 0;
    font-size: 1.15rem;
    font-style: italic;
    color: var(--text);
    line-height: 1.65;
    background: var(--surface-2);
    border-radius: 0 8px 8px 0;
  }

  .discovery-note {
    font-size: 0.9rem;
    color: var(--muted-light);
  }

  /* ── RESEARCH ── */
  .research-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .research-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
  }

  .research-method {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.35rem;
  }

  .research-detail {
    font-size: 0.8rem;
    color: var(--muted-light);
  }

  .workshops-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .workshop-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    gap: 1rem;
  }

  .workshop-item:last-child {
    border-bottom: none;
  }

  .workshop-type {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
  }

  .workshop-participants {
    font-size: 0.8rem;
    color: var(--muted-light);
    text-align: right;
  }

  .research-note {
    font-size: 0.9rem;
    color: var(--muted-light);
    line-height: 1.65;
  }

  /* ── SYNTHESIS ── */
  .insights-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .insight-row {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1rem;
    align-items: start;
  }

  .insight-num {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1.3;
  }

  .insight-text {
    font-size: 0.95rem;
    color: var(--muted-light);
    line-height: 1.65;
    padding-top: 0.2rem;
  }

  .opportunities-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .opp-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .opp-text {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.5;
  }

  .opp-impact {
    font-size: 0.8rem;
    color: var(--muted-light);
  }

  /* ── TIMELINE ── */
  .timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 1.5rem;
    padding-bottom: 3rem;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 0.35rem;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    box-shadow: 0 0 0 3px var(--accent-dim);
  }

  .timeline-line {
    width: 1px;
    flex: 1;
    background: var(--border);
    margin-top: 0.5rem;
  }

  .timeline-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    transition: border-color 0.2s;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .timeline-card:hover {
    border-color: var(--accent-glow);
  }

  .phase-name {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .phase-desc {
    font-size: 0.9rem;
    color: var(--muted-light);
    line-height: 1.6;
  }

  .stakeholder-callout {
    border-left: 2px solid var(--accent);
    padding: 0.75rem 1rem;
    margin-top: 0.5rem;
    background: var(--surface);
    border-radius: 0 6px 6px 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .callout-label {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .callout-text {
    font-size: 0.8rem;
    color: var(--muted-light);
    font-style: italic;
    line-height: 1.55;
  }

  /* ── IMPACT ── */
  .outcome-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .outcome-card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1.75rem 2rem;
    background: var(--accent-dim);
    border: 1px solid var(--border);
    border-radius: 10px;
    min-width: 200px;
    flex: 1;
  }

  .outcome-value {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }

  .outcome-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
  }

  .outcome-context {
    font-size: 0.75rem;
    color: var(--muted);
    line-height: 1.5;
    margin-top: 0.25rem;
  }

  /* ── NEXT / BACK ── */
  .next-project-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 3rem;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 12px;
    max-width: 640px;
    margin: 0 auto;
    align-items: flex-start;
  }

  .next-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .next-meta {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .next-title {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .back-link-wrap {
    text-align: center;
  }

  .back-link {
    font-size: 0.9rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .back-link:hover {
    opacity: 0.8;
  }

  /* ── BUTTONS ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    background: var(--accent);
    color: var(--bg);
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.2s;
    letter-spacing: 0.01em;
  }

  .btn-primary:hover {
    background: #8fffea;
    transform: translateY(-1px);
    box-shadow: 0 8px 24px var(--accent-glow);
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .section-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .section-label {
      position: static;
    }

    .overview-grid,
    .owned-collab-grid,
    .research-grid,
    .opportunities-grid {
      grid-template-columns: 1fr;
    }

    .timeline-item {
      grid-template-columns: 20px 1fr;
      gap: 1rem;
    }

    .workshop-item {
      flex-direction: column;
      align-items: flex-start;
    }

    .workshop-participants {
      text-align: left;
    }

    .outcome-card {
      min-width: 100%;
    }

    .next-project-card {
      padding: 2rem;
    }

