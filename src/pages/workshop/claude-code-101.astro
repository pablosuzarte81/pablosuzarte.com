---
import Layout from '../../layouts/Layout.astro'
---

<Layout title="Claude Code 101 — From Prompting to Orchestrating | Pablo Suzarte" description="A hands-on workshop template to take anyone from zero to orchestrating AI agents with Claude Code in terminal." lang="en">
  <header class="ws-nav">
    <div class="ws-nav-inner">
      <a href="/" class="nav-back">&larr; Portfolio</a>
      <a href="/" class="nav-logo">PS</a>
      <span class="nav-breadcrumb">Workshop Template</span>
    </div>
  </header>

  <article class="ws">
    <!-- HERO -->
    <section class="ws-hero">
      <div class="ws-container">
        <p class="ws-kicker">Workshop Template</p>
        <h1 class="ws-title">Claude Code 101</h1>
        <p class="ws-subtitle">From prompting a chatbot to orchestrating agents that solve real problems.</p>
        <div class="ws-meta-row">
          <div class="ws-meta-item">
            <span class="ws-meta-label">Duration</span>
            <span class="ws-meta-value">3–4 hours</span>
          </div>
          <div class="ws-meta-item">
            <span class="ws-meta-label">Level</span>
            <span class="ws-meta-value">Beginner → Advanced</span>
          </div>
          <div class="ws-meta-item">
            <span class="ws-meta-label">Format</span>
            <span class="ws-meta-value">Hands-on, terminal-based</span>
          </div>
          <div class="ws-meta-item">
            <span class="ws-meta-label">Outcome</span>
            <span class="ws-meta-value">Fully set up AI working environment</span>
          </div>
        </div>
      </div>
    </section>

    <!-- PHILOSOPHY -->
    <section class="ws-section">
      <div class="ws-container">
        <p class="ws-section-num">00</p>
        <h2 class="ws-section-title">The mindset before the tool</h2>
        <div class="ws-body">
          <p>Most people prompt a chatbot. By the end of this workshop, you will orchestrate agents to handle complex, multi-step tasks. The difference is not the tool — it is the environment you design around it.</p>
          <p>This workshop is built on <strong>Project Intelligence Principles</strong> — the same framework I use to set up human-AI collaboration at scale. Each module maps to a principle.</p>
          <div class="ws-principle-map">
            <div class="ws-pm-item"><span class="ws-pm-num">01</span><span class="ws-pm-principle">Shared Memory</span><span class="ws-pm-arrow">→</span><span class="ws-pm-module">CLAUDE.md & project setup</span></div>
            <div class="ws-pm-item"><span class="ws-pm-num">02</span><span class="ws-pm-principle">Current Orientation</span><span class="ws-pm-arrow">→</span><span class="ws-pm-module">First conversation & context</span></div>
            <div class="ws-pm-item"><span class="ws-pm-num">03</span><span class="ws-pm-principle">Evidence Discipline</span><span class="ws-pm-arrow">→</span><span class="ws-pm-module">Reading & understanding code</span></div>
            <div class="ws-pm-item"><span class="ws-pm-num">04</span><span class="ws-pm-principle">Collaboration Clarity</span><span class="ws-pm-arrow">→</span><span class="ws-pm-module">Permissions & working agreements</span></div>
            <div class="ws-pm-item"><span class="ws-pm-num">05</span><span class="ws-pm-principle">Role Clarity</span><span class="ws-pm-arrow">→</span><span class="ws-pm-module">Custom agents & slash commands</span></div>
            <div class="ws-pm-item"><span class="ws-pm-num">06</span><span class="ws-pm-principle">Decision Continuity</span><span class="ws-pm-arrow">→</span><span class="ws-pm-module">Memory system & persistence</span></div>
            <div class="ws-pm-item"><span class="ws-pm-num">07</span><span class="ws-pm-principle">Asset Awareness</span><span class="ws-pm-arrow">→</span><span class="ws-pm-module">MCP servers & external tools</span></div>
            <div class="ws-pm-item"><span class="ws-pm-num">08</span><span class="ws-pm-principle">Reusable Patterns</span><span class="ws-pm-arrow">→</span><span class="ws-pm-module">Orchestrating complex tasks</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- PRE-REQUISITES -->
    <section class="ws-section ws-section--alt">
      <div class="ws-container">
        <p class="ws-section-num">Setup</p>
        <h2 class="ws-section-title">Before the workshop</h2>
        <div class="ws-body">
          <p>Participants need these ready before we start:</p>
          <div class="ws-checklist">
            <div class="ws-check"><span class="ws-check-box">&#9744;</span><div><strong>Node.js 22+</strong> — <code>node --version</code> to verify</div></div>
            <div class="ws-check"><span class="ws-check-box">&#9744;</span><div><strong>A terminal</strong> — macOS Terminal, iTerm2, Windows Terminal, or VS Code integrated terminal</div></div>
            <div class="ws-check"><span class="ws-check-box">&#9744;</span><div><strong>An Anthropic account</strong> — sign up at claude.ai, you will authenticate during install</div></div>
            <div class="ws-check"><span class="ws-check-box">&#9744;</span><div><strong>A project folder</strong> — any personal project, side project, or even an empty folder to experiment with</div></div>
            <div class="ws-check"><span class="ws-check-box">&#9744;</span><div><strong>Git installed</strong> — Claude Code works best inside git repositories</div></div>
          </div>
          <div class="ws-code-block">
            <p class="ws-code-label">Step 1 — Install</p>
            <div class="ws-cmd" data-cmd="npm install -g @anthropic-ai/claude-code">
              <code>npm install -g @anthropic-ai/claude-code</code>
              <button type="button" class="ws-copy" aria-label="Copy command">Copy</button>
            </div>
          </div>
          <div class="ws-code-block">
            <p class="ws-code-label">Step 2 — Launch</p>
            <div class="ws-cmd" data-cmd="claude">
              <code>claude</code>
              <button type="button" class="ws-copy" aria-label="Copy command">Copy</button>
            </div>
            <p class="ws-code-note">That's it. First run opens a browser to log in. After that, you're in.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- MODULE 01 -->
    <section class="ws-section">
      <div class="ws-container">
        <p class="ws-section-num">01</p>
        <h2 class="ws-section-title">Shared Memory — teaching AI who you are</h2>
        <p class="ws-principle-tag">Principle: AI needs a clear understanding of what the project is, why it matters, and what must not be misunderstood.</p>
        <div class="ws-body">
          <h3>What you will do</h3>
          <p>Create a <code>CLAUDE.md</code> file — the shared memory between you and AI. This is not a README. It is a living agreement about what is true.</p>

          <h3>Why it matters</h3>
          <p>Without shared memory, every conversation starts from zero. With it, Claude Code understands your project, your stack, your conventions, and your constraints from the first message.</p>

          <div class="ws-exercise">
            <p class="ws-exercise-label">Try it — 15 min</p>
            <p>Inside Claude Code, run this — it scans your project and generates a CLAUDE.md for you:</p>
            <div class="ws-cmd ws-cmd--prompt" data-cmd="/init">
              <code>/init</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <p>Then edit the generated file together. Make sure it answers:</p>
            <ol>
              <li>What is this project? (one paragraph)</li>
              <li>What is the tech stack?</li>
              <li>What commands matter? (dev, build, test, deploy)</li>
              <li>What conventions should never be broken?</li>
              <li>What should AI never do? (delete files, push to main, etc.)</li>
            </ol>
          </div>

          <div class="ws-code-block">
            <p class="ws-code-label">Example CLAUDE.md — copy and adapt for your project</p>
            <div class="ws-cmd ws-cmd--multi" data-cmd="# My Project&#10;&#10;## Stack&#10;- Next.js 15, TypeScript, Tailwind CSS&#10;- Deployed on Vercel&#10;&#10;## Commands&#10;- npm run dev — start dev server&#10;- npm run build — production build&#10;&#10;## Conventions&#10;- All components in src/components/&#10;- Never modify package-lock.json manually&#10;- Do not push to main without review">
              <pre><code># My Project

## Stack
- Next.js 15, TypeScript, Tailwind CSS
- Deployed on Vercel

## Commands
- npm run dev — start dev server
- npm run build — production build

## Conventions
- All components in src/components/
- Never modify package-lock.json manually
- Do not push to main without review</code></pre>
              <button type="button" class="ws-copy" aria-label="Copy to clipboard">Copy</button>
            </div>
          </div>

          <div class="ws-key-insight">
            <strong>Key insight:</strong> CLAUDE.md is automatically loaded into every conversation. It is the most important file in your project for AI collaboration.
          </div>
        </div>
      </div>
    </section>

    <!-- MODULE 02 -->
    <section class="ws-section ws-section--alt">
      <div class="ws-container">
        <p class="ws-section-num">02</p>
        <h2 class="ws-section-title">Current Orientation — your first real conversation</h2>
        <p class="ws-principle-tag">Principle: The project needs a visible sense of where things stand now.</p>
        <div class="ws-body">
          <h3>What you will do</h3>
          <p>Have your first meaningful conversation with Claude Code. Not "write me a function" — but "understand where I am and help me move forward."</p>

          <div class="ws-exercise">
            <p class="ws-exercise-label">Try it — 15 min</p>
            <p>Open your project in terminal. Copy and paste these one at a time:</p>
            <div class="ws-cmd" data-cmd="claude">
              <code>claude</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <p>Once inside, try these prompts progressively:</p>
            <div class="ws-cmd ws-cmd--prompt" data-cmd="Read the project and tell me what you understand about it">
              <code>Read the project and tell me what you understand about it</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <div class="ws-cmd ws-cmd--prompt" data-cmd="What are the main files and how do they connect?">
              <code>What are the main files and how do they connect?</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <div class="ws-cmd ws-cmd--prompt" data-cmd="I want to add a dark mode toggle. What is your approach before writing any code?">
              <code>I want to add a dark mode toggle. What is your approach before writing any code?</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <p>Watch what happens. Claude reads your files, understands your structure, and reasons about your project. This is not a chatbot — it is an agent with tools.</p>
          </div>

          <div class="ws-tools-grid">
            <div class="ws-tool"><strong>Read</strong><span>Reads any file in your project</span></div>
            <div class="ws-tool"><strong>Glob</strong><span>Finds files by pattern (*.tsx, src/**/*)</span></div>
            <div class="ws-tool"><strong>Grep</strong><span>Searches content across files</span></div>
            <div class="ws-tool"><strong>Bash</strong><span>Runs terminal commands</span></div>
            <div class="ws-tool"><strong>Edit</strong><span>Makes precise changes to files</span></div>
            <div class="ws-tool"><strong>Write</strong><span>Creates new files</span></div>
          </div>

          <div class="ws-key-insight">
            <strong>Key insight:</strong> Claude Code is not generating text — it is using tools to explore, understand, and modify your actual codebase. The quality of its work depends on how well you orient it.
          </div>
        </div>
      </div>
    </section>

    <!-- MODULE 03 -->
    <section class="ws-section">
      <div class="ws-container">
        <p class="ws-section-num">03</p>
        <h2 class="ws-section-title">Evidence Discipline — read before you write</h2>
        <p class="ws-principle-tag">Principle: Ideas should be grounded in visible evidence, not assumptions.</p>
        <div class="ws-body">
          <h3>What you will do</h3>
          <p>Learn to ask Claude Code to investigate before acting. The most common mistake beginners make: asking AI to write code without understanding the existing code first.</p>

          <div class="ws-exercise">
            <p class="ws-exercise-label">Try it — 20 min</p>
            <p>Pick a real file in your project. Before asking Claude to change anything, make it investigate first:</p>
            <div class="ws-cmd ws-cmd--prompt" data-cmd="Read src/components/Header.tsx and explain how it works">
              <code>Read src/components/Header.tsx and explain how it works</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <div class="ws-cmd ws-cmd--prompt" data-cmd="How do other components in this project handle navigation?">
              <code>How do other components in this project handle navigation?</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <div class="ws-cmd ws-cmd--prompt" data-cmd="Now implement the change, following the patterns you found">
              <code>Now implement the change, following the patterns you found</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <p>Replace the file paths with your own. The pattern is always: <strong>read → understand → then act.</strong></p>
          </div>

          <div class="ws-key-insight">
            <strong>Key insight:</strong> An AI collaborator will treat an assumption as a fact if you present it as one. The discipline to say "read first, then act" produces dramatically better results.
          </div>
        </div>
      </div>
    </section>

    <!-- MODULE 04 -->
    <section class="ws-section ws-section--alt">
      <div class="ws-container">
        <p class="ws-section-num">04</p>
        <h2 class="ws-section-title">Collaboration Clarity — permissions and trust</h2>
        <p class="ws-principle-tag">Principle: Good results depend on knowing how to work together well.</p>
        <div class="ws-body">
          <h3>What you will do</h3>
          <p>Configure how Claude Code works with you. Permissions are not restrictions — they are working agreements.</p>

          <div class="ws-exercise">
            <p class="ws-exercise-label">Try it — 10 min</p>
            <p>Inside Claude Code, check your current permissions:</p>
            <div class="ws-cmd ws-cmd--prompt" data-cmd="/permissions">
              <code>/permissions</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <p>Now try something that needs approval. When prompted, notice you can allow it just once, for the session, or permanently.</p>
            <p>Pro tip: press <strong>Shift+Tab</strong> to cycle between permission modes (Default → Auto-accept edits → Plan mode).</p>
          </div>

          <div class="ws-key-insight">
            <strong>Key insight:</strong> Start strict, loosen as trust builds. This mirrors how you onboard any new team member — you give more autonomy as they prove they understand the context.
          </div>
        </div>
      </div>
    </section>

    <!-- MODULE 05 -->
    <section class="ws-section">
      <div class="ws-container">
        <p class="ws-section-num">05</p>
        <h2 class="ws-section-title">Role Clarity — custom agents and commands</h2>
        <p class="ws-principle-tag">Principle: Every collaborator should have a clear role and responsibility.</p>
        <div class="ws-body">
          <h3>What you will do</h3>
          <p>Create custom slash commands that give Claude Code specific roles. Instead of one general AI, you design specialised agents.</p>

          <div class="ws-exercise">
            <p class="ws-exercise-label">Try it — 20 min</p>
            <p>Create your first custom command. Run these in your terminal (not inside Claude):</p>
            <div class="ws-cmd" data-cmd="mkdir -p .claude/commands">
              <code>mkdir -p .claude/commands</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <p>Now paste the review.md content from below into <code>.claude/commands/review.md</code>. Then go back into Claude Code and type:</p>
            <div class="ws-cmd ws-cmd--prompt" data-cmd="/review">
              <code>/review</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <p>That's it. You just created a specialist agent.</p>
          </div>

          <div class="ws-code-block">
            <p class="ws-code-label">Example: .claude/commands/review.md — copy this to get started</p>
            <div class="ws-cmd ws-cmd--multi" data-cmd="You are a senior code reviewer. Review the staged&#10;changes (git diff --cached) and provide feedback on:&#10;&#10;1. Code quality and readability&#10;2. Potential bugs or edge cases&#10;3. Performance considerations&#10;4. Whether the changes follow the project conventions&#10;   defined in CLAUDE.md&#10;&#10;Be direct. If it looks good, say so briefly.">
              <pre><code>You are a senior code reviewer. Review the staged
changes (git diff --cached) and provide feedback on:

1. Code quality and readability
2. Potential bugs or edge cases
3. Performance considerations
4. Whether the changes follow the project conventions
   defined in CLAUDE.md

Be direct. If it looks good, say so briefly.</code></pre>
              <button type="button" class="ws-copy" aria-label="Copy to clipboard">Copy</button>
            </div>
          </div>

          <div class="ws-key-insight">
            <strong>Key insight:</strong> Custom commands turn Claude Code from a general assistant into a team of specialists. A <code>/review</code> agent, a <code>/test</code> agent, a <code>/deploy</code> agent — each with a clear role.
          </div>
        </div>
      </div>
    </section>

    <!-- MODULE 06 -->
    <section class="ws-section ws-section--alt">
      <div class="ws-container">
        <p class="ws-section-num">06</p>
        <h2 class="ws-section-title">Decision Continuity — memory that persists</h2>
        <p class="ws-principle-tag">Principle: Decisions and reasoning should be preserved so the team does not restart the same thinking.</p>
        <div class="ws-body">
          <h3>What you will do</h3>
          <p>Learn how Claude Code's memory system works. Conversations end, but important decisions should survive.</p>

          <div class="ws-exercise">
            <p class="ws-exercise-label">Try it — 15 min</p>
            <p>Inside Claude Code, make a decision and ask it to remember:</p>
            <div class="ws-cmd ws-cmd--prompt" data-cmd="Let's use server components for all data fetching. Remember this decision.">
              <code>Let's use server components for all data fetching. Remember this decision.</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <p>Now clear the conversation and test if it stuck:</p>
            <div class="ws-cmd ws-cmd--prompt" data-cmd="/clear">
              <code>/clear</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <div class="ws-cmd ws-cmd--prompt" data-cmd="What are our design decisions?">
              <code>What are our design decisions?</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
          </div>

          <div class="ws-key-insight">
            <strong>Key insight:</strong> The biggest failure mode in AI-assisted projects is losing context between sessions. CLAUDE.md + the memory system solve this — decisions carry forward, not just code.
          </div>
        </div>
      </div>
    </section>

    <!-- MODULE 07 -->
    <section class="ws-section">
      <div class="ws-container">
        <p class="ws-section-num">07</p>
        <h2 class="ws-section-title">Asset Awareness — connecting external tools</h2>
        <p class="ws-principle-tag">Principle: Both humans and AI need to know what materials exist.</p>
        <div class="ws-body">
          <h3>What you will do</h3>
          <p>Connect Claude Code to external services using MCP (Model Context Protocol) servers. This extends what Claude can see and do.</p>

          <div class="ws-exercise">
            <p class="ws-exercise-label">Try it — 15 min</p>
            <p>Inside Claude Code, open the settings:</p>
            <div class="ws-cmd ws-cmd--prompt" data-cmd="/settings">
              <code>/settings</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <p>Add an MCP server — Vercel, GitHub, or a file system server. Then try something like:</p>
            <div class="ws-cmd ws-cmd--prompt" data-cmd="Check my latest Vercel deployments">
              <code>Check my latest Vercel deployments</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <p>Claude now has awareness of systems outside your codebase. That is asset awareness.</p>
          </div>

          <div class="ws-key-insight">
            <strong>Key insight:</strong> MCP servers turn Claude Code from a code assistant into a workspace assistant. It can read your deployments, your project management tools, your documentation — anything you connect.
          </div>
        </div>
      </div>
    </section>

    <!-- MODULE 08 -->
    <section class="ws-section ws-section--alt">
      <div class="ws-container">
        <p class="ws-section-num">08</p>
        <h2 class="ws-section-title">Reusable Patterns — orchestrating complex tasks</h2>
        <p class="ws-principle-tag">Principle: Workflows that work well should be saved, refined, and reused.</p>
        <div class="ws-body">
          <h3>What you will do</h3>
          <p>This is where it all comes together. You will orchestrate a complex, multi-step task — the kind that would take hours manually but minutes with a well-designed AI environment.</p>

          <div class="ws-exercise">
            <p class="ws-exercise-label">Try it — 30 min</p>
            <p>This is the big one. Pick an ambitious task and give Claude the full context:</p>
            <div class="ws-cmd ws-cmd--prompt" data-cmd="Add a contact form to this site with validation and an API endpoint that sends an email. Read the project first, plan your approach, then implement it.">
              <code>Add a contact form to this site with validation and an API endpoint that sends an email. Read the project first, plan your approach, then implement it.</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <p>Watch what happens. Claude will read your project, propose an approach, create files, edit existing ones, and handle errors — all autonomously. When it's done:</p>
            <div class="ws-cmd ws-cmd--prompt" data-cmd="/commit">
              <code>/commit</code>
              <button type="button" class="ws-copy" aria-label="Copy">Copy</button>
            </div>
            <p>Claude writes the commit message from the actual changes. Review the git diff together.</p>
          </div>

          <div class="ws-progression">
            <p class="ws-progression-title">The progression you just made:</p>
            <div class="ws-progression-steps">
              <div class="ws-prog-step">
                <span class="ws-prog-num">1</span>
                <div>
                  <strong>Prompting</strong>
                  <p>"Write me a function"</p>
                </div>
              </div>
              <div class="ws-prog-arrow">→</div>
              <div class="ws-prog-step">
                <span class="ws-prog-num">2</span>
                <div>
                  <strong>Collaborating</strong>
                  <p>"Read the project, then help me add this feature"</p>
                </div>
              </div>
              <div class="ws-prog-arrow">→</div>
              <div class="ws-prog-step">
                <span class="ws-prog-num">3</span>
                <div>
                  <strong>Orchestrating</strong>
                  <p>"Here is what I need. You have the context, the tools, and the permissions. Go."</p>
                </div>
              </div>
            </div>
          </div>

          <div class="ws-key-insight">
            <strong>Key insight:</strong> The environment you built in modules 01–07 is what makes module 08 possible. Without shared memory, permissions, custom roles, and connected tools — this would be just another chatbot prompt.
          </div>
        </div>
      </div>
    </section>

    <!-- CLOSING -->
    <section class="ws-section">
      <div class="ws-container">
        <p class="ws-section-num">09</p>
        <h2 class="ws-section-title">What you built today</h2>
        <div class="ws-body">
          <div class="ws-outcome-grid">
            <div class="ws-outcome"><span class="ws-outcome-check">&#10003;</span> A CLAUDE.md that teaches AI your project</div>
            <div class="ws-outcome"><span class="ws-outcome-check">&#10003;</span> Permission settings that match your trust level</div>
            <div class="ws-outcome"><span class="ws-outcome-check">&#10003;</span> Custom slash commands for specialised roles</div>
            <div class="ws-outcome"><span class="ws-outcome-check">&#10003;</span> A memory system that carries decisions forward</div>
            <div class="ws-outcome"><span class="ws-outcome-check">&#10003;</span> Connected external tools via MCP</div>
            <div class="ws-outcome"><span class="ws-outcome-check">&#10003;</span> The ability to orchestrate complex, multi-step tasks</div>
          </div>

          <p>You did not just learn a tool. You designed an environment — a working system where your mind collaborates with AI naturally. That is the difference between prompting and orchestrating.</p>
          <p>This is <strong>Project Intelligence</strong>.</p>

          <div class="ws-cta-block">
            <p>Want to run this workshop for your team?</p>
            <a href="https://www.linkedin.com/in/pablosuzarte/" target="_blank" rel="noopener noreferrer" class="ws-cta">Get in touch with Pablo &rarr;</a>
          </div>
        </div>
      </div>
    </section>
  </article>

  <style>
    .ws-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
      background: rgba(10, 10, 15, 0.8); border-bottom: 1px solid var(--border);
    }
    .ws-nav-inner {
      max-width: 900px; margin: 0 auto; padding: 0.9rem 2rem;
      display: flex; align-items: center; gap: 1.5rem;
    }
    .nav-back { color: var(--muted); text-decoration: none; font-size: 0.85rem; font-weight: 500; transition: color 0.2s; }
    .nav-back:hover { color: var(--accent); }
    .nav-logo { font-weight: 800; font-size: 1.1rem; letter-spacing: -0.04em; color: var(--text); text-decoration: none; }
    .nav-breadcrumb { color: var(--muted); font-size: 0.8rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; margin-left: auto; }

    .ws { padding-top: 4rem; }
    .ws-container { max-width: 800px; margin: 0 auto; padding: 0 2rem; }

    .ws-hero { padding: 5rem 0 3rem; border-bottom: 1px solid var(--border); }
    .ws-kicker { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; }
    .ws-title { font-size: clamp(2.5rem, 6vw, 3.5rem); font-weight: 900; line-height: 1; letter-spacing: -0.04em; color: var(--text); margin-bottom: 0.5rem; }
    .ws-subtitle { font-size: clamp(1.05rem, 2vw, 1.25rem); color: var(--muted); line-height: 1.5; max-width: 560px; margin-bottom: 2rem; }

    .ws-meta-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
    .ws-meta-item { padding: 1rem; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; }
    .ws-meta-label { display: block; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.25rem; }
    .ws-meta-value { display: block; font-size: 0.9rem; font-weight: 600; color: var(--text); }

    .ws-section { padding: 4rem 0; }
    .ws-section--alt { background: var(--surface); }
    .ws-section-num { font-size: 0.7rem; font-weight: 800; letter-spacing: 0.12em; color: var(--accent); margin-bottom: 0.5rem; }
    .ws-section-title { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; letter-spacing: -0.02em; color: var(--text); margin-bottom: 0.5rem; line-height: 1.15; }
    .ws-principle-tag { font-size: 0.82rem; color: var(--muted); font-style: italic; margin-bottom: 2rem; max-width: 600px; }

    .ws-body { color: rgba(226, 232, 240, 0.85); font-size: 1rem; line-height: 1.7; }
    .ws-body p { margin-bottom: 1rem; }
    .ws-body h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin: 2rem 0 0.5rem; }
    .ws-body ol, .ws-body ul { margin: 0.5rem 0 1.5rem 1.25rem; }
    .ws-body li { margin-bottom: 0.4rem; }
    .ws-body strong { color: var(--text); }
    .ws-body code { font-size: 0.85em; background: var(--surface-2); padding: 0.15rem 0.4rem; border-radius: 4px; color: var(--accent); }

    .ws-principle-map { display: flex; flex-direction: column; gap: 0.4rem; margin: 1.5rem 0; }
    .ws-pm-item { display: grid; grid-template-columns: 2.5rem 11rem auto 1fr; gap: 0.75rem; align-items: center; padding: 0.6rem 0.8rem; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; font-size: 0.85rem; }
    .ws-pm-num { font-weight: 800; color: var(--accent); font-size: 0.75rem; }
    .ws-pm-principle { font-weight: 700; color: var(--text); }
    .ws-pm-arrow { color: var(--accent); opacity: 0.4; }
    .ws-pm-module { color: var(--muted); }

    .ws-exercise { margin: 1.5rem 0; padding: 1.5rem; background: rgba(100, 255, 218, 0.04); border: 1px solid rgba(100, 255, 218, 0.12); border-left: 3px solid var(--accent); border-radius: 0 10px 10px 0; }
    .ws-exercise-label { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; }

    .ws-code-block { margin: 1.5rem 0; background: var(--surface-2); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
    .ws-code-label { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); padding: 0.75rem 1rem 0.5rem; }
    .ws-code-block pre { padding: 0.5rem 0; overflow-x: auto; margin: 0; }
    .ws-code-block code { font-size: 0.85rem; color: var(--accent); background: none; padding: 0; line-height: 1.6; }
    .ws-code-note { font-size: 0.8rem; color: var(--muted); padding: 0 1rem 0.75rem; }

    /* Copyable command blocks */
    .ws-cmd {
      display: flex; align-items: center; justify-content: space-between; gap: 1rem;
      padding: 0.65rem 0.75rem 0.65rem 1rem;
      background: var(--surface-2); border: 1px solid var(--border); border-radius: 8px;
      margin: 0.5rem 0; cursor: pointer; transition: border-color 0.2s;
    }
    .ws-cmd:hover { border-color: rgba(100, 255, 218, 0.3); }
    .ws-cmd code { font-size: 0.88rem; color: var(--accent); background: none; padding: 0; white-space: nowrap; overflow-x: auto; flex: 1; }
    .ws-cmd--prompt { border-left: 3px solid rgba(100, 255, 218, 0.25); }
    .ws-cmd--prompt code { color: var(--text); white-space: normal; }
    .ws-cmd--multi { flex-direction: column; align-items: stretch; cursor: default; }
    .ws-cmd--multi pre { margin: 0; padding: 0; }
    .ws-cmd--multi code { white-space: pre; }
    .ws-cmd--multi .ws-copy { align-self: flex-end; }

    .ws-copy {
      flex-shrink: 0; padding: 0.35rem 0.75rem; border: 1px solid var(--border);
      border-radius: 6px; background: transparent; color: var(--muted); font-size: 0.72rem;
      font-weight: 700; letter-spacing: 0.04em; cursor: pointer; transition: all 0.15s;
      white-space: nowrap;
    }
    .ws-copy:hover { color: var(--accent); border-color: var(--accent); }
    .ws-copy.ws-copied { color: var(--accent); border-color: var(--accent); background: rgba(100, 255, 218, 0.08); }

    .ws-key-insight { margin: 1.5rem 0; padding: 1rem 1.25rem; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; font-size: 0.9rem; }

    .ws-tools-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; margin: 1.5rem 0; }
    .ws-tool { padding: 0.75rem; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; }
    .ws-tool strong { display: block; font-size: 0.85rem; color: var(--accent); margin-bottom: 0.15rem; }
    .ws-tool span { font-size: 0.75rem; color: var(--muted); }

    .ws-checklist { display: flex; flex-direction: column; gap: 0.5rem; margin: 1rem 0 1.5rem; }
    .ws-check { display: flex; gap: 0.75rem; padding: 0.75rem 1rem; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; font-size: 0.9rem; }
    .ws-check-box { color: var(--accent); flex-shrink: 0; }

    .ws-progression { margin: 2rem 0; padding: 1.5rem; background: var(--surface); border: 1px solid var(--border); border-radius: 12px; }
    .ws-progression-title { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; }
    .ws-progression-steps { display: flex; align-items: flex-start; gap: 0.75rem; }
    .ws-prog-step { flex: 1; display: flex; gap: 0.6rem; }
    .ws-prog-num { font-size: 0.75rem; font-weight: 800; color: var(--accent); background: rgba(100, 255, 218, 0.1); width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; }
    .ws-prog-step strong { display: block; font-size: 0.9rem; color: var(--text); }
    .ws-prog-step p { font-size: 0.8rem; color: var(--muted); margin: 0.15rem 0 0; }
    .ws-prog-arrow { color: var(--accent); opacity: 0.3; font-weight: 800; padding-top: 2px; flex-shrink: 0; }

    .ws-outcome-grid { display: grid; gap: 0.4rem; margin: 0 0 2rem; }
    .ws-outcome { display: flex; align-items: center; gap: 0.75rem; padding: 0.6rem 0; font-size: 0.95rem; color: var(--text); border-bottom: 1px solid rgba(148, 163, 184, 0.08); }
    .ws-outcome-check { color: var(--accent); font-weight: 700; }

    .ws-cta-block { margin-top: 2.5rem; padding: 2rem; background: var(--surface); border: 1px solid var(--border); border-radius: 12px; text-align: center; }
    .ws-cta-block p { font-size: 1rem; color: var(--muted); margin-bottom: 1rem; }
    .ws-cta { display: inline-flex; padding: 0.75rem 1.5rem; background: var(--accent); color: var(--bg); font-weight: 700; font-size: 0.9rem; border-radius: 8px; text-decoration: none; transition: opacity 0.2s; }
    .ws-cta:hover { opacity: 0.85; }

    @media (max-width: 768px) {
      .ws-container { padding: 0 1.25rem; }
      .ws-meta-row { grid-template-columns: repeat(2, 1fr); }
      .ws-tools-grid { grid-template-columns: 1fr; }
      .ws-pm-item { grid-template-columns: 2rem 1fr; gap: 0.4rem; }
      .ws-pm-arrow, .ws-pm-module { display: none; }
      .ws-progression-steps { flex-direction: column; }
      .ws-prog-arrow { transform: rotate(90deg); align-self: center; }
      .ws-hero { padding: 4rem 0 2rem; }
    }

    @media (max-width: 480px) {
      .ws-meta-row { grid-template-columns: 1fr; }
    }
  </style>

  <script is:inline>
    document.querySelectorAll('.ws-copy').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation()
        const container = btn.closest('.ws-cmd')
        const text = container ? container.dataset.cmd : ''
        if (!text) return
        navigator.clipboard.writeText(text.replace(/&#10;/g, '\n')).then(() => {
          btn.textContent = 'Copied!'
          btn.classList.add('ws-copied')
          setTimeout(() => {
            btn.textContent = 'Copy'
            btn.classList.remove('ws-copied')
          }, 2000)
        })
      })
    })
    // Click anywhere on the command block to copy too
    document.querySelectorAll('.ws-cmd:not(.ws-cmd--multi)').forEach(cmd => {
      cmd.addEventListener('click', () => {
        cmd.querySelector('.ws-copy')?.click()
      })
    })
  </script>
</Layout>
