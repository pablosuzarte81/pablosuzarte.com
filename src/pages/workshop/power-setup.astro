      <!-- HERO -->
      <section class="ws-hero">
        <div class="ws-container">
          <p class="ws-kicker">Start here — before anything else</p>
          <h1 class="ws-title">Supercharge<br/>Your Setup</h1>
          <p class="ws-subtitle">Claude Code out of the box is a junior dev with amnesia. These 7 tools turn it into an orchestration machine. Takes 30 minutes. Changes everything.</p>
          <div class="ws-meta-row">
            <div class="ws-meta-item">
              <span class="ws-meta-label">Time</span>
              <span class="ws-meta-value">30 min</span>
            </div>
            <div class="ws-meta-item">
