---
import Layout from '../../layouts/Layout.astro'
import { posts } from '../../data/blog'
import type { BlogPost } from '../../data/blog'

export async function getStaticPaths() {
  return posts.map((p) => ({
    params: { slug: p.slug },
    props: { post: p },
  }))
}

interface Props {
  post: BlogPost
}

const { post } = Astro.props

function renderMarkdown(content: string): string {
  return content
    .split('\n\n')
    .map((block) => {
      block = block.trim()
      if (!block) return ''
      if (block.startsWith('### '))
        return `<h3>${block.slice(4)}</h3>`
      if (block.startsWith('## '))
        return `<h2>${block.slice(3)}</h2>`
      if (block.startsWith('---'))
        return '<hr />'
      if (block.startsWith('- ')) {
        const items = block
          .split('\n')
          .filter((l) => l.trim().startsWith('- '))
          .map((l) => {
            const text = l.trim().slice(2)
            return `<li>${text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')}</li>`
          })
          .join('\n')
        return `<ul>${items}</ul>`
      }
      const formatted = block
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.+?)\*/g, '<em>$1</em>')
        .replace(/ — /g, ' — ')
      return `<p>${formatted}</p>`
    })
    .filter(Boolean)
    .join('\n')
}

const htmlContent = renderMarkdown(post.content)
---

<Layout title={`${post.title} — Pablo Suzarte`} description={post.excerpt} lang="en">
  <header class="blog-nav">
    <div class="blog-nav-inner">
      <a href="/" class="nav-back">&larr; Back</a>
      <a href="/" class="nav-logo">PS</a>
      <span class="nav-breadcrumb">Writing</span>
    </div>
  </header>

  <article class="blog-article">
    <div class="blog-hero">
      <div class="blog-hero-inner">
        <div class="blog-tags">
          {post.tags.map((tag) => <span class="blog-tag">{tag}</span>)}
        </div>
        <h1 class="blog-title">{post.title}</h1>
        <p class="blog-subtitle">{post.subtitle}</p>
        <div class="blog-meta">
          <span>Pablo Suzarte</span>
          <span class="blog-meta-sep">&middot;</span>
          <time datetime={post.date}>
            {new Date(post.date).toLocaleDateString('en-GB', {
              day: 'numeric',
              month: 'long',
              year: 'numeric',
            })}
          </time>
          <span class="blog-meta-sep">&middot;</span>
          <span>{post.readingTime}</span>
        </div>
      </div>
    </div>

    <div class="blog-body">
      <Fragment set:html={htmlContent} />
    </div>

    <footer class="blog-footer">
      <div class="blog-footer-inner">
        <p class="blog-footer-label">Written by</p>
        <p class="blog-footer-author">Pablo Suzarte</p>
        <p class="blog-footer-role">Senior Product UX Designer &middot; IKEA Global</p>
        <div class="blog-footer-links">
          <a href="https://www.linkedin.com/in/pablosuzarte/" target="_blank" rel="noopener noreferrer" class="btn-primary">Connect on LinkedIn</a>
          <a href="/" class="btn-secondary">&larr; Portfolio</a>
        </div>
      </div>
    </footer>
  </article>

  <style>
    .blog-nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      background: rgba(10, 10, 15, 0.8);
      border-bottom: 1px solid var(--border);
    }
    .blog-nav-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0.9rem 2rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .nav-back {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      transition: color 0.2s;
    }
    .nav-back:hover {
      color: var(--accent);
    }
    .nav-logo {
      font-weight: 800;
      font-size: 1.1rem;
      letter-spacing: -0.04em;
      color: var(--text);
      text-decoration: none;
    }
    .nav-breadcrumb {
      color: var(--muted);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-left: auto;
    }

    .blog-article {
      padding-top: 4rem;
    }

    .blog-hero {
      padding: 5rem 2rem 3rem;
      border-bottom: 1px solid var(--border);
    }
    .blog-hero-inner {
      max-width: 720px;
      margin: 0 auto;
    }
    .blog-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
    }
    .blog-tag {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      background: rgba(100, 255, 218, 0.08);
      border: 1px solid rgba(100, 255, 218, 0.15);
      padding: 0.3rem 0.7rem;
      border-radius: 4px;
    }
    .blog-title {
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.04em;
      color: var(--text);
      margin-bottom: 0.75rem;
    }
    .blog-subtitle {
      font-size: clamp(1.1rem, 2vw, 1.35rem);
      line-height: 1.45;
      color: var(--muted);
      font-weight: 400;
      max-width: 600px;
    }
    .blog-meta {
      margin-top: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.85rem;
      color: var(--muted);
      font-weight: 500;
    }
    .blog-meta-sep {
      opacity: 0.4;
    }

    .blog-body {
      max-width: 720px;
      margin: 0 auto;
      padding: 3rem 2rem 4rem;
      color: var(--text);
      font-size: 1.08rem;
      line-height: 1.72;
    }
    .blog-body :global(h2) {
      font-size: clamp(1.5rem, 3vw, 2rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      margin: 3rem 0 1rem;
      color: var(--text);
      line-height: 1.15;
    }
    .blog-body :global(h3) {
      font-size: 1.15rem;
      font-weight: 700;
      margin: 2rem 0 0.5rem;
      color: var(--accent);
    }
    .blog-body :global(p) {
      margin-bottom: 1.25rem;
      color: rgba(226, 232, 240, 0.85);
    }
    .blog-body :global(hr) {
      border: none;
      border-top: 1px solid var(--border);
      margin: 2.5rem 0;
    }
    .blog-body :global(ul) {
      margin-bottom: 1.5rem;
      padding-left: 0;
      list-style: none;
    }
    .blog-body :global(li) {
      position: relative;
      padding-left: 1.25rem;
      margin-bottom: 0.75rem;
      color: rgba(226, 232, 240, 0.85);
    }
    .blog-body :global(li::before) {
      content: '';
      position: absolute;
      left: 0;
      top: 0.65em;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      opacity: 0.6;
    }
    .blog-body :global(strong) {
      color: var(--text);
      font-weight: 700;
    }
    .blog-body :global(em) {
      font-style: italic;
      color: var(--muted);
    }

    .blog-footer {
      border-top: 1px solid var(--border);
      padding: 3rem 2rem 5rem;
    }
    .blog-footer-inner {
      max-width: 720px;
      margin: 0 auto;
      text-align: center;
    }
    .blog-footer-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.5rem;
    }
    .blog-footer-author {
      font-size: 1.25rem;
      font-weight: 800;
      color: var(--text);
      margin-bottom: 0.25rem;
    }
    .blog-footer-role {
      font-size: 0.9rem;
      color: var(--muted);
      margin-bottom: 1.5rem;
    }
    .blog-footer-links {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      padding: 0.75rem 1.5rem;
      background: var(--accent);
      color: var(--bg);
      font-weight: 700;
      font-size: 0.9rem;
      border-radius: 8px;
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .btn-primary:hover {
      opacity: 0.85;
    }
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      padding: 0.75rem 1.5rem;
      border: 1px solid var(--border);
      color: var(--text);
      font-weight: 600;
      font-size: 0.9rem;
      border-radius: 8px;
      text-decoration: none;
      transition: border-color 0.2s;
    }
    .btn-secondary:hover {
      border-color: var(--accent);
    }

    @media (max-width: 768px) {
      .blog-nav-inner {
        padding: 0.75rem 1.25rem;
        gap: 1rem;
      }
      .blog-hero {
        padding: 4rem 1.25rem 2rem;
      }
      .blog-title {
        font-size: 2rem;
      }
      .blog-subtitle {
        font-size: 1rem;
      }
      .blog-meta {
        flex-wrap: wrap;
        gap: 0.35rem;
      }
      .blog-body {
        padding: 2rem 1.25rem 3rem;
        font-size: 1rem;
      }
      .blog-body :global(h2) {
        font-size: 1.35rem;
        margin: 2rem 0 0.75rem;
      }
      .blog-body :global(h3) {
        font-size: 1.05rem;
      }
      .blog-footer {
        padding: 2rem 1.25rem 4rem;
      }
      .blog-footer-links {
        flex-direction: column;
        align-items: stretch;
      }
      .btn-primary,
      .btn-secondary {
        justify-content: center;
      }
    }

    @media (max-width: 480px) {
      .blog-hero {
        padding: 3.5rem 1rem 1.5rem;
      }
      .blog-title {
        font-size: 1.75rem;
      }
      .blog-tags {
        gap: 0.35rem;
      }
      .blog-tag {
        font-size: 0.6rem;
        padding: 0.2rem 0.5rem;
      }
      .blog-body {
        padding: 1.5rem 1rem 2.5rem;
        font-size: 0.95rem;
      }
      .blog-footer {
        padding: 1.5rem 1rem 3rem;
      }
    }
  </style>
</Layout>
