  let ghostX = 0, ghostY = 0, ghostVx = 0, ghostVy = 0;
  function resize() {
    W = window.innerWidth; H = window.innerHeight;
    canvas.width = W * devicePixelRatio; canvas.height = H * devicePixelRatio;
    ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
    ghostX = 0.72 * W; ghostY = 0.48 * H;
  }
  function lerp(a, b, t) { return a + (b - a) * t; }
  let slide3Active = 0, targetSlide3 = 0;
  function getPos(node, t) {
    const s = scattered[node.id] || { x: node.x, y: node.y };
    const scatteredX = lerp(node.x * W, s.x * W, t);
    const scatteredY = lerp(node.y * H, s.y * H, t);
