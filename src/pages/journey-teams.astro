    }
    return { x: scatteredX, y: scatteredY };
  }
  function updateTargets() {
    const s01 = document.getElementById('s01');
    const s02b = document.getElementById('s02b');
    const s03 = document.getElementById('s03');
    const s03b = document.getElementById('s03b');
    if (!s01) return;
    const r1 = s01.getBoundingClientRect();
    const gone = Math.max(0, -r1.top) / H;
    targetMorphT = Math.max(0, Math.min(1, gone));
    let reconvergedVis = 0;
    [s02b, s03, s03b].forEach(el => {
      if (!el) return;
      const r = el.getBoundingClientRect();
      const vis = Math.max(0, Math.min(H, r.bottom) - Math.max(0, r.top)) / H;
      reconvergedVis = Math.max(reconvergedVis, vis);
    });
    targetSlide3 = Math.max(0, Math.min(1, (reconvergedVis - 0.1) / 0.5));
    if (targetSlide3 > 0.05) targetOpacity = targetSlide3;
    else targetOpacity = Math.max(0, 1 - gone * 2.5);
  }
  function draw() {
    morphT = lerp(morphT, targetMorphT, 0.12);
    slide3Active = lerp(slide3Active, targetSlide3, 0.1);
    canvasOpacity = lerp(canvasOpacity, targetOpacity, targetSlide3 > 0.05 ? 0.15 : 0.08);
    canvas.style.opacity = canvasOpacity;
    pulse += 0.015;
    ctx.clearRect(0, 0, W, H);
    const positions = nodes.map(n => getPos(n, morphT));
    if (morphT > 0.3 && slide3Active < 0.3) {
      const chaseStrength = Math.min(1, (morphT - 0.3) / 0.3) * (1 - slide3Active * 3.33);
      for (let i = 1; i < nodes.length; i++) {
        const s = scattered[nodes[i].id];
        const baseX = s.x * W; const baseY = s.y * H;
        const dx = ghostX - baseX; const dy = ghostY - baseY;
        const dist = Math.sqrt(dx * dx + dy * dy) || 1;
        const chase = Math.min(dist * 0.3, 80) * chaseStrength;
        positions[i].x = baseX + (dx / dist) * chase; positions[i].y = baseY + (dy / dist) * chase;
      }
      let repX = 0, repY = 0;
      for (let i = 1; i < positions.length; i++) {
        const dx = ghostX - positions[i].x; const dy = ghostY - positions[i].y;
        const dist = Math.sqrt(dx * dx + dy * dy) || 1;
        const force = 2000 / (dist * dist);
        repX += (dx / dist) * force; repY += (dy / dist) * force;
      }
      repX += (0.72 * W - ghostX) * 0.008; repY += (0.48 * H - ghostY) * 0.008;
      ghostVx = (ghostVx + repX * chaseStrength) * 0.94; ghostVy = (ghostVy + repY * chaseStrength) * 0.94;
      ghostX += ghostVx; ghostY += ghostVy;
      ghostX = Math.max(W * 0.35, Math.min(W * 0.95, ghostX));
      ghostY = Math.max(H * 0.1, Math.min(H * 0.9, ghostY));
    } else if (slide3Active >= 0.3) {
      ghostX = lerp(ghostX, reconvergedCenterX * W, 0.08); ghostY = lerp(ghostY, reconvergedCenterY * H, 0.08);
      ghostVx *= 0.85; ghostVy *= 0.85;
    } else {
      ghostX = lerp(ghostX, positions[0].x, 0.1); ghostY = lerp(ghostY, positions[0].y, 0.1);
      ghostVx *= 0.9; ghostVy *= 0.9;
    }
    edges.forEach(([a, b]) => {
      const pa = a === 0 ? { x: ghostX, y: ghostY } : positions[a];
      const pb = b === 0 ? { x: ghostX, y: ghostY } : positions[b];
      const isToCenter = a === 0 || b === 0;
      const alpha = isToCenter ? 0.15 * (1 - morphT * 0.85) : 0.04 * (1 - morphT * 0.9);
      if (alpha < 0.005) return;
      ctx.beginPath(); ctx.moveTo(pa.x, pa.y); ctx.lineTo(pb.x, pb.y);
      ctx.strokeStyle = isToCenter ? `rgba(255, 219, 0, ${alpha})` : `rgba(255, 255, 255, ${alpha})`;
      ctx.lineWidth = isToCenter ? 1.5 : 0.8; ctx.stroke();
      if (isToCenter && morphT < 0.5) {
        const t = (Math.sin(pulse * 2 + a + b) * 0.5 + 0.5);
        const px = lerp(pa.x, pb.x, t); const py = lerp(pa.y, pb.y, t);
        const glow = ctx.createRadialGradient(px, py, 0, px, py, 12);
        glow.addColorStop(0, `rgba(255, 219, 0, ${0.4 * (1 - morphT * 2)})`); glow.addColorStop(1, 'transparent');
        ctx.fillStyle = glow; ctx.beginPath(); ctx.arc(px, py, 12, 0, Math.PI * 2); ctx.fill();
      }
    });
    if (slide3Active > 0.05) {
      for (let i = 1; i < nodes.length; i++) {
        const p = positions[i];
        ctx.beginPath(); ctx.moveTo(ghostX, ghostY); ctx.lineTo(p.x, p.y);
        ctx.strokeStyle = `rgba(255, 219, 0, ${0.25 * slide3Active})`; ctx.lineWidth = 1.5; ctx.stroke();
        for (let pi = 0; pi < 2; pi++) {
          const offset = pi * 0.5 + i * 0.35;
          const raw = ((pulse * 0.6 + offset) % 2); const t = raw > 1 ? 2 - raw : raw;
          const px = lerp(ghostX, p.x, t); const py = lerp(ghostY, p.y, t);
          const particleAlpha = slide3Active * (0.6 + 0.4 * Math.sin(pulse * 3 + offset));
          const pGlow = ctx.createRadialGradient(px, py, 0, px, py, 8);
          pGlow.addColorStop(0, `rgba(255, 219, 0, ${0.7 * particleAlpha})`);
          pGlow.addColorStop(0.5, `rgba(255, 219, 0, ${0.2 * particleAlpha})`);
          pGlow.addColorStop(1, 'transparent');
          ctx.fillStyle = pGlow; ctx.beginPath(); ctx.arc(px, py, 8, 0, Math.PI * 2); ctx.fill();
          ctx.beginPath(); ctx.arc(px, py, 3, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255, 219, 0, ${particleAlpha})`; ctx.fill();
        }
      }
    }
    nodes.forEach((node, i) => {
      if (node.type === 'center') return;
      const p = positions[i];
      const ballSize = lerp(4, 18, morphT);
      const ballAlpha = lerp(0.35, 0.6, morphT);
      ctx.beginPath(); ctx.arc(p.x, p.y, ballSize + Math.sin(pulse + i) * 1.5, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(120, 160, 200, ${ballAlpha})`; ctx.fill();
      const glow = ctx.createRadialGradient(p.x, p.y, ballSize * 0.5, p.x, p.y, ballSize * 2.5);
      glow.addColorStop(0, `rgba(120, 160, 200, ${0.15 * ballAlpha})`); glow.addColorStop(1, 'transparent');
      ctx.fillStyle = glow; ctx.beginPath(); ctx.arc(p.x, p.y, ballSize * 2.5, 0, Math.PI * 2); ctx.fill();
      ctx.font = '600 11px Inter, system-ui, sans-serif'; ctx.textAlign = 'center';
      const text = node.label; const textW = ctx.measureText(text).width;
      const chipX = p.x - textW / 2 - 8; const chipY = p.y + ballSize + 6;
      ctx.fillStyle = `rgba(20, 30, 45, 0.7)`; ctx.beginPath(); ctx.roundRect(chipX, chipY, textW + 16, 22, 6); ctx.fill();
      ctx.strokeStyle = `rgba(255, 255, 255, 0.1)`; ctx.lineWidth = 0.5;
      ctx.beginPath(); ctx.roundRect(chipX, chipY, textW + 16, 22, 6); ctx.stroke();
      ctx.fillStyle = `rgba(255, 255, 255, 0.5)`; ctx.fillText(text, p.x, chipY + 15);
    });
    const glowR = lerp(70, 100, slide3Active) + Math.sin(pulse) * 15;
    const glow = ctx.createRadialGradient(ghostX, ghostY, 0, ghostX, ghostY, glowR);
    glow.addColorStop(0, `rgba(255, 219, 0, ${0.2 * 0.9})`); glow.addColorStop(0.5, `rgba(255, 219, 0, ${0.05 * 0.9})`); glow.addColorStop(1, 'transparent');
    ctx.fillStyle = glow; ctx.beginPath(); ctx.arc(ghostX, ghostY, glowR, 0, Math.PI * 2); ctx.fill();
    const dotR = lerp(8, 14, slide3Active) + Math.sin(pulse) * 2;
    ctx.beginPath(); ctx.arc(ghostX, ghostY, dotR, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(255, 219, 0, 0.9)`; ctx.fill();
    const label1Alpha = Math.max(0, 1 - morphT * 2);
    const label2Alpha = Math.max(0, Math.min(1, (morphT - 0.3) / 0.3)) * (1 - slide3Active);
    const label3Alpha = slide3Active;
    ctx.textAlign = 'center';
    if (label1Alpha > 0.01) { ctx.font = '800 13px Inter, system-ui, sans-serif'; ctx.fillStyle = `rgba(255, 219, 0, ${label1Alpha * 0.9})`; ctx.fillText('Journey Teams', ghostX, ghostY + dotR + 20); }
    if (label2Alpha > 0.01) { ctx.font = '800 22px Inter, system-ui, sans-serif'; ctx.fillStyle = `rgba(255, 219, 0, ${label2Alpha * 0.7})`; ctx.fillText('Shared Understanding', ghostX, ghostY + dotR + 22); }
    if (label3Alpha > 0.01) { ctx.font = '800 22px Inter, system-ui, sans-serif'; ctx.fillStyle = `rgba(255, 219, 0, ${label3Alpha * 0.9})`; ctx.fillText('Journey Centric Approach', ghostX, ghostY + dotR + 22); }
    requestAnimationFrame(loop);
  }
  function loop() { updateTargets(); draw(); }
  window.addEventListener('resize', resize, { passive: true });
  resize(); requestAnimationFrame(loop);
}
  </script>
