  <script is:inline>
// ============================================================
//  Journey Teams — Scroll presentation engine
//  Pure CSS scroll-snap handles slide transitions.
//  JS handles: progress bar, nav dots, entrance animations,
//  constellation canvas, and smooth nav clicks.
// ============================================================

document.addEventListener('DOMContentLoaded', () => {
  // --------------------------------------------------------
  //  Progress bar
  // --------------------------------------------------------
  const progressBar = document.getElementById('progressBar');

  function updateProgress() {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    progressBar.style.width = pct + '%';
  }

  window.addEventListener('scroll', updateProgress, { passive: true });

  // --------------------------------------------------------
  //  Nav dots — click scrolls smoothly to section
  // --------------------------------------------------------
  const dots = document.querySelectorAll('.sidenav .dot');

  dots.forEach(dot => {
    dot.addEventListener('click', (e) => {
      e.preventDefault();
      const targetId = dot.getAttribute('href');
      const target = document.querySelector(targetId);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });

  // --------------------------------------------------------
  //  Section visibility — entrance animations + active dot
  // --------------------------------------------------------
  const allSections = document.querySelectorAll('section[id]');
  const totalSlides = allSections.length;
  const slideCounter = document.getElementById('slideCounter');
  const sectionIndexMap = new Map();
  allSections.forEach((s, i) => sectionIndexMap.set(s, i + 1));

  const sectionObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      // Entrance animation
      entry.target.classList.toggle('is-visible', entry.isIntersecting);

      // Active dot + slide counter
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute('id');
        dots.forEach(dot => {
          dot.classList.toggle('active', dot.getAttribute('href') === '#' + id);
        });
        const num = sectionIndexMap.get(entry.target) || 1;
        slideCounter.textContent = num + ' / ' + totalSlides;
      }
    });
  }, {
    threshold: 0.5
  });

  allSections.forEach(s => sectionObserver.observe(s));


  // --------------------------------------------------------
  //  CONSTELLATION
  // --------------------------------------------------------
  initConstellation();
  try { initChaseConstellation(); } catch(e) { console.warn('Chase constellation error:', e); }
  try { initTeamConstellation(); } catch(e) { console.warn('Team constellation error:', e); }
  try { initSharingConstellation(); } catch(e) { console.warn('Sharing constellation error:', e); }
  try { initCommitmentConstellation(); } catch(e) { console.warn('Commitment constellation error:', e); }
  try { initOutcomesConstellation(); } catch(e) { console.warn('Outcomes constellation error:', e); }
  try { initOutcomesLines(); } catch(e) { console.warn('Outcomes lines error:', e); }
  try { initPainDots(); } catch(e) { console.warn('Pain dots error:', e); }
});

