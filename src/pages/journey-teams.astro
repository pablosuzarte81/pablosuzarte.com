function initChaseConstellation() {
  const canvas = document.getElementById('chaseCanvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const section = canvas.closest('section');
  let W, H, running = false;
  const teamNames = ['Dialog', 'C360 Admin', 'PIR', 'SAMS', 'Case Management', 'VETA', 'Mosaik', 'Retail', 'RCMP Co-workers'];
  let target = { x: 0, y: 0, vx: 1.5, vy: 0.8 };
  const chasers = teamNames.map((name) => ({
    label: name, x: 0, y: 0, vx: 0, vy: 0, speed: 0.6 + Math.random() * 0.8, size: 38 + Math.random() * 14,
  }));
  function resize() {
    const rect = section.getBoundingClientRect();
    W = rect.width; H = rect.height;
    canvas.width = W * devicePixelRatio; canvas.height = H * devicePixelRatio;
    canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
    ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
    target.x = W * 0.65; target.y = H * 0.45;
    chasers.forEach((c, i) => {
      const angle = (i / chasers.length) * Math.PI * 2;
      const dist = 300 + Math.random() * 200;
      c.x = target.x + Math.cos(angle) * dist; c.y = target.y + Math.sin(angle) * dist;
    });
  }
  function draw() {
    if (!running) return;
    ctx.clearRect(0, 0, W, H);
    let fleeX = 0, fleeY = 0;
    chasers.forEach(c => {
      const dx = target.x - c.x; const dy = target.y - c.y;
      const dist = Math.sqrt(dx * dx + dy * dy) || 1;
      const force = 3000 / (dist * dist);
      fleeX += (dx / dist) * force; fleeY += (dy / dist) * force;
    });
    target.vx += fleeX * 0.15 + Math.sin(Date.now() * 0.001) * 0.3;
    target.vy += fleeY * 0.15 + Math.cos(Date.now() * 0.0013) * 0.3;
    target.vx *= 0.96; target.vy *= 0.96;
    const speed = Math.sqrt(target.vx * target.vx + target.vy * target.vy);
    if (speed > 4) { target.vx = (target.vx / speed) * 4; target.vy = (target.vy / speed) * 4; }
    target.x += target.vx; target.y += target.vy;
    const pad = 80;
    if (target.x < pad) { target.x = pad; target.vx = Math.abs(target.vx); }
    if (target.x > W - pad) { target.x = W - pad; target.vx = -Math.abs(target.vx); }
    if (target.y < pad) { target.y = pad; target.vy = Math.abs(target.vy); }
    if (target.y > H - pad) { target.y = H - pad; target.vy = -Math.abs(target.vy); }
    chasers.forEach((c, i) => {
      const dx = target.x - c.x; const dy = target.y - c.y;
      const dist = Math.sqrt(dx * dx + dy * dy) || 1;
      c.vx += (dx / dist) * c.speed * 0.12; c.vy += (dy / dist) * c.speed * 0.12;
      chasers.forEach((other, j) => {
        if (i === j) return;
        const odx = c.x - other.x; const ody = c.y - other.y;
        const odist = Math.sqrt(odx * odx + ody * ody) || 1;
        if (odist < 140) { c.vx += (odx / odist) * 1.2; c.vy += (ody / odist) * 1.2; }
      });
      c.vx *= 0.95; c.vy *= 0.95; c.x += c.vx; c.y += c.vy;
    });
    chasers.forEach(c => {
      ctx.beginPath(); ctx.arc(c.x, c.y, c.size, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(100, 140, 190, 0.5)'; ctx.fill();
      const glow = ctx.createRadialGradient(c.x, c.y, c.size * 0.3, c.x, c.y, c.size * 2);
      glow.addColorStop(0, 'rgba(100, 140, 190, 0.12)'); glow.addColorStop(1, 'transparent');
      ctx.fillStyle = glow; ctx.beginPath(); ctx.arc(c.x, c.y, c.size * 2, 0, Math.PI * 2); ctx.fill();
      ctx.font = '600 11px Inter, system-ui, sans-serif'; ctx.textAlign = 'center';
      const textW = ctx.measureText(c.label).width;
      const chipX = c.x - textW / 2 - 6; const chipY = c.y + c.size + 4;
      ctx.fillStyle = 'rgba(15, 22, 35, 0.75)'; ctx.beginPath(); ctx.roundRect(chipX, chipY, textW + 12, 20, 5); ctx.fill();
      ctx.fillStyle = 'rgba(255, 255, 255, 0.5)'; ctx.fillText(c.label, c.x, chipY + 14);
    });
    const glowR = 60 + Math.sin(Date.now() * 0.002) * 10;
    const tGlow = ctx.createRadialGradient(target.x, target.y, 0, target.x, target.y, glowR);
    tGlow.addColorStop(0, 'rgba(255, 219, 0, 0.25)'); tGlow.addColorStop(0.5, 'rgba(255, 219, 0, 0.06)'); tGlow.addColorStop(1, 'transparent');
    ctx.fillStyle = tGlow; ctx.beginPath(); ctx.arc(target.x, target.y, glowR, 0, Math.PI * 2); ctx.fill();
    const dotR = 20 + Math.sin(Date.now() * 0.003) * 3;
    ctx.beginPath(); ctx.arc(target.x, target.y, dotR, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(255, 219, 0, 0.9)'; ctx.fill();
    ctx.font = '800 20px Inter, system-ui, sans-serif'; ctx.textAlign = 'center';
    ctx.fillStyle = 'rgba(255, 219, 0, 0.8)'; ctx.fillText('Shared Understanding', target.x, target.y + dotR + 28);
    requestAnimationFrame(draw);
  }
  canvas.style.opacity = '0'; canvas.style.transition = 'opacity 0.8s ease';
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting && !running) { running = true; resize(); canvas.style.opacity = '1'; requestAnimationFrame(draw); }
      else if (!entry.isIntersecting) { running = false; canvas.style.opacity = '0'; }
    });
  }, { threshold: 0.3 });
  observer.observe(section);
  window.addEventListener('resize', resize);
}

function initConstellation() {
