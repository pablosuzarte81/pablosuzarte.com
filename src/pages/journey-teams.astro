}

.orchestrator-capability {
  padding: 1.2rem 1.2rem 1.15rem;
  border-radius: 1.15rem;
  background: linear-gradient(180deg, rgba(14, 21, 37, 0.96), rgba(11, 17, 31, 0.98));
  border: 1px solid rgba(255,255,255,0.04);
