  <section id="s12" class="section section--outcomes">
    <div class="section__inner section__inner--stack">
      <div class="stack__header">
        <p class="section-label">Opportunities for Improvement</p>
        <h2 class="heading-xl"><span style="color: var(--yellow, #ffdb00)">75+</span> opportunities across systemic themes.</h2>
