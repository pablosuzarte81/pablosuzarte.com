<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connecting the Silos: A Journey-Centric Approach</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style is:inline>
/* ============================================================
   Journey Teams — Connecting the Silos
   IKEA Skapa inspired design
   ============================================================ */

/* ---------- Design Tokens ---------- */
:root {
  --blue:       #0058A3;
  --blue-dark:  #003E77;
  --yellow:     #FFDB00;
  --dark:       #08131F;
  --dark-2:     #0D1B2A;
  --dark-3:     #13263A;
  --mid:        #91A0AF;
  --light:      #E8EEF3;
  --mid-gray:   #314153;
  --white:      #FFFFFF;
  --text-soft:  rgba(255,255,255,0.74);
  --line:       rgba(255,255,255,0.08);

  --font: 'Inter', system-ui, -apple-system, sans-serif;

  --space-xs:   0.5rem;
  --space-s:    1rem;
  --space-m:    1.5rem;
  --space-l:    2.5rem;
  --space-xl:   4rem;
  --space-xxl:  6rem;

  --radius-s:   4px;
  --radius-m:   8px;
  --radius-l:   16px;
  --radius-xl:  24px;

  --max-width:  1200px;
  --text-max:   680px;

  /* Narrative slide proportion rules */
  --narrative-grid-text: 1.12fr;
  --narrative-grid-visual: 0.88fr;
  --narrative-gap: clamp(1.25rem, 2.6vw, 2.5rem);
  --narrative-label-size: 0.82rem;
  --narrative-title-size: clamp(2.1rem, 3.4vw, 3rem);
  --narrative-title-measure: 19ch;
  --narrative-title-leading: 1.08;
  --narrative-lead-size: clamp(1.28rem, 2vw, 1.75rem);
  --narrative-lead-measure: 39rem;
  --narrative-lead-leading: 1.5;
  --narrative-visual-size: min(34rem, 100%);
}

/* ---------- Reset ---------- */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html {
  font-size: 16px;
  scroll-snap-type: y mandatory;
  overflow-y: scroll;
}
body {
  font-family: var(--font);
  color: var(--white);
  background:
    radial-gradient(circle at top left, rgba(255, 219, 0, 0.08), transparent 22%),
    radial-gradient(circle at 85% 15%, rgba(0, 88, 163, 0.18), transparent 28%),
    linear-gradient(180deg, #06111c 0%, #08131f 100%);
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}
img { max-width: 100%; height: auto; display: block; }
ul, ol { list-style: none; }
strong { font-weight: 700; }

/* ---------- Typography ---------- */
.display-xl {
  font-size: clamp(3.5rem, 9vw, 8rem);
  font-weight: 900;
  line-height: 0.95;
  letter-spacing: -0.04em;
  color: var(--white);
}
.display-sub {
  font-size: clamp(1.25rem, 3vw, 2.25rem);
  font-weight: 700;
  color: var(--yellow);
  margin-top: var(--space-m);
  letter-spacing: -0.01em;
}
.title-speaker {
  margin-top: 1.1rem;
  font-size: clamp(1rem, 2vw, 1.45rem);
  font-weight: 700;
  letter-spacing: 0.02em;
  color: rgba(255,255,255,0.92);
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}
.title-speaker__avatar {
  width: 2.4rem;
  height: 2.4rem;
  border-radius: 50%;
  object-fit: cover;
  border: 1.5px solid rgba(255, 255, 255, 0.2);
}
.title-speaker__text {
  display: flex;
  flex-direction: column;
}
.title-speaker__name {
  font-size: clamp(1rem, 2vw, 1.45rem);
  font-weight: 700;
  color: rgba(255, 255, 255, 0.92);
}
.title-speaker__role {
  font-size: clamp(0.75rem, 1.2vw, 0.95rem);
  font-weight: 400;
  color: rgba(255, 255, 255, 0.45);
}
.title-context {
  margin-top: 0.55rem;
  font-size: clamp(0.72rem, 1.1vw, 0.9rem);
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.46);
  max-width: 44rem;
  line-height: 1.5;
}
.heading-xl {
  font-size: clamp(2rem, 4vw, 3.25rem);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: var(--space-l);
  color: var(--white);
}
.statement {
  font-size: clamp(2rem, 4.5vw, 3.5rem);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: var(--space-l);
}
.body-xl {
  font-size: clamp(1.125rem, 2vw, 1.5rem);
  font-weight: 400;
  line-height: 1.55;
  margin-bottom: var(--space-m);
  color: var(--text-soft);
}
.body-l {
  font-size: clamp(1rem, 1.4vw, 1.125rem);
  font-weight: 400;
  line-height: 1.65;
  margin-bottom: var(--space-s);
  color: var(--text-soft);
}
.body-m {
  font-size: 1rem;
  font-weight: 400;
  line-height: 1.6;
}
.caption-note {
  color: var(--text-soft);
  font-size: 0.875rem;
  margin-top: var(--space-s);
  line-height: 1.5;
}
.caption-note--light {
  color: rgba(255,255,255,0.55);
  font-size: 0.875rem;
  margin-top: var(--space-s);
}
.section-label {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--yellow);
  margin-bottom: var(--space-m);
  display: block;
}
.section-label--light {
  color: rgba(255,255,255,0.5);
}
.eyebrow {
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  margin-bottom: var(--space-l);
  display: block;
}
.tagline {
  font-size: clamp(1rem, 1.5vw, 1.25rem);
  font-weight: 400;
  color: rgba(255,255,255,0.7);
  margin-top: var(--space-xl);
  line-height: 1.5;
}
.project-name {
  font-size: 0.8rem;
  font-weight: 600;
  color: rgba(255,255,255,0.4);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-top: var(--space-m);
}
.heading--light { color: var(--white); }
.body--light { color: rgba(255,255,255,0.85); }
.italic { font-style: italic; }
.with-purpose {
  color: var(--yellow);
  font-style: normal;
}
.highlight-yellow {
  color: var(--yellow);
  font-weight: 800;
}
.crayon-underline {
  position: relative;
  display: inline;
}
.crayon-underline::after {
  content: "";
  position: absolute;
  left: -2%;
  right: -2%;
  bottom: -0.05em;
  height: 0.18em;
  background: var(--yellow);
  opacity: 0.55;
  border-radius: 40% 20% 40% 30% / 80% 60% 90% 50%;
  transform: rotate(-0.5deg) scaleY(0.85);
  z-index: -1;
}

/* ---------- Slide Counter ---------- */
.slide-counter {
  position: fixed;
  bottom: 1.5rem;
  right: 1.75rem;
  z-index: 200;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: rgba(255,255,255,0.35);
  font-variant-numeric: tabular-nums;
}

/* ---------- Progress Bar ---------- */
.progress-bar {
  position: fixed;
  top: 0; left: 0;
  height: 3px;
  background: var(--yellow);
  width: 0%;
  z-index: 200;
  transition: width 0.08s linear;
}

/* ---------- Side Navigation ---------- */
.sidenav {
  position: fixed;
  right: 1.75rem;
  top: 50%;
  transform: translateY(-50%);
  z-index: 100;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}
.dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: rgba(255,255,255,0.18);
  display: block;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
  position: relative;
}
.dot:hover {
  background: var(--yellow);
  transform: scale(1.5);
}
.dot.active {
  background: var(--yellow);
  transform: scale(1.8);
  box-shadow: 0 0 0 3px rgba(255, 219, 0, 0.3);
}
.dot::after {
  content: attr(data-label);
  position: absolute;
  right: 1.4rem;
  top: 50%;
  transform: translateY(-50%);
  background: var(--dark);
  color: var(--white);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 3px 8px;
  border-radius: 3px;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.15s;
}
.dot:hover::after { opacity: 1; }
.dot.active::after {
  opacity: 0;
}

/* ---------- Sections — Base ---------- */
.section {
  min-height: 100vh;
  min-height: 100svh;
  display: flex;
  align-items: center;
  position: relative;
  scroll-snap-align: start;
  scroll-snap-stop: always;
  transition: background 0.4s ease;
  contain: layout style;
}
.section__inner {
  width: 100%;
  max-width: var(--max-width);
  margin: 0 auto;
  padding: var(--space-xxl) var(--space-xl);
}

/* ---------- Slide entrance animations ---------- */
.section .section__inner {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
              transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}
.section.is-visible .section__inner,
.section--title .section__inner {
  opacity: 1;
  transform: translateY(0);
}
.section__inner--title {
  padding: var(--space-xxl) var(--space-xl);
}
.section__inner--problem-hero {
  display: flex;
  align-items: center;
  min-height: 100vh;
}
.section__inner--text {
  max-width: var(--text-max);
}
.section__inner--split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-xxl);
  align-items: center;
}
.section__inner--reverse {
  direction: rtl;
}
.section__inner--reverse > * {
  direction: ltr;
}
.section__inner--stack {
  display: flex;
  flex-direction: column;
  gap: var(--space-xl);
}
.section__inner--center {
  text-align: center;
  max-width: 860px;
  margin: 0 auto;
}

/* ---------- Split Images ---------- */
.split__image img,
.split__image--left img {
  width: 100%;
  height: 520px;
  object-fit: cover;
  border-radius: var(--radius-xl);
  box-shadow: 0 24px 64px rgba(0,0,0,0.12);
}

/* ---------- Section Themes ---------- */
.section--title    { background: transparent; }
.section--problem  {
  background: #08080F;
  position: relative;
  overflow: hidden;
}

.section--constellation-bg {
  background: transparent;
}
.section--constellation-bg .section__inner {
  position: relative;
  z-index: 1;
}

.chase-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
}
.section--story    { display: block; overflow: visible; position: relative; z-index: 0; }

/* Pull each section after a scroll-story up by 100vh to absorb the sticky trailing blank */
.section--story + .section {
  position: relative;
  z-index: 1;
  margin-top: -100vh;
}
.section--strategy    { background: #08080F; }
.section--strategy.section--with-constellation { background: transparent; }
.section--planning    { background: #08080F; }
.section--onboarding  { background: #08080F; position: relative; overflow: hidden; }
.section--onboarding .section__inner { position: relative; z-index: 1; }
.section--team        { background: #08080F; }
.section--orchestrator{ background: #08080F; }
.section--involved    { background: #08080F; }
.section--research    { background: #08080F; }
.section--analysis    { background: #08080F; }
.section--sharing     { background: #08080F; }
.section--artefact    { background: #08080F; }

/* ---------- Artefact Layout ---------- */
.section__inner--artefact {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  max-width: 100%;
  padding: var(--space-xl) var(--space-xl);
}

.artefact-header {
  max-width: var(--max-width);
  margin: 0 auto;
  width: 100%;
}

.artefact-header .heading-xl {
  max-width: 56rem;
}

/* Physical → Digital transformation layout */
.maps-transformation {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  align-items: center;
  width: 100%;
  max-width: var(--max-width);
  margin: 0 auto;
}

.maps-physical {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 0.5rem;
  width: 100%;
}

.maps-physical__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
}

.maps-physical__item img {
  width: 100%;
  aspect-ratio: 16 / 10;
  object-fit: cover;
  border-radius: var(--radius-m);
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 8px 24px rgba(0,0,0,0.25);
}

.maps-physical__item span {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: rgba(255,255,255,0.5);
}

.maps-arrow-down {
  font-size: 1.5rem;
  color: var(--yellow);
  opacity: 0.5;
  line-height: 1;
  margin-top: 0.25rem;
}

/* Journey map — full width */
.maps-insight {
  text-align: left;
  color: rgba(255, 255, 255, 0.7);
  font-size: clamp(2rem, 4vw, 3.25rem);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-top: var(--space-l);
}
.artefact-map-wrap {
  width: 100%;
  max-width: var(--max-width);
  margin: 0 auto;
}

.artefact-map {
  border-radius: var(--radius-l);
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow:
    0 24px 80px rgba(0,0,0,0.35),
    inset 0 1px 0 rgba(255,255,255,0.04);
  background: #fefefe;
}

.artefact-map {
  position: relative;
}

.artefact-map img {
  display: block;
  width: 100%;
  height: auto;
}

/* Pain point dots overlay */
.pain-dots {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.pain-dot {
  position: absolute;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: rgba(255, 40, 40, 1);
  box-shadow: 0 0 10px rgba(255, 40, 40, 0.8), 0 0 28px rgba(255, 40, 40, 0.4), 0 0 50px rgba(255, 40, 40, 0.15);
  animation: pain-blink var(--blink-speed, 2.5s) ease-in-out var(--blink-delay, 0s) infinite;
}

@keyframes pain-blink {
  0%, 100% { opacity: 0.5; transform: scale(0.9); box-shadow: 0 0 8px rgba(255,40,40,0.6), 0 0 20px rgba(255,40,40,0.25); }
  50% { opacity: 1; transform: scale(1.4); box-shadow: 0 0 18px rgba(255,40,40,0.9), 0 0 40px rgba(255,40,40,0.45), 0 0 70px rgba(255,40,40,0.15); }
}

/* Stats row */
.artefact-stat-row {
  display: flex;
  gap: 2rem;
  justify-content: center;
  margin-top: 1.5rem;
}

.artefact-stat {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
}

.artefact-stat__number {
  font-size: clamp(2rem, 3.5vw, 3rem);
  font-weight: 900;
  color: var(--yellow, #ffdb00);
  line-height: 1;
}

.artefact-stat__label {
  font-size: clamp(0.85rem, 1vw, 1rem);
  color: rgba(255,255,255,0.5);
  font-weight: 500;
}

.artefact-card-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-top: 1.5rem;
  max-width: var(--max-width);
  margin-left: auto;
  margin-right: auto;
}

.artefact-card {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 1.2rem 1.5rem;
  background: rgba(13, 27, 42, 0.85);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 12px;
}

.artefact-card__icon {
  font-size: 1.3rem;
  color: var(--yellow, #ffdb00);
  flex-shrink: 0;
  margin-top: 2px;
}

.artefact-card__text {
  font-size: clamp(0.9rem, 1.1vw, 1.05rem);
  color: rgba(255,255,255,0.6);
  line-height: 1.5;
  margin: 0;
}

.artefact-map-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 0.6rem;
  padding: 0 0.25rem;
}

.artefact-map-labels span {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
}

/* Pain point sample cards */
.artefact-painpoints {
  max-width: var(--max-width);
  margin: 0 auto;
  width: 100%;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
}

.artefact-painpoint {
  display: flex;
  align-items: flex-start;
  gap: 0.65rem;
  padding: 0.85rem 1rem;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: var(--radius-m);
}

.artefact-painpoint__icon {
  font-size: 1.1rem;
  flex-shrink: 0;
  margin-top: 0.1rem;
}

.artefact-painpoint__title {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--white);
  line-height: 1.2;
  margin-bottom: 0.2rem;
}

.artefact-painpoint__desc {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.55);
  line-height: 1.4;
}

.artefact-painpoint__link {
  flex-shrink: 0;
  font-size: 0.65rem;
  font-weight: 700;
  color: var(--yellow);
  opacity: 0.7;
  margin-top: 0.15rem;
}

/* ---------- Pain Point Zoom-In Slides ---------- */
.section--painpoint {
  background:
    radial-gradient(circle at 25% 50%, rgba(255,219,0,0.04), transparent 30%),
    linear-gradient(180deg, #0a1520 0%, #0d1e30 100%);
}
.section--painpoint-alt {
  background:
    radial-gradient(circle at 75% 50%, rgba(0,88,163,0.06), transparent 30%),
    linear-gradient(180deg, #0d1e30 0%, #0a1520 100%);
}

.section__inner--painpoint {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-xl);
  align-items: center;
  max-width: var(--max-width);
  margin: 0 auto;
  padding: var(--space-xxl) var(--space-xl);
}

.section--painpoint-alt .section__inner--painpoint {
  direction: rtl;
}
.section--painpoint-alt .section__inner--painpoint > * {
  direction: ltr;
}

.painpoint-slide__label {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1.2rem;
}

.painpoint-number {
  font-size: 0.7rem;
  font-weight: 900;
  color: var(--yellow);
  background: rgba(255,219,0,0.12);
  border: 1px solid rgba(255,219,0,0.2);
  width: 2.2rem;
  height: 2.2rem;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.painpoint-activity {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
}

.painpoint-slide__title {
  font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  font-weight: 800;
  line-height: 1.08;
  letter-spacing: -0.03em;
  color: var(--white);
  margin-bottom: 1rem;
}

.painpoint-slide__desc {
  font-size: clamp(1rem, 1.4vw, 1.15rem);
  line-height: 1.6;
  color: rgba(255,255,255,0.72);
  margin-bottom: 1.5rem;
  max-width: 32rem;
}

.painpoint-slide__meta {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.painpoint-slide__video {
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--yellow);
  opacity: 0.85;
}

.painpoint-slide__impact {
  font-size: 0.78rem;
  font-weight: 600;
  color: rgba(255,255,255,0.45);
  line-height: 1.4;
}

.painpoint-slide__screenshot {
  display: flex;
  align-items: center;
  justify-content: center;
}

.painpoint-slide__screenshot img {
  width: 100%;
  max-width: 520px;
  border-radius: var(--radius-l);
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 24px 64px rgba(0,0,0,0.35);
}

.section--workshop-gallery {
  position: relative;
  min-height: 100vh;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #08080F;
}
.section--outcomes    { background: #08080F; }
.section--outcomes-detail { background: #08080F; position: relative; overflow: hidden; }
.section--outcomes-detail .section__inner { position: relative; z-index: 1; }
.section--feedback    { background: #08080F; }
.section--dxd         { background: #08080F; }
.section--close       { background: #08080F; }

/* ---------- DXD Landscape ---------- */
.dxd-subtitle {
  font-size: clamp(0.9rem, 1.1vw, 1.05rem);
  color: rgba(255, 255, 255, 0.45);
  margin-top: -0.5rem;
}

/* Tension layout: two sides with center divider */
.dxd-tension {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 0;
  max-width: var(--max-width);
  align-items: start;
}

.dxd-tension__side {
  display: flex;
  flex-direction: column;
  gap: var(--space-s);
}

/* Column labels */
.dxd-tension__label {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: clamp(1.1rem, 1.4vw, 1.3rem);
  font-weight: 800;
  letter-spacing: 0.02em;
  padding-bottom: 0.5rem;
}
.dxd-tension__label--green { color: #3ee0a5; }
.dxd-tension__label--red   { color: #ff6b6b; }

.dxd-tension__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}

/* Card stack */
.dxd-tension__cards {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

/* Individual cards */
.dxd-card {
  padding: 0.9rem 1.2rem;
  border-radius: var(--radius-m);
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.07);
  transition: border-color 0.2s ease, background 0.2s ease;
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}
.dxd-card strong {
  font-size: clamp(0.92rem, 1.1vw, 1.05rem);
  font-weight: 700;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.35;
}
.dxd-card span {
  font-size: clamp(0.8rem, 0.95vw, 0.9rem);
  color: rgba(255, 255, 255, 0.45);
  line-height: 1.35;
}

/* Green card accent */
.dxd-card--green {
  border-left: 3px solid rgba(62, 224, 165, 0.4);
}
.dxd-card--green:hover {
  border-color: rgba(62, 224, 165, 0.25);
  background: rgba(62, 224, 165, 0.04);
}

/* Red card accent */
.dxd-card--red {
  border-left: 3px solid rgba(255, 107, 107, 0.4);
}
.dxd-card--red:hover {
  border-color: rgba(255, 107, 107, 0.25);
  background: rgba(255, 107, 107, 0.04);
}

/* Center divider */
.dxd-tension__divider {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 1.5rem;
  align-self: stretch;
  padding-top: 2.8rem; /* align with cards, below labels */
}
.dxd-tension__divider-line {
  flex: 1;
  width: 1px;
  background: linear-gradient(
    to bottom,
    transparent,
    rgba(255, 255, 255, 0.15) 20%,
    rgba(255, 255, 255, 0.15) 80%,
    transparent
  );
}
.dxd-tension__divider-badge {
  font-size: 0.65rem;
  font-weight: 800;
  letter-spacing: 0.18em;
  color: rgba(255, 255, 255, 0.35);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: var(--radius-s);
  padding: 0.3rem 0.65rem;
  margin: 0.75rem 0;
  text-transform: uppercase;
  background: rgba(255, 255, 255, 0.03);
}

/* Conclusion with inflection point styling */
.dxd-conclusion--inflection {
  max-width: 52rem;
  margin-top: var(--space-l);
  display: flex;
  align-items: stretch;
  gap: 1.25rem;
  padding: 1.5rem 2rem;
  background: rgba(255, 219, 0, 0.03);
  border: 1px solid rgba(255, 219, 0, 0.12);
  border-radius: var(--radius-l);
}
.dxd-conclusion__accent {
  width: 3px;
  flex-shrink: 0;
  border-radius: 2px;
  background: linear-gradient(to bottom, #FFDB00, rgba(255, 219, 0, 0.3));
}
.dxd-conclusion__text {
  font-size: clamp(1.05rem, 1.4vw, 1.25rem);
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.55;
}

/* ---------- Feedback Quotes ---------- */
.feedback-quotes {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  max-width: var(--max-width);
  margin-top: var(--space-xl);
}
.feedback-quotes--single {
  grid-template-columns: 1fr;
  max-width: 44rem;
}
.feedback-quotes--three {
  grid-template-columns: 1fr;
  max-width: 52rem;
}
.feedback-quotes--three .feedback-quote {
  flex-direction: row;
  align-items: center;
  gap: 2rem;
  padding: 1.5rem 2rem;
}
.feedback-quotes--three .feedback-quote__text {
  flex: 1;
}
.feedback-quotes--three .feedback-quote__author {
  flex-shrink: 0;
  min-width: 10rem;
  text-align: right;
}
.feedback-quote {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-left: 3px solid var(--yellow);
  border-radius: 12px;
  padding: 2rem 2rem 1.5rem;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 1.5rem;
  margin: 0;
}
.feedback-quote__text {
  font-size: clamp(1rem, 1.3vw, 1.2rem);
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
  margin: 0;
}
.feedback-quote__avatar {
  width: 2.8rem;
  height: 2.8rem;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid rgba(255, 255, 255, 0.1);
}
.feedback-quote__author {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.15rem;
}
.feedback-quote__name {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--white);
}
.feedback-quote__role {
  font-size: 0.8rem;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.4);
}
.section--implication { background: #08080F; }

/* ---------- Outcomes Canvas ---------- */
.outcomes-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  filter: blur(16px);
  opacity: 0.3;
}

/* ---------- Outcomes Grid ---------- */
/* ---------- Outcomes Node System ---------- */
.outcomes-node-system {
  position: relative;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 2rem 3rem;
  max-width: 56rem;
  margin: 0 auto;
  align-items: center;
}
.outcomes-center {
  grid-row: 1 / 3;
  grid-column: 2 / 3;
  width: 10rem;
  height: 10rem;
  border-radius: 50%;
  border: 2px solid var(--yellow);
  background: rgba(255, 219, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  z-index: 2;
}
.outcomes-center__label {
  font-size: 1rem;
  font-weight: 800;
  color: var(--yellow);
  line-height: 1.2;
}
.outcome-card {
  padding: 1.2rem 1.5rem;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-left: 3px solid var(--card-color, #fff);
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.outcome-card--tl { grid-row: 1; grid-column: 1; }
.outcome-card--tr { grid-row: 1; grid-column: 3; }
.outcome-card--bl { grid-row: 2; grid-column: 1; }
.outcome-card--br { grid-row: 2; grid-column: 3; }
.outcome-card__title {
  font-size: clamp(1rem, 1.2vw, 1.15rem);
  font-weight: 800;
  color: var(--card-color, #fff);
  line-height: 1.2;
}
.outcome-card__desc {
  font-size: clamp(0.85rem, 1vw, 0.95rem);
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.45;
  margin: 0;
}
.outcome-card__desc strong {
  color: rgba(255, 255, 255, 0.9);
  font-weight: 700;
}
.outcomes-lines {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  pointer-events: none;
}
.outcomes-subtitle {
  font-size: clamp(1rem, 1.4vw, 1.25rem);
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.5;
  text-align: left;
  max-width: 42rem;
  margin-top: -0.5rem;
}

/* ---------- Scroll Hint ---------- */
.scroll-hint {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255,255,255,0.3);
  font-size: 1.25rem;
  animation: bounce 2.5s ease-in-out infinite;
  user-select: none;
}
@keyframes bounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50%       { transform: translateX(-50%) translateY(8px); }
}

/* ---------- Pullquote ---------- */
.pullquote {
  font-size: clamp(1.125rem, 2vw, 1.5rem);
  font-weight: 700;
  line-height: 1.45;
  border-left: 4px solid var(--yellow);
  padding-left: var(--space-m);
  margin: var(--space-l) 0;
  color: var(--white);
  font-style: normal;
}
.pullquote--light {
  color: var(--white);
}

/* ---------- Field Quote (Serba / participant voices) ---------- */
.field-quote {
  margin: var(--space-l) 0;
  padding: var(--space-m) var(--space-l);
  border-left: 3px solid var(--yellow);
  background: rgba(255, 219, 0, 0.07);
  border-radius: 0 var(--radius-m) var(--radius-m) 0;
}
.field-quote p {
  font-size: clamp(1rem, 1.6vw, 1.25rem);
  font-style: italic;
  font-weight: 500;
  line-height: 1.55;
  color: var(--white);
  margin-bottom: var(--space-xs);
}
.field-quote cite {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--yellow);
  font-style: normal;
}
.field-quote--light .field-quote p { color: var(--white); }

/* ---------- Big standalone field quote (s02 step 2) ---------- */
.field-quote-eyebrow {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--yellow);
  margin-bottom: var(--space-m);
}
.field-quote-big {
  font-size: clamp(1.5rem, 3.5vw, 2.5rem);
  font-weight: 700;
  font-style: italic;
  line-height: 1.35;
  color: var(--white);
  border-left: 4px solid var(--yellow);
  padding-left: var(--space-l);
  margin: 0;
}
.field-quote-name {
  font-size: 0.85rem;
  font-weight: 600;
  color: rgba(255,255,255,0.5);
  padding-left: var(--space-l);
  margin-top: var(--space-s);
}

.intro-connection {
  width: min(var(--max-width), calc(100vw - 4rem));
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
  gap: clamp(1.5rem, 4vw, 4rem);
  align-items: center;
  padding: 0;
}

.intro-connection__text {
  max-width: 700px;
}

.intro-proof-list {
  margin-top: var(--space-l);
  display: grid;
  gap: 0.85rem;
}

.intro-proof-list p {
  margin: 0;
  padding: 0.9rem 1rem;
  border-left: 3px solid rgba(255, 219, 0, 0.95);
  background: rgba(255,255,255,0.05);
  border-radius: 0 16px 16px 0;
  color: rgba(255,255,255,0.92);
  font-size: clamp(0.98rem, 1.4vw, 1.08rem);
  line-height: 1.5;
}

.intro-connection__visual {
  display: grid;
  gap: 1.1rem;
  justify-items: center;
}

.connection-slide {
  width: min(var(--max-width), calc(100vw - 4rem));
  display: grid;
  grid-template-columns: minmax(0, var(--narrative-grid-text)) minmax(320px, var(--narrative-grid-visual));
  gap: var(--narrative-gap);
  align-items: center;
  min-height: 100vh;
}

.connection-slide--stacked {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  max-width: 52rem;
  min-height: 0;
}

.connection-slide__text {
  width: min(100%, 48rem);
  position: relative;
  z-index: 2;
  padding-left: 0;
  align-self: center;
}

.connection-slide__label {
  color: var(--yellow);
  font-size: var(--narrative-label-size);
  margin-bottom: 1.2rem;
}

.connection-slide__text .problem-hero-title,
.connection-slide--stacked .problem-hero-title {
  max-width: var(--narrative-title-measure);
  font-size: var(--narrative-title-size);
  line-height: var(--narrative-title-leading);
  letter-spacing: -0.032em;
  color: rgba(255,255,255,0.9);
  margin-bottom: 1.6rem;
  text-wrap: balance;
  font-weight: 700;
}

.connection-slide__visual {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  min-height: 29rem;
  position: relative;
  z-index: 2;
  padding-left: 0.25rem;
}

.hook-proof {
  width: var(--narrative-visual-size);
  display: grid;
  gap: 1.35rem;
}

.hook-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.9rem;
}

.hook-metrics--inline {
  grid-template-columns: repeat(4, 1fr);
  gap: 0.75rem;
  margin-top: 2rem;
  margin-bottom: 1.5rem;
  width: 100%;
  max-width: 32rem;
}

.hook-metric--compact {
  aspect-ratio: 1;
  padding: 1rem;
  border-radius: var(--radius-l);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02)),
    rgba(9, 21, 35, 0.78);
  border: 1px solid rgba(255,255,255,0.09);
  box-shadow: 0 12px 32px rgba(0,0,0,0.18);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.3rem;
  min-height: auto;
}

.hook-metric {
  min-height: 8.6rem;
  padding: 1.2rem 1.15rem;
  border-radius: 1.35rem;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03)),
    rgba(9, 21, 35, 0.78);
  border: 1px solid rgba(255,255,255,0.09);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.05),
    0 20px 40px rgba(0,0,0,0.18);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.hook-metric__value {
  display: block;
  font-size: clamp(2.4rem, 4vw, 3.6rem);
  font-weight: 900;
  line-height: 0.95;
  letter-spacing: -0.05em;
  color: var(--yellow);
}

.hook-metric__label {
  display: block;
  font-size: 0.92rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.72);
}

.hook-roles {
  display: flex;
  flex-wrap: wrap;
  gap: 0.65rem;
  align-content: flex-start;
}

.hook-role {
  display: inline-flex;
  align-items: center;
  min-height: 2.6rem;
  padding: 0.72rem 0.95rem;
  border-radius: 999px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.10);
  color: rgba(255,255,255,0.88);
  font-size: 0.84rem;
  font-weight: 600;
  line-height: 1.2;
}


.silo-cluster {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  justify-content: center;
}

.silo-pill {
  padding: 0.75rem 1rem;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.18);
  background: rgba(255,255,255,0.08);
  color: var(--white);
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  box-shadow: 0 10px 24px rgba(0,0,0,0.14);
}

.silo-bridge {
  display: flex;
  align-items: center;
  gap: 1rem;
  width: 100%;
}

.silo-bridge__line {
  flex: 1;
  height: 2px;
  background: linear-gradient(90deg, rgba(255,255,255,0.08), rgba(255,219,0,0.8), rgba(255,255,255,0.08));
}

.silo-bridge__core {
  min-width: 210px;
  padding: 1rem 1.1rem;
  border-radius: 24px;
  background: rgba(255, 219, 0, 0.12);
  border: 1px solid rgba(255, 219, 0, 0.3);
  text-align: center;
  box-shadow: 0 18px 40px rgba(0,0,0,0.16);
}

.silo-bridge__core strong {
  display: block;
  color: var(--white);
  font-size: 1.05rem;
  font-weight: 800;
  letter-spacing: -0.02em;
}

.silo-bridge__core span {
  display: block;
  margin-top: 0.25rem;
  color: rgba(255,255,255,0.72);
  font-size: 0.82rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

/* ---------- Outcomes Teaser ---------- */
.outcomes-teaser {
  margin-top: var(--space-l);
  padding-top: var(--space-l);
  border-top: 1px solid rgba(255,255,255,0.15);
}
.outcomes-teaser__label {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--yellow);
  margin-bottom: var(--space-m);
}
.outcomes-teaser__list {
  display: flex;
  flex-direction: column;
  gap: var(--space-s);
  list-style: none;
  padding: 0;
}
.outcomes-teaser__list li {
  font-size: clamp(0.95rem, 1.4vw, 1.1rem);
  font-weight: 500;
  color: rgba(255,255,255,0.85);
  padding-left: 1.25rem;
  position: relative;
}
.outcomes-teaser__list li::before {
  content: '→';
  position: absolute;
  left: 0;
  color: var(--yellow);
  font-size: 0.85rem;
}

/* ---------- Strategy Chain ---------- */
.chain {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin: var(--space-l) 0;
}
.chain__item {
  padding: var(--space-m) var(--space-m);
  background: rgba(255,255,255,0.05);
  border-radius: var(--radius-m);
  border: 1px solid var(--line);
}
.chain__item strong {
  display: block;
  font-size: 1rem;
  margin-bottom: 4px;
}
.chain__item p {
  font-size: 0.9rem;
  color: var(--text-soft);
  line-height: 1.5;
}
.chain__item--highlight {
  background: var(--blue);
  border-color: var(--blue);
}
.chain__item--highlight strong,
.chain__item--highlight p {
  color: var(--white);
}
.chain__subline {
  margin-top: var(--space-xs) !important;
  font-size: 0.8rem !important;
  opacity: 0.75;
}
.chain__arrow {
  font-size: 1.125rem;
  color: var(--text-soft);
  padding: var(--space-xs) var(--space-m);
  line-height: 1;
}
.number-highlight {
  color: var(--yellow);
  font-weight: 900;
  font-size: 1.05em;
}

/* ---------- Journey Team ---------- */
/* ---------- Team Constellation ---------- */
.section--team {
  position: relative;
  overflow: hidden;
}

.team-constellation__canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.team-constellation {
  position: relative;
  width: 100%;
  height: 80vh;
  min-height: 500px;
  max-height: 750px;
  z-index: 1;
}

.team-constellation__lines {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* Center node */
.team-constellation__center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 2;
  text-align: center;
}

.team-constellation__core {
  background: rgba(255,219,0,0.08);
  border: 2px solid rgba(255,219,0,0.25);
  border-radius: 50%;
  width: clamp(180px, 22vw, 260px);
  height: clamp(180px, 22vw, 260px);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 1.5rem;
  animation: core-breathe 5s ease-in-out infinite;
  box-shadow: 0 0 60px rgba(255,219,0,0.06), 0 0 120px rgba(255,219,0,0.03);
}

.team-constellation__title {
  font-size: clamp(1.3rem, 2vw, 1.8rem);
  font-weight: 800;
  color: var(--yellow, #ffdb00);
  letter-spacing: -0.02em;
  margin-bottom: 0.3rem;
}

.team-constellation__mission {
  font-size: clamp(0.75rem, 0.95vw, 0.95rem);
  color: rgba(255,255,255,0.6);
  line-height: 1.4;
  max-width: 180px;
}

/* Team member nodes */
.team-constellation__node {
  position: absolute;
  z-index: 3;
  display: flex;
  align-items: center;
  gap: 14px;
  transition: transform 0.4s ease;
}

.team-constellation__node:hover {
  transform: scale(1.05);
}

.team-constellation__node--tl { top: 12%; left: 8%; animation: team-float-a 8s ease-in-out infinite; }
.team-constellation__node--tr { top: 12%; right: 8%; flex-direction: row-reverse; text-align: right; animation: team-float-b 9s ease-in-out infinite; }
.team-constellation__node--bl { bottom: 12%; left: 8%; animation: team-float-c 10s ease-in-out infinite; }
.team-constellation__node--br { bottom: 12%; right: 8%; flex-direction: row-reverse; text-align: right; animation: team-float-d 8.5s ease-in-out infinite; }

@keyframes team-float-a {
  0%, 100% { transform: translate(0, 0); }
  25% { transform: translate(12px, -18px); }
  50% { transform: translate(-6px, -24px); }
  75% { transform: translate(-14px, -10px); }
}

@keyframes team-float-b {
  0%, 100% { transform: translate(0, 0); }
  25% { transform: translate(-14px, -14px); }
  50% { transform: translate(8px, -22px); }
  75% { transform: translate(16px, -8px); }
}

@keyframes team-float-c {
  0%, 100% { transform: translate(0, 0); }
  25% { transform: translate(10px, 16px); }
  50% { transform: translate(-8px, 22px); }
  75% { transform: translate(-16px, 6px); }
}

@keyframes team-float-d {
  0%, 100% { transform: translate(0, 0); }
  25% { transform: translate(-12px, 12px); }
  50% { transform: translate(6px, 20px); }
  75% { transform: translate(14px, 8px); }
}

@keyframes core-breathe {
  0%, 100% { box-shadow: 0 0 40px rgba(255,219,0,0.05), 0 0 80px rgba(255,219,0,0.02); border-color: rgba(255,219,0,0.2); }
  50% { box-shadow: 0 0 60px rgba(255,219,0,0.12), 0 0 120px rgba(255,219,0,0.05); border-color: rgba(255,219,0,0.4); }
}

.team-constellation__avatar {
  width: clamp(70px, 9vw, 100px);
  height: clamp(70px, 9vw, 100px);
  border-radius: 50%;
  overflow: hidden;
  border: 3px solid rgba(255,255,255,0.12);
  flex-shrink: 0;
  box-shadow: 0 0 20px rgba(0,0,0,0.3);
}

.team-constellation__avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.team-constellation__info h3 {
  font-size: clamp(1rem, 1.3vw, 1.3rem);
  font-weight: 700;
  color: var(--white);
  margin: 0;
  line-height: 1.2;
}

.team-constellation__info p {
  font-size: clamp(0.8rem, 0.95vw, 0.95rem);
  color: rgba(255,255,255,0.5);
  margin: 0.2rem 0 0;
  font-weight: 500;
}

/* Legacy grid styles (kept for reference) */
.journey-team-stage {
  min-height: 100%;
  display: grid;
  grid-template-rows: auto 1fr;
  gap: clamp(2rem, 4vw, 3.75rem);
  align-content: center;
}

.journey-team-stage__intro {
  max-width: 58rem;
}

.journey-team-stage__summary {
  max-width: 45rem;
  color: rgba(255,255,255,0.76);
}

.journey-team-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: clamp(1rem, 1.8vw, 1.5rem);
  align-items: stretch;
}

.journey-team-card {
  position: relative;
  min-height: 20rem;
  display: grid;
  grid-template-rows: 1fr auto;
  overflow: hidden;
  border-radius: 1.75rem;
  border: 1px solid rgba(255,255,255,0.08);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02)),
    rgba(8,16,27,0.74);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.05),
    0 28px 60px rgba(0,0,0,0.28);
}

.journey-team-card--lead {
  background: rgba(12,21,34,0.88);
  border-color: rgba(255,255,255,0.10);
}

.journey-team-card__photo {
  position: relative;
  min-height: 14rem;
  display: flex;
  align-items: end;
  justify-content: center;
  padding: 1.4rem 1.15rem 0;
  background:
    radial-gradient(circle at 50% 18%, rgba(255,255,255,0.16), transparent 48%),
    linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0));
}

.journey-team-card__photo::after {
  content: "";
  position: absolute;
  left: 1rem;
  right: 1rem;
  bottom: 0;
  height: 45%;
  background: linear-gradient(180deg, rgba(8,16,27,0), rgba(8,16,27,0.85));
  pointer-events: none;
}

.journey-team-card__photo img {
  width: 100%;
  max-width: 16rem;
  height: auto;
  display: block;
  object-fit: contain;
  object-position: center bottom;
  position: relative;
  z-index: 1;
}

.journey-team-card__body {
  position: relative;
  z-index: 1;
  padding: 1.1rem 1.25rem 1.3rem;
  display: grid;
  gap: 0.45rem;
}

.journey-team-card__eyebrow {
  margin: 0;
  font-size: 0.7rem;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.56);
}

.journey-team-card__name {
  margin: 0;
  font-size: clamp(1.2rem, 1.4vw, 1.5rem);
  line-height: 1.08;
  letter-spacing: -0.03em;
  color: var(--white);
}

.journey-team-card--lead .journey-team-card__eyebrow,
.journey-team-card--lead .journey-team-card__name {
  color: var(--white);
}

.journey-team-card__role {
  font-size: clamp(0.8rem, 0.9vw, 0.95rem);
  color: var(--text-dim, #a0a0be);
  margin: 2px 0 0;
  line-height: 1.3;
}

.journey-team-card__org {
  font-size: clamp(0.75rem, 0.85vw, 0.9rem);
  color: var(--text-muted, #707088);
  margin: 1px 0 0;
  line-height: 1.3;
  font-weight: 600;
}

.journey-team-card--lead .journey-team-card__role,
.journey-team-card--lead .journey-team-card__org {
  color: var(--text-dim, #a0a0be);
}

.journey-team-card--lead .journey-team-card__body {
  background: rgba(255,255,255,0.06);
}

/* ---------- Kickoff Mosaic ---------- */
.section--kickoff-gallery {
  position: relative;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.kickoff-text-overlay {
  position: relative;
  z-index: 2;
  padding: clamp(2rem, 5vw, 4rem) clamp(2rem, 6vw, 5rem);
  padding-bottom: 1.5rem;
}

.kickoff-mosaic {
  flex: 1;
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  grid-template-rows: 1fr 0.7fr;
  gap: 10px;
  padding: 0 clamp(2rem, 6vw, 5rem) clamp(1.5rem, 3vw, 2.5rem);
  min-height: 0;
}

.kickoff-mosaic__hero {
  grid-row: 1 / 2;
  grid-column: 1 / 2;
  border-radius: 14px;
  overflow: hidden;
}

.kickoff-mosaic__side {
  grid-row: 1 / 2;
  grid-column: 2 / 3;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.kickoff-mosaic__bottom {
  grid-row: 2 / 3;
  grid-column: 1 / 3;
  display: flex;
  gap: 10px;
}

.kickoff-mosaic__hero img,
.kickoff-mosaic__img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s ease;
}

.kickoff-mosaic__img {
  flex: 1;
  border-radius: 14px;
  overflow: hidden;
}

.kickoff-mosaic__hero:hover img,
.kickoff-mosaic__img:hover img {
  transform: scale(1.04);
}

/* ---------- Sharing Sessions Constellation ---------- */
.section--sharing {
  position: relative;
  overflow: hidden;
}

.sharing-canvas,
.commitment-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  filter: blur(12px);
  opacity: 0.5;
}

/* ---------- Sharing: Two-Column Layout ---------- */
.sharing-overlay {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(2rem, 5vw, 5rem);
  align-items: center;
  min-height: 100vh;
  padding: clamp(2rem, 5vw, 4rem) clamp(3rem, 7vw, 6rem);
  box-sizing: border-box;
}

.sharing-col--left {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.sharing-col--right {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.sharing-stat {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  margin-top: 1.5rem;
}

.sharing-stat__number {
  font-size: clamp(4.5rem, 8vw, 7rem);
  font-weight: 900;
  color: var(--yellow, #ffdb00);
  line-height: 1;
  letter-spacing: -0.04em;
}

.sharing-stat__label {
  font-size: clamp(1rem, 1.3vw, 1.25rem);
  color: rgba(255,255,255,0.55);
  line-height: 1.35;
  max-width: 10em;
}

/* ---------- Sharing Question Decision Tree ---------- */
.sharing-question {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 16px;
  padding: clamp(1.5rem, 2.5vw, 2.5rem);
}

.sharing-question__prompt {
  font-size: clamp(0.8rem, 1vw, 0.95rem);
  color: rgba(255,255,255,0.4);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-weight: 700;
  margin: 0 0 0.6rem;
}

.sharing-question__text {
  font-size: clamp(1.4rem, 2.2vw, 1.8rem);
  font-weight: 700;
  color: var(--white);
  margin: 0 0 1.75rem;
  font-style: italic;
  line-height: 1.3;
}

.sharing-branches {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.sharing-connector {
  width: 2px;
  height: 1.25rem;
  background: rgba(255,255,255,0.12);
  margin-left: 2rem;
}

.sharing-branch {
  display: flex;
  align-items: flex-start;
  gap: 1.25rem;
  padding: 1.25rem 1.5rem;
  border-radius: 12px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  transition: background 0.2s ease;
}

.sharing-branch:hover {
  background: rgba(255,255,255,0.07);
}

.sharing-branch__label {
  flex-shrink: 0;
  font-size: 0.9rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 0.3rem 0.85rem;
  border-radius: 6px;
  line-height: 1.3;
  margin-top: 0.1rem;
  min-width: 2.5rem;
  text-align: center;
}

.sharing-branch--yes .sharing-branch__label {
  background: rgba(255,219,0,0.18);
  color: var(--yellow, #ffdb00);
  border: 1px solid rgba(255,219,0,0.25);
}

.sharing-branch--no .sharing-branch__label {
  background: rgba(204,0,78,0.18);
  color: #ff6b9d;
  border: 1px solid rgba(204,0,78,0.25);
}

.sharing-branch__desc {
  font-size: clamp(0.95rem, 1.1vw, 1.1rem);
  color: rgba(255,255,255,0.7);
  line-height: 1.55;
  margin: 0;
}

.sharing-artefact {
  position: absolute;
  right: 8%;
  top: 50%;
  transform: translateY(-50%);
  z-index: 1;
  width: clamp(280px, 35vw, 480px);
  border-radius: 14px;
  overflow: hidden;
  border: 2px solid rgba(255,219,0,0.2);
  box-shadow: 0 0 60px rgba(255,219,0,0.06), 0 0 120px rgba(255,219,0,0.03);
  animation: artefact-glow 6s ease-in-out infinite;
}

.sharing-artefact img {
  width: 100%;
  display: block;
}

@keyframes artefact-glow {
  0%, 100% { box-shadow: 0 0 40px rgba(255,219,0,0.04), 0 0 80px rgba(255,219,0,0.02); border-color: rgba(255,219,0,0.15); }
  50% { box-shadow: 0 0 80px rgba(255,219,0,0.1), 0 0 140px rgba(255,219,0,0.04); border-color: rgba(255,219,0,0.35); }
}

/* ---------- Research Gallery ---------- */
.section--research-gallery {
  position: relative;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.research-text-overlay {
  position: relative;
  z-index: 2;
  padding: clamp(2rem, 5vw, 4rem) clamp(2rem, 6vw, 5rem);
  padding-bottom: 1rem;
}

.research-markets {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-top: 1rem;
}

.research-market {
  font-size: clamp(0.85rem, 1vw, 1rem);
  font-weight: 600;
  color: rgba(255,255,255,0.7);
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  padding: 0.4rem 0.9rem;
  border-radius: 8px;
}

.research-mosaic {
  flex: 1;
  display: flex;
  gap: 8px;
  padding: 0.5rem clamp(2rem, 6vw, 5rem) clamp(1rem, 2vw, 2rem);
  min-height: 0;
  overflow: hidden;
}

.research-mosaic__col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.research-mosaic__col--tall {
  flex: 1.2;
}

.research-mosaic__img {
  flex: 1;
  border-radius: 12px;
  overflow: hidden;
  min-height: 0;
}

.research-mosaic__img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s ease, filter 0.6s ease;
  filter: brightness(0.85);
}

.research-mosaic__text {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 1.2rem 1rem;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.03);
}
.research-mosaic__text .body-xl {
  font-size: clamp(0.95rem, 1.4vw, 1.15rem);
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.75);
  margin: 0;
}

.research-mosaic__img:hover img {
  transform: scale(1.05);
  filter: brightness(1);
}

/* ---------- Onboarding Steps (horizontal timeline) ---------- */
.onboarding-steps {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 0;
  margin-top: 1.5rem;
}

.onboarding-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 2rem 1.75rem;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 16px;
  transition: border-color 0.3s;
}

.onboarding-step:hover {
  border-color: rgba(255,255,255,0.12);
}

.onboarding-step__number {
  font-size: 2rem;
  font-weight: 800;
  color: rgba(255,219,0,0.5);
  line-height: 1;
  margin-bottom: 0.75rem;
}

.onboarding-step__title {
  font-size: clamp(1.1rem, 1.3vw, 1.4rem);
  font-weight: 700;
  color: var(--white);
  margin: 0 0 0.5rem;
}

.onboarding-step__desc {
  font-size: clamp(0.9rem, 1vw, 1.05rem);
  color: rgba(255,255,255,0.6);
  line-height: 1.5;
  margin: 0;
}

.onboarding-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 0 1rem;
  color: rgba(255,219,0,0.4);
}

.onboarding-arrow svg {
  width: 28px;
  height: 28px;
}

/* Mobile: stack vertically with downward arrows */
@media (max-width: 768px) {
  .onboarding-steps {
    flex-direction: column;
    gap: 0;
  }

  .onboarding-arrow {
    padding: 0.75rem 0;
    transform: rotate(90deg);
  }
}

.onboarding-step__image {
  flex-shrink: 0;
  width: 180px;
  height: 120px;
  border-radius: 12px;
  overflow: hidden;
}

.onboarding-step__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ---------- Role List ---------- */
.role-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  margin: var(--space-m) 0 var(--space-l);
}
.role-list li {
  padding: var(--space-s) var(--space-m);
  background: rgba(255,255,255,0.1);
  border-radius: var(--radius-m);
  border: 1px solid rgba(255,255,255,0.15);
  font-size: 0.975rem;
  color: rgba(255,255,255,0.9);
}

/* ---------- Steps List ---------- */
.steps-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-m);
  margin: var(--space-l) 0;
}
.steps-list li {
  display: flex;
  gap: var(--space-m);
  align-items: flex-start;
}
.steps-list li strong {
  display: block;
  font-size: 1rem;
  margin-bottom: 4px;
}
.steps-list li p {
  font-size: 0.9rem;
  color: var(--text-soft);
  line-height: 1.5;
}
.step-num {
  font-size: 2rem;
  font-weight: 900;
  color: var(--blue);
  line-height: 1;
  min-width: 3rem;
}

/* ---------- Market Grid ---------- */
.market-grid {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  margin: var(--space-m) 0;
  padding: var(--space-m);
  background: rgba(255,255,255,0.05);
  border-radius: var(--radius-m);
  border-left: 3px solid var(--yellow);
}
.market-item {
  font-size: 0.975rem;
  line-height: 1.5;
}
.market-label {
  font-weight: 700;
  margin-right: var(--space-s);
  color: #7fc3ff;
}

/* ---------- Stat Badge ---------- */
.stat-badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-m);
  margin-top: var(--space-l);
  padding: var(--space-m) var(--space-l);
  background: var(--blue);
  border-radius: var(--radius-l);
  color: var(--white);
}
.stat-badge__number {
  font-size: 3rem;
  font-weight: 900;
  line-height: 1;
}
.stat-badge__label {
  font-size: 1rem;
  font-weight: 600;
  line-height: 1.4;
}

/* ---------- Question Split ---------- */
.question-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-m);
}
.question-card {
  padding: var(--space-l);
  border-radius: var(--radius-l);
}
.question-card--yes {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(127,195,255,0.35);
}
.question-card--no {
  background: var(--blue);
  color: var(--white);
}
.question-card--no .question-answer p {
  color: rgba(255,255,255,0.9);
}
.question-prompt {
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  margin-bottom: var(--space-m);
}
.question-answer p {
  font-size: 1.125rem;
  font-weight: 500;
  line-height: 1.55;
  margin-bottom: var(--space-s);
}
.question-answer strong {
  color: inherit;
}

/* ---------- Quick Wins ---------- */
.quick-wins-section { }
.wins-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-m);
  margin-top: var(--space-m);
}
.win-card {
  padding: var(--space-l);
  background: rgba(255,255,255,0.05);
  border-radius: var(--radius-l);
  border: 1px solid var(--line);
}
.win-num {
  font-size: 0.7rem;
  font-weight: 900;
  color: var(--yellow);
  background: var(--dark);
  width: 2rem;
  height: 2rem;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-m);
}
.win-card h3 {
  font-size: 1rem;
  font-weight: 700;
  margin-bottom: var(--space-xs);
  color: var(--white);
}
.win-card p {
  font-size: 0.875rem;
  color: var(--text-soft);
  line-height: 1.55;
}

/* ---------- Constellation Canvas (fixed global layer) ---------- */
.constellation-fixed {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
  pointer-events: none;
  background: #08080F;
}

/* Blur + dark scrim on constellation for slide 4 only */
.section--with-constellation::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  backdrop-filter: blur(3px);
  background: linear-gradient(180deg, rgba(6,17,28,0.4) 0%, rgba(6,17,28,0.18) 40%, rgba(6,17,28,0.3) 100%);
}
.section--with-constellation .section__inner {
  position: relative;
  z-index: 2;
}

/* ---------- Workshop Background ---------- */
/* ---------- Workshop Gallery (mosaic layout like kickoff) ---------- */
.workshop-text-overlay {
  position: relative;
  z-index: 2;
  padding: clamp(2rem, 5vw, 4rem) clamp(2rem, 6vw, 5rem);
  padding-bottom: 1.5rem;
}

.stat-row--inline {
  margin: var(--space-m) 0 0;
}

.workshop-mosaic {
  flex: 1;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  padding: 0 clamp(1rem, 3vw, 2rem) clamp(1rem, 2vw, 1.5rem);
  min-height: 0;
}
.workshop-mosaic__col {
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-height: 0;
}
.workshop-mosaic__text {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 1.2rem 1.5rem;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.03);
}
.workshop-mosaic__text .body-xl {
  font-size: clamp(0.95rem, 1.4vw, 1.15rem);
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.75);
  margin: 0;
}

.workshop-mosaic__hero img,
.workshop-mosaic__img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s ease;
}

.workshop-mosaic__img {
  flex: 1;
  border-radius: 14px;
  overflow: hidden;
}

.workshop-mosaic__hero:hover img,
.workshop-mosaic__img:hover img {
  transform: scale(1.04);
}

.section__inner--overlay {
  position: relative;
  z-index: 1;
}

/* ---------- Workshop Stats ---------- */
.stat-row {
  display: flex;
  gap: var(--space-xl);
  margin: var(--space-l) 0;
  align-items: flex-end;
}
.stat-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 1rem 1.8rem;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 12px;
  min-width: 6rem;
}
.stat-number {
  font-size: clamp(3rem, 7vw, 5rem);
  font-weight: 900;
  color: var(--yellow);
  line-height: 1;
}
.stat-label {
  font-size: 0.875rem;
  font-weight: 700;
  color: rgba(255,255,255,0.6);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-top: 0.3rem;
}

/* ---------- Opportunities Dashboard ---------- */
.opps-dashboard {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  align-items: center;
}

.opps-hero-stat {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  text-align: center;
}

.opps-hero-stat__number {
  font-size: clamp(4rem, 8vw, 6rem);
  font-weight: 900;
  color: var(--yellow, #ffdb00);
  line-height: 1;
  letter-spacing: -0.04em;
}

.opps-hero-stat__label {
  font-size: clamp(1rem, 1.3vw, 1.2rem);
  color: rgba(255,255,255,0.5);
  text-align: left;
  max-width: 280px;
  line-height: 1.4;
}

.opps-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  width: 100%;
}

.opp-card {
  background: rgba(255,255,255,0.02);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 14px;
  padding: 1.2rem 1.3rem;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  transition: border-color 0.3s, background 0.3s;
  border-top: 3px solid var(--opp-color, rgba(255,255,255,0.1));
}

.opp-card:hover {
  border-color: var(--opp-color, rgba(255,255,255,0.15));
  background: rgba(255,255,255,0.04);
}

.opp-card__header {
  display: flex;
  align-items: center;
  gap: 0.7rem;
}

.opp-card__count {
  font-size: clamp(1.6rem, 2.2vw, 2rem);
  font-weight: 900;
  color: var(--opp-color, #fff);
  line-height: 1;
  flex-shrink: 0;
}

.opp-card__title {
  font-size: clamp(1rem, 1.3vw, 1.25rem);
  font-weight: 800;
  color: var(--opp-color, #fff);
  line-height: 1.15;
  min-height: 3.45em;
  display: flex;
  align-items: center;
}

.opp-card__desc {
  font-size: clamp(0.9rem, 1.1vw, 1.05rem);
  color: rgba(255,255,255,0.6);
  line-height: 1.4;
  margin: 0;
}
.opp-card__desc strong {
  color: rgba(255,255,255,0.9);
  font-weight: 700;
}

.opp-card__example {
  font-size: clamp(0.78rem, 0.9vw, 0.88rem);
  color: var(--opp-color, rgba(255,255,255,0.5));
  line-height: 1.4;
  font-style: normal;
  font-weight: 600;
  margin: 0;
  padding-top: 0.5rem;
  border-top: 1px solid rgba(255,255,255,0.06);
}

/* ---------- Outcomes (legacy) ---------- */
.outcomes-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-m);
}
.outcome-card {
  background: rgba(255,255,255,0.05);
  border-radius: var(--radius-xl);
  overflow: hidden;
  border: 1px solid var(--line);
}
.outcome-card--featured {
  border-color: var(--blue);
  border-width: 2px;
}
.outcome-card__img img {
  width: 100%;
  height: 180px;
  object-fit: cover;
  border-radius: 0;
}
.outcome-card__body {
  padding: var(--space-m);
}
.outcome-card__body h3 {
  font-size: 1rem;
  font-weight: 800;
  margin-bottom: var(--space-xs);
  line-height: 1.3;
}
.outcome-card__body p {
  font-size: 0.875rem;
  color: var(--text-soft);
  line-height: 1.55;
  margin-bottom: var(--space-xs);
}
.outcome-quote {
  font-weight: 700 !important;
  color: #8fceff !important;
  font-style: italic;
}

.outcomes-meta {
  max-width: var(--text-max);
}
.outcomes-pullquote {
  margin-top: var(--space-l);
}

/* ---------- Scroll Story ---------- */
.scroll-story {
  height: 300vh;
  position: relative;
}
.scroll-story--2 { height: 200vh; }
.scroll-story__stage {
  position: sticky;
  top: 0;
  height: 100vh;
  overflow: hidden;
  background: var(--light);
  display: flex;
  align-items: center;
  justify-content: center;
}
.scroll-story__stage--split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: stretch;
}
.scroll-story__stage--dark {
  background: var(--dark);
}
.scroll-story__stage--clear {
  background: transparent;
}
.scroll-story__stage--strategy {
  background:
    radial-gradient(circle at top left, rgba(255, 219, 0, 0.2), transparent 32%),
    linear-gradient(135deg, #fffdf5 0%, #f3f7fb 45%, #edf3f8 100%);
}

/* General step — full-stage cross-fade (section 04 style) */
.scroll-story__step {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.55s ease, transform 0.55s ease;
  pointer-events: none;
}
.scroll-story__step.is-active {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.scroll-story__stage--strategy .scroll-story__step {
  transition: opacity 0.5s ease, transform 0.5s ease;
}

.manager-step {
  width: min(var(--max-width), calc(100vw - 4rem));
  display: grid;
  grid-template-columns: minmax(300px, 420px) minmax(420px, 1fr);
  gap: clamp(2rem, 4vw, 5rem);
  align-items: center;
  padding: 0;
}

/* Left column override for split stages */
.story-steps-container {
  position: relative;
  height: 100vh;
}
.story-steps-container .scroll-story__step {
  justify-content: flex-start;
  padding-left: var(--space-xxl);
  transform: translateY(28px);
}
.story-steps-container .scroll-story__step.is-active {
  transform: translateY(0);
}

/* Right: persistent photo */
.story-photo-panel {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-l) var(--space-l) var(--space-l) var(--space-m);
  height: 100vh;
}
.story-photo-panel img {
  width: 100%;
  height: 52vh;
  object-fit: cover;
  object-position: center 52%;
  border-radius: var(--radius-xl);
  box-shadow: 0 24px 64px rgba(0,0,0,0.08);
}

/* ---------- Manager Profile Cards (s03) ---------- */
.managers-panel {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-l);
  padding: 0 var(--space-xl) 0 var(--space-l);
  height: 100vh;
}
.manager-card {
  display: flex;
  align-items: center;
  gap: var(--space-m);
  padding: var(--space-m) var(--space-l);
  background: rgba(255,255,255,0.05);
  border-radius: var(--radius-xl);
  box-shadow: 0 8px 32px rgba(0,0,0,0.07);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.manager-avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
  border: 3px solid var(--light);
}
.manager-info {
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.manager-name {
  font-size: 1.1rem;
  font-weight: 800;
  color: var(--white);
  letter-spacing: -0.01em;
}
.manager-role {
  font-size: 0.875rem;
  font-weight: 500;
  color: #8fceff;
}
.manager-team {
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--text-soft);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.manager-step__portrait--stack {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-m);
}

.manager-step__person {
  padding: 0;
  text-align: center;
}

.manager-step__person img {
  width: 100%;
  aspect-ratio: 4 / 5;
  object-fit: cover;
  object-position: center top;
  border-radius: 0;
  margin-bottom: var(--space-s);
}

.manager-step__text {
  max-width: 620px;
}

.manager-step__support {
  max-width: 34rem;
  margin-top: var(--space-m);
  color: var(--text-soft);
}

.manager-step--brief {
  grid-template-columns: minmax(180px, 220px) minmax(480px, 1fr);
  gap: clamp(1.5rem, 3vw, 2.5rem);
  align-items: start;
}

.manager-step--brief .manager-step__portrait--stack {
  grid-template-columns: 1fr;
  gap: 0.85rem;
  align-content: start;
  max-width: 172px;
  padding-top: 0.45rem;
}

.manager-step--brief .manager-step__person {
  display: grid;
  grid-template-columns: 54px minmax(0, 1fr);
  gap: 0.68rem;
  align-items: center;
  text-align: left;
  padding: 0.45rem 0.55rem;
  border-radius: 1rem;
  background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
}

.manager-step--brief .manager-step__person img {
  width: 54px;
  height: 54px;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  object-position: center top;
  border-radius: 50%;
  margin-bottom: 0;
  border: 1px solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.03);
}

.manager-step--brief .manager-step__person > :not(img) {
  align-self: center;
}

.manager-step--brief .manager-step__name {
  font-size: 0.84rem;
  font-weight: 700;
  line-height: 1.15;
  color: rgba(255,255,255,0.9);
}

.manager-step--brief .manager-step__role {
  margin-top: 0.12rem;
  font-size: 0.71rem;
  font-weight: 500;
  line-height: 1.2;
  color: rgba(143, 206, 255, 0.76);
}

.manager-step--brief .manager-step__team {
  margin-top: 0.18rem;
  font-size: 0.63rem;
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.46);
}

.manager-step--brief .manager-step__text {
  max-width: 42rem;
}

.strategy-map {
  display: grid;
  gap: 1rem;
  margin: 1.45rem 0 0.9rem;
}

.strategy-pillars {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.9rem;
}

.strategy-pillar {
  min-height: 7.6rem;
  padding: 1rem 1rem 1.05rem;
  border-radius: 1.1rem;
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
}

.strategy-pillar__title {
  font-size: 1.02rem;
  font-weight: 800;
  line-height: 1.15;
  letter-spacing: -0.02em;
}

.strategy-pillar__meta {
  margin-top: 0.45rem;
  font-size: 0.78rem;
  font-weight: 700;
  line-height: 1.35;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  opacity: 0.82;
}

.strategy-pillar__note {
  margin-top: 0.7rem;
  font-size: 0.72rem;
  font-weight: 700;
  line-height: 1.35;
  letter-spacing: 0.04em;
  color: rgba(255,255,255,0.82);
}

.strategy-pillar__price {
  display: flex;
  flex-direction: column;
  gap: 0.18rem;
  margin-top: 0.85rem;
}

.strategy-pillar__price-label {
  font-size: 0.68rem;
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.78);
}

.strategy-pillar__price-value {
  font-size: clamp(1.7rem, 2.8vw, 2.5rem);
  font-weight: 900;
  line-height: 0.95;
  letter-spacing: -0.05em;
  color: rgba(255,255,255,0.99);
}

.strategy-pillar__price-period {
  font-size: 0.76rem;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: 0.04em;
  color: rgba(255,255,255,0.82);
}

.strategy-pillar--blue {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.9);
}

.strategy-pillar--yellow {
  background: linear-gradient(180deg, rgba(255, 219, 0, 0.92), rgba(233, 188, 0, 0.82));
  color: #1a1400;
  border: 1px solid rgba(255, 219, 0, 0.4);
}


.strategy-pillar--primary {
  min-height: 8.4rem;
  border-color: rgba(255, 219, 0, 0.26);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.07),
    0 0 0 1px rgba(255, 219, 0, 0.06);
}

.strategy-pillar--primary .strategy-pillar__title {
  font-size: 1.14rem;
}

.strategy-pillar--primary .strategy-pillar__meta {
  color: rgba(38,29,0,0.86);
}

.strategy-pillar--expanded {
  min-height: 13rem;
  padding: 1.5rem 1.4rem;
  border-radius: 1.35rem;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.strategy-pillar--expanded .strategy-pillar__title {
  font-size: clamp(1.55rem, 2.8vw, 2.2rem);
  line-height: 1.02;
}

.strategy-pillar--expanded .strategy-pillar__meta {
  font-size: 0.92rem;
  letter-spacing: 0.06em;
}

.strategy-pillar--expanded .strategy-pillar__price {
  margin-top: 1rem;
}

.strategy-pillar--expanded .strategy-pillar__price-value {
  font-size: clamp(2.3rem, 4vw, 3.3rem);
}

.strategy-pillar--expanded .strategy-pillar__price-label {
  font-size: 0.74rem;
}

.strategy-pillar--expanded .strategy-pillar__price-period {
  font-size: 0.84rem;
}

.strategy-pillar--expanded .strategy-pillar__note {
  font-size: 0.8rem;
}

.strategy-pillar--teal {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.9);
}

.strategy-pillar--slate {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.9);
}

.strategy-support {
  display: grid;
  gap: 0.4rem;
  padding: 1rem 1.1rem;
  border-left: 4px solid var(--yellow);
  background: rgba(255,255,255,0.05);
  border-radius: 0 1rem 1rem 0;
}

.strategy-support__label {
  font-size: 0.7rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--yellow);
}

.strategy-support__text {
  font-size: 1rem;
  font-weight: 600;
  line-height: 1.45;
  color: rgba(255,255,255,0.9);
}

.manager-step--brief .body-xl {
  max-width: 44rem;
  line-height: 1.6;
  color: rgba(255,255,255,0.9);
}

.manager-step--brief .manager-step__support {
  max-width: 42rem;
  margin-top: 1rem;
  color: rgba(255,255,255,0.72);
}

.manager-step--brief .manager-step__support strong {
  color: rgba(255,255,255,0.95);
  font-weight: 800;
}

.strategy-focus {
  width: min(var(--max-width), calc(100vw - 4rem));
  display: grid;
  grid-template-columns: minmax(280px, 420px) minmax(460px, 1fr);
  gap: clamp(1.5rem, 4vw, 4rem);
  align-items: center;
}

.strategy-focus__card {
  display: flex;
  flex-direction: column;
  gap: 0.9rem;
  align-items: center;
  justify-content: center;
}

.strategy-managers {
  display: flex;
  gap: 0.7rem;
  align-items: center;
  align-self: flex-start;
}

.strategy-manager {
  display: inline-flex;
  align-items: center;
  gap: 0.48rem;
  min-height: 2.5rem;
  padding: 0.38rem 0.65rem 0.38rem 0.38rem;
  border-radius: 999px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.10);
  color: rgba(255,255,255,0.9);
  font-size: 0.76rem;
  font-weight: 700;
  opacity: 0.92;
  transform-origin: top left;
  transform:
    translate(var(--manager-morph-x, 0px), var(--manager-morph-y, 10px))
    scale(var(--manager-morph-scale-x, 1), var(--manager-morph-scale-y, 1));
  transition: opacity 260ms ease 140ms, transform 520ms cubic-bezier(0.22, 1, 0.36, 1) 80ms;
}

.strategy-manager img {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  object-fit: cover;
  object-position: center top;
  border: 1px solid rgba(255,255,255,0.14);
}

.strategy-focus__card .strategy-pillar {
  width: min(100%, 24rem);
  transform: scale(0.55);
  transform-origin: top left;
  opacity: 0;
  transition: transform 600ms cubic-bezier(0.16, 1, 0.3, 1),
              opacity 400ms ease;
}

.strategy-focus__text {
  max-width: 40rem;
  opacity: 0;
  transform: translateX(26px);
  transition: opacity 400ms ease 300ms, transform 500ms cubic-bezier(0.16, 1, 0.3, 1) 300ms;
}

.strategy-focus__text .body-xl {
  max-width: 40rem;
  line-height: 1.6;
  color: rgba(255,255,255,0.9);
}

.strategy-focus__text .manager-step__support {
  max-width: 38rem;
}

.strategy-focus__kpi {
  margin-top: var(--space-l);
  padding: var(--space-m) var(--space-l);
  background: rgba(255,219,0,0.08);
  border-left: 3px solid var(--yellow);
  border-radius: 0 var(--radius-m) var(--radius-m) 0;
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}
.strategy-focus__kpi-label {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
}
.strategy-focus__kpi-value {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 900;
  color: var(--yellow);
  line-height: 1;
  letter-spacing: -0.03em;
}
.strategy-focus__kpi-period {
  font-size: 0.8rem;
  font-weight: 600;
  color: rgba(255,255,255,0.5);
}

#s03b.is-visible .strategy-focus__card .strategy-pillar {
  transform: scale(1);
  opacity: 1;
}

#s03b.is-visible .strategy-focus__text {
  opacity: 1;
  transform: translateX(0);
}

#s03b.is-visible .strategy-manager {
  opacity: 1;
  transform: translate(0, 0) scale(1, 1);
}

.manager-step__metric {
  margin-top: 0.6rem;
  font-size: 0.9rem;
  color: rgba(255,255,255,0.62);
}

.manager-step__metric strong {
  color: rgba(255,255,255,0.92);
}

.orchestrator-hero {
  width: min(var(--max-width), calc(100vw - 4rem));
  display: grid;
  grid-template-columns: minmax(0, 0.48fr) minmax(0, 0.52fr);
  gap: clamp(1.2rem, 2.4vw, 2.2rem);
  align-items: start;
}

.orchestrator-hero__intro {
  max-width: 31rem;
  padding-top: 0;
  padding-bottom: 0.5rem;
  align-self: start;
}

.orchestrator-hero__eyebrow {
  color: #ef8f76;
  position: relative;
  padding-left: 3.5rem;
  letter-spacing: 0.16em;
}

.orchestrator-hero__eyebrow::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  width: 2.6rem;
  height: 1px;
  background: #ef8f76;
  transform: translateY(-50%);
}

.orchestrator-hero__intro .heading-xl {
  max-width: 9ch;
  font-size: clamp(2.65rem, 4.4vw, 4rem);
  line-height: 0.98;
  letter-spacing: -0.045em;
  margin-bottom: 0.7rem;
}

.orchestrator-hero__intro .heading-xl .accent,
.orchestrator-hero__intro .heading-xl strong {
  color: var(--yellow);
}

.orchestrator-usp {
  max-width: 28rem;
  font-size: clamp(1.14rem, 1.6vw, 1.34rem);
  line-height: 1.6;
  color: rgba(255,255,255,0.78);
}

.orchestrator-hero__portrait {
  display: block;
  align-self: start;
  padding-right: 1rem;
  padding-top: 0.4rem;
}

.orchestrator-system {
  width: min(100%, 28.5rem);
  margin-left: auto;
  margin-right: auto;
}

.orchestrator-portrait-wrap {
  position: relative;
  width: 100%;
  padding-bottom: 2.25rem;
}

.orchestrator-hero__portrait img {
  width: 100%;
  max-width: none;
  display: block;
  height: 16.5rem;
  object-fit: cover;
  object-position: center 24%;
  border-radius: 1.4rem;
  box-shadow: 0 28px 70px rgba(0,0,0,0.18);
  filter: saturate(1.02) contrast(1.02);
}

.orchestrator-identity {
  width: calc(100% - 2rem);
  position: absolute;
  left: 1rem;
  bottom: 0;
  transform: none;
  padding: 0.9rem 1rem 0.95rem;
  border-radius: 1.2rem;
  background:
    linear-gradient(180deg, rgba(26, 34, 56, 0.92), rgba(17, 24, 42, 0.96)),
    rgba(17, 24, 42, 0.92);
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow:
    0 20px 40px rgba(0,0,0,0.24),
    inset 0 1px 0 rgba(255,255,255,0.05);
  backdrop-filter: blur(14px);
  overflow: hidden;
}

.orchestrator-identity::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top left, rgba(255, 219, 0, 0.14), transparent 36%),
    linear-gradient(135deg, rgba(255,255,255,0.04), transparent 58%);
  pointer-events: none;
}

.orchestrator-identity__label {
  font-size: 0.82rem;
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.72);
  position: relative;
  z-index: 1;
}

.orchestrator-identity__subtitle {
  margin-top: 0.3rem;
  font-size: 0.88rem;
  line-height: 1.35;
  color: rgba(255,255,255,0.92);
  position: relative;
  z-index: 1;
}

.orchestrator-capabilities {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.9rem;
  width: 100%;
}

.orchestrator-capability {
  padding: 1.2rem 1.2rem 1.15rem;
  border-radius: 1.15rem;
  background: linear-gradient(180deg, rgba(14, 21, 37, 0.96), rgba(11, 17, 31, 0.98));
  border: 1px solid rgba(255,255,255,0.04);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
  min-height: 9.5rem;
}

.orchestrator-capability__head {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 1.05rem;
}

.orchestrator-capability__icon {
  width: 1.35rem;
  height: 1.35rem;
  flex-shrink: 0;
  border-radius: 999px;
  position: relative;
}

.orchestrator-capability__icon::before,
.orchestrator-capability__icon::after {
  content: "";
  position: absolute;
}

.orchestrator-capability__icon--connects {
  background: rgba(255, 219, 0, 0.16);
}

.orchestrator-capability__icon--connects::before {
  inset: 0.32rem;
  border-radius: 50%;
  background: var(--yellow);
  box-shadow: -0.5rem 0 0 -0.08rem var(--yellow), 0.5rem 0 0 -0.08rem var(--yellow), 0 -0.5rem 0 -0.08rem var(--yellow), 0 0.5rem 0 -0.08rem var(--yellow);
}

.orchestrator-capability__icon--process {
  background: rgba(239, 143, 118, 0.16);
}

.orchestrator-capability__icon--process::before {
  left: 0.6rem;
  top: 0.2rem;
  width: 0.12rem;
  height: 0.9rem;
  background: #ef8f76;
  border-radius: 999px;
}

.orchestrator-capability__icon--process::after {
  left: 0.38rem;
  top: 0.82rem;
  width: 0.52rem;
  height: 0.12rem;
  background: #ef8f76;
  border-radius: 999px;
}

.orchestrator-capability__icon--truth {
  background: rgba(255, 219, 0, 0.16);
}

.orchestrator-capability__icon--truth::before {
  left: 0.28rem;
  top: 0.26rem;
  width: 0.78rem;
  height: 0.82rem;
  border: 0.12rem solid var(--yellow);
  border-top-width: 0.18rem;
  border-radius: 0.28rem;
}

.orchestrator-capability__icon--clarifies {
  background: rgba(239, 143, 118, 0.16);
}

.orchestrator-capability__icon--clarifies::before {
  left: 0.28rem;
  top: 0.28rem;
  width: 0.72rem;
  height: 0.72rem;
  border: 0.12rem solid #ef8f76;
  border-radius: 50%;
}

.orchestrator-capability__icon--clarifies::after {
  right: 0.16rem;
  bottom: 0.18rem;
  width: 0.34rem;
  height: 0.12rem;
  background: #ef8f76;
  transform: rotate(45deg);
  border-radius: 999px;
}

.orchestrator-capability__icon--action {
  background: rgba(255, 219, 0, 0.16);
}

.orchestrator-capability__icon--action::before {
  left: 0.24rem;
  top: 0.6rem;
  width: 0.78rem;
  height: 0.12rem;
  background: var(--yellow);
  border-radius: 999px;
}

.orchestrator-capability__icon--action::after {
  right: 0.16rem;
  top: 0.46rem;
  width: 0.36rem;
  height: 0.36rem;
  border-top: 0.12rem solid var(--yellow);
  border-right: 0.12rem solid var(--yellow);
  transform: rotate(45deg);
}

.orchestrator-capability h3 {
  font-size: 0.82rem;
  font-weight: 800;
  line-height: 1.22;
  letter-spacing: 0.02em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.96);
}

.orchestrator-capability p {
  margin-top: 0.75rem;
  font-size: 0.92rem;
  line-height: 1.55;
  color: rgba(255,255,255,0.66);
}

.orchestrator-capability--wide {
  grid-column: 1 / -1;
  min-height: 7.25rem;
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  column-gap: 1rem;
}

.orchestrator-capability--wide .orchestrator-capability__head {
  gap: 0.9rem;
}

.orchestrator-capability--wide p {
  margin-top: 0.55rem;
}

.orchestrator-capability--wide::after {
  content: "\2192";
  align-self: center;
  font-size: 1.2rem;
  font-weight: 700;
  color: rgba(255, 219, 0, 0.72);
}

.orchestrator-partners {
  width: min(var(--max-width), calc(100vw - 4rem));
  display: flex;
  gap: 2.2rem;
  margin-top: 0.8rem;
}

.orchestrator-partner {
  display: grid;
  gap: 0.12rem;
}

.orchestrator-partner__role {
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.38);
}

.orchestrator-partner__name {
  font-size: 0.98rem;
  font-weight: 800;
  color: #ef8f76;
}

.orchestrator-partner:first-child .orchestrator-partner__name {
  color: var(--yellow);
}

/* ---------- Orchestrator Slide Redesign ---------- */
.orchestrator-stage {
  width: min(var(--max-width), calc(100vw - 4rem));
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: clamp(1.2rem, 2.4vw, 2.2rem);
  align-items: stretch;
}

.orchestrator-stage__copy {
  max-width: none;
  min-height: 100%;
  padding: 2.2rem 2rem 2rem;
  border-radius: 1.6rem;
  background:
    radial-gradient(circle at top left, rgba(255, 219, 0, 0.08), transparent 30%),
    linear-gradient(180deg, rgba(18, 28, 48, 0.92), rgba(9, 15, 28, 0.98));
  border: 1px solid rgba(255,255,255,0.06);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.04),
    0 24px 60px rgba(0,0,0,0.18);
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.orchestrator-stage__eyebrow {
  color: #ef8f76;
  position: relative;
  padding-left: 3.5rem;
  letter-spacing: 0.16em;
}

.orchestrator-stage__eyebrow::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  width: 2.6rem;
  height: 1px;
  background: #ef8f76;
  transform: translateY(-50%);
}

.orchestrator-stage__title {
  max-width: 7ch;
  margin: 0.8rem 0 0.9rem;
  font-size: clamp(2.8rem, 4.8vw, 4.5rem);
  font-weight: 800;
  line-height: 0.96;
  letter-spacing: -0.05em;
  color: var(--yellow);
}

.orchestrator-stage__usp {
  max-width: 28rem;
  font-size: clamp(1.18rem, 1.7vw, 1.42rem);
  line-height: 1.62;
  color: rgba(255,255,255,0.86);
}

.orchestrator-stage__bridge {
  max-width: 24rem;
  margin-top: 1rem;
  font-size: 1rem;
  line-height: 1.52;
  color: rgba(255,255,255,0.6);
}

.orchestrator-stage__system {
  width: min(100%, 31rem);
  margin: 0 auto;
  display: grid;
  gap: 0.95rem;
}

.orchestrator-stage__portrait {
  position: relative;
  width: 100%;
  padding-bottom: 2.2rem;
}

.orchestrator-stage__portrait img {
  width: 100%;
  height: 18.5rem;
  object-fit: cover;
  object-position: center 24%;
  border-radius: 1.5rem;
  box-shadow: 0 28px 70px rgba(0,0,0,0.22);
  filter: saturate(1.02) contrast(1.02);
  display: block;
}

.orchestrator-stage__identity {
  position: absolute;
  left: 1rem;
  right: 1rem;
  bottom: 0;
  padding: 0.95rem 1.05rem 1rem;
  border-radius: 1.2rem;
  background:
    linear-gradient(180deg, rgba(28, 36, 58, 0.92), rgba(16, 24, 42, 0.96)),
    rgba(17, 24, 42, 0.94);
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow:
    0 20px 40px rgba(0,0,0,0.24),
    inset 0 1px 0 rgba(255,255,255,0.05);
  backdrop-filter: blur(14px);
  overflow: hidden;
}

.orchestrator-stage__identity::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top left, rgba(255, 219, 0, 0.14), transparent 36%),
    linear-gradient(135deg, rgba(255,255,255,0.04), transparent 58%);
  pointer-events: none;
}

.orchestrator-stage__identity-label,
.orchestrator-stage__identity-subtitle {
  position: relative;
  z-index: 1;
}

.orchestrator-stage__identity-label {
  font-size: 0.82rem;
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.72);
}

.orchestrator-stage__identity-subtitle {
  margin-top: 0.3rem;
  font-size: 0.98rem;
  line-height: 1.35;
  color: rgba(255,255,255,0.92);
}

.orchestrator-stage__capabilities {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.75rem;
  margin-top: 0;
}

.orchestrator-card {
  min-height: 8.5rem;
  padding: 1rem 1rem 0.95rem;
  border-radius: 1.15rem;
  background: linear-gradient(180deg, rgba(14, 21, 37, 0.96), rgba(11, 17, 31, 0.98));
  border: 1px solid rgba(255,255,255,0.05);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
}

.orchestrator-card--wide {
  grid-column: 1 / -1;
  min-height: 6.8rem;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  align-items: center;
  gap: 1rem;
}

.orchestrator-card__marker {
  width: 2.1rem;
  height: 0.22rem;
  border-radius: 999px;
  margin-bottom: 0.9rem;
}

.orchestrator-card--yellow .orchestrator-card__marker {
  background: linear-gradient(90deg, rgba(255, 219, 0, 0.95), rgba(255, 219, 0, 0.45));
}

.orchestrator-card--coral .orchestrator-card__marker {
  background: linear-gradient(90deg, rgba(239, 143, 118, 0.95), rgba(239, 143, 118, 0.45));
}

.orchestrator-card h3 {
  margin-top: 0;
  font-size: 0.84rem;
  font-weight: 800;
  line-height: 1.22;
  letter-spacing: 0.02em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.96);
}

.orchestrator-card p {
  margin-top: 0.78rem;
  font-size: 0.92rem;
  line-height: 1.55;
  color: rgba(255,255,255,0.66);
}

.orchestrator-card__body h3 {
  margin-top: 0;
}

.orchestrator-card__body p {
  margin-top: 0.45rem;
}

.orchestrator-card--wide .orchestrator-card__marker {
  margin-bottom: 0;
  align-self: start;
  margin-top: 0.25rem;
}

.orchestrator-card__arrow {
  width: 1.1rem;
  height: 1.1rem;
  position: relative;
}

.orchestrator-card__arrow::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.48rem;
  width: 0.78rem;
  height: 0.12rem;
  background: rgba(255, 219, 0, 0.78);
  border-radius: 999px;
}

.orchestrator-card__arrow::after {
  content: "";
  position: absolute;
  right: 0;
  top: 0.3rem;
  width: 0.36rem;
  height: 0.36rem;
  border-top: 0.12rem solid rgba(255, 219, 0, 0.78);
  border-right: 0.12rem solid rgba(255, 219, 0, 0.78);
  transform: rotate(45deg);
}

.manager-step__impact {
  display: flex;
  flex-direction: column;
  gap: var(--space-l);
  padding: 0;
  background: transparent;
  color: var(--white);
}

.manager-step__impact-label {
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #8fceff;
}

.impact-flow {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  font-size: clamp(1.1rem, 1.8vw, 1.35rem);
  font-weight: 700;
  letter-spacing: -0.02em;
}

.impact-flow__arrow {
  color: var(--yellow);
  font-size: 1.3rem;
}

.impact-stat {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  padding-top: var(--space-m);
  border-top: 1px solid rgba(27, 50, 74, 0.12);
}

.impact-stat__value {
  font-size: clamp(3rem, 6vw, 4.8rem);
  font-weight: 800;
  line-height: 0.95;
  letter-spacing: -0.05em;
}

.impact-stat__meta {
  font-size: 0.95rem;
  font-weight: 600;
  letter-spacing: 0.03em;
  text-transform: uppercase;
  color: var(--text-soft);
}

.story-card {
  width: min(var(--text-max), calc(100vw - 4rem));
  max-width: none;
  text-align: center;
  padding: 0;
}
.story-card--left {
  text-align: left;
  padding: 0;
}
.problem-hero-copy {
  position: relative;
  z-index: 2;
  width: min(42rem, calc(100vw - 4rem));
  margin-right: auto;
  border: 1.5px solid rgba(255, 255, 255, 0.09);
  border-radius: var(--radius-xl);
  padding: var(--space-l) var(--space-xl);
}
.problem-hero-title {
  font-size: clamp(1.6rem, 3vw, 2.5rem);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.02em;
  color: var(--yellow);
  margin-bottom: var(--space-l);
}

.story-step-num {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  margin-bottom: var(--space-l);
}
.cost-flow {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: var(--space-s);
  margin: var(--space-l) 0;
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--white);
}
.cost-arrow {
  color: #8fceff;
  font-size: 1.25rem;
  font-weight: 700;
}
.cost-stat {
  font-size: clamp(1.125rem, 2vw, 1.5rem);
  font-weight: 700;
  color: #8fceff;
  margin-top: var(--space-m);
  line-height: 1.4;
}
.cost-stat strong {
  color: var(--white);
}

/* ---------- Timeline ---------- */
.timeline-slide {
  width: 100%;
  max-width: min(var(--max-width), calc(100vw - 4rem));
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-xl);
}
.timeline-intro { max-width: 600px; }

.timeline-chart {
  display: flex;
  flex-direction: column;
  gap: var(--space-s);
  width: 100%;
}

/* Month labels */
.tl-months {
  display: grid;
  grid-template-columns: repeat(10, 1fr);
  gap: 4px;
}
.tl-months span {
  text-align: center;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  padding-bottom: var(--space-xs);
}
.tl-dim    { color: rgba(255,255,255,0.18) !important; }
.tl-yellow { color: var(--yellow) !important; }

/* Phase blocks */
.tl-phases {
  display: grid;
  grid-template-columns: repeat(10, 1fr);
  gap: 4px;
  height: 88px;
  align-items: stretch;
}
.tl-phase {
  border-radius: var(--radius-m);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: var(--space-xs);
  gap: 2px;
  transition: opacity 0.3s;
}
.tl-phase span  { font-size: 0.75rem; font-weight: 700; line-height: 1.25; }
.tl-phase small { font-size: 0.65rem; font-weight: 400; opacity: 0.8; line-height: 1.2; }

.tl-phase--blue   { background: rgba(100,160,255,0.28); color: rgba(200,225,255,0.95); }
.tl-phase--purple { background: rgba(160,100,255,0.28); color: rgba(220,200,255,0.95); }
.tl-phase--orange { background: rgba(255,140, 60,0.28); color: rgba(255,215,170,0.95); }
.tl-phase--green  { background: rgba( 60,210,120,0.28); color: rgba(180,255,210,0.95); }
.tl-phase--pink   { background: rgba(255, 90,150,0.28); color: rgba(255,200,220,0.95); }
.tl-phase--olive  { background: rgba(200,200, 80,0.28); color: rgba(240,240,180,0.95); }
.tl-phase--finale { background: var(--yellow); color: var(--dark); }
.tl-phase--finale span { font-size: 0.75rem; font-weight: 900; }
.tl-phase--ghost  { background: rgba(255,255,255,0.04); border: 1px dashed rgba(255,255,255,0.08); }

/* Milestones */
.tl-milestones {
  display: grid;
  grid-template-columns: repeat(10, 1fr);
  gap: 4px;
  margin-top: var(--space-s);
}
.tl-milestone {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}
.tl-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: rgba(255,255,255,0.35);
  flex-shrink: 0;
}
.tl-dot--yellow { background: var(--yellow); }
.tl-milestone p {
  font-size: 0.68rem;
  font-weight: 600;
  color: rgba(255,255,255,0.5);
  text-align: center;
  line-height: 1.35;
}
.tl-milestone--big p { color: var(--yellow); font-weight: 700; }

/* ---------- Stack Header ---------- */
.stack__header {
  max-width: var(--text-max);
}

/* ---------- Closing ---------- */
.closing-quote {
  font-size: clamp(1.75rem, 4.5vw, 3.25rem);
  font-weight: 800;
  line-height: 1.3;
  color: var(--white);
  border: none;
  padding: 0;
  margin: var(--space-xl) auto;
  letter-spacing: -0.02em;
  font-style: normal;
}
.closing-attribution {
  font-size: clamp(1rem, 1.5vw, 1.25rem);
  font-weight: 700;
  color: var(--yellow);
  margin-bottom: var(--space-l);
}
.closing-note {
  font-size: 1rem;
  color: rgba(255,255,255,0.65);
  max-width: 560px;
  margin: 0 auto;
  line-height: 1.65;
}

/* ---------- Implication / Footer ---------- */
.event-footer {
  margin-top: var(--space-xxl);
  font-size: 0.8rem;
  color: var(--mid);
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

/* ---------- Responsive ---------- */
@media (max-width: 960px) {
  .section__inner--split {
    grid-template-columns: 1fr;
    gap: var(--space-l);
  }
  .section__inner--reverse {
    direction: ltr;
  }
  .split__image img,
  .split__image--left img {
    height: 300px;
  }
  .wins-grid {
    grid-template-columns: 1fr;
  }
  .outcomes-grid {
    grid-template-columns: 1fr;
  }
  .question-split {
    grid-template-columns: 1fr;
  }
  .stat-row {
    gap: var(--space-l);
  }
  .sidenav {
    display: none;
  }
  .section__inner {
    padding: var(--space-xl) var(--space-m);
  }
  .section__inner--title {
    padding: var(--space-xl) var(--space-m);
  }
  .intro-connection {
    width: min(100vw - 2rem, 760px);
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 1rem;
  }
  .connection-slide {
    width: min(100vw - 2rem, 760px);
    grid-template-columns: 1fr;
    gap: 1.75rem;
  }
  .connection-slide__text .problem-hero-title,
  .connection-slide__text .body-xl {
    max-width: none;
  }
  .connection-slide__visual {
    justify-content: center;
    min-height: 24rem;
    padding-left: 0;
  }
  .hook-proof {
    width: min(32rem, 100%);
  }
  .hook-metric {
    min-height: 7.8rem;
  }
  .manager-step {
    grid-template-columns: 1fr;
    width: min(100vw - 2rem, 720px);
    padding: 1.5rem;
    gap: 1.5rem;
  }
  .manager-step--brief {
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .manager-step--brief .manager-step__portrait--stack {
    max-width: none;
    grid-template-columns: 1fr 1fr;
  }
  .manager-step__portrait--stack {
    grid-template-columns: 1fr 1fr;
