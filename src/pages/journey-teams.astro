}

.orchestrator-capability__icon--connects {
  background: rgba(255, 219, 0, 0.16);
}

.orchestrator-capability__icon--connects::before {
  inset: 0.32rem;
  border-radius: 50%;
  background: var(--yellow);
  box-shadow: -0.5rem 0 0 -0.08rem var(--yellow), 0.5rem 0 0 -0.08rem var(--yellow), 0 -0.5rem 0 -0.08rem var(--yellow), 0 0.5rem 0 -0.08rem var(--yellow);
}

.orchestrator-capability__icon--process {
  background: rgba(239, 143, 118, 0.16);
}

.orchestrator-capability__icon--process::before {
  left: 0.6rem;
  top: 0.2rem;
  width: 0.12rem;
  height: 0.9rem;
  background: #ef8f76;
  border-radius: 999px;
}

.orchestrator-capability__icon--process::after {
  left: 0.38rem;
  top: 0.82rem;
  width: 0.52rem;
  height: 0.12rem;
  background: #ef8f76;
  border-radius: 999px;
}

.orchestrator-capability__icon--truth {
  background: rgba(255, 219, 0, 0.16);
}

.orchestrator-capability__icon--truth::before {
  left: 0.28rem;
  top: 0.26rem;
  width: 0.78rem;
  height: 0.82rem;
  border: 0.12rem solid var(--yellow);
  border-top-width: 0.18rem;
  border-radius: 0.28rem;
}

.orchestrator-capability__icon--clarifies {
  background: rgba(239, 143, 118, 0.16);
}

.orchestrator-capability__icon--clarifies::before {
  left: 0.28rem;
  top: 0.28rem;
  width: 0.72rem;
  height: 0.72rem;
  border: 0.12rem solid #ef8f76;
  border-radius: 50%;
}

.orchestrator-capability__icon--clarifies::after {
  right: 0.16rem;
  bottom: 0.18rem;
  width: 0.34rem;
  height: 0.12rem;
  background: #ef8f76;
  transform: rotate(45deg);
  border-radius: 999px;
}

.orchestrator-capability__icon--action {
  background: rgba(255, 219, 0, 0.16);
}

.orchestrator-capability__icon--action::before {
  left: 0.24rem;
  top: 0.6rem;
  width: 0.78rem;
  height: 0.12rem;
  background: var(--yellow);
  border-radius: 999px;
}

.orchestrator-capability__icon--action::after {
  right: 0.16rem;
  top: 0.46rem;
  width: 0.36rem;
  height: 0.36rem;
