function initTeamConstellation() {
  const canvas = document.getElementById('teamCanvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H;
  function resize() {
    const rect = canvas.parentElement.getBoundingClientRect();
    W = canvas.width = rect.width * devicePixelRatio;
    H = canvas.height = rect.height * devicePixelRatio;
    canvas.style.width = rect.width + 'px';
    canvas.style.height = rect.height + 'px';
    ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
  }
  resize();
  window.addEventListener('resize', resize);
  const members = [
    { x: 0.16, y: 0.22 }, { x: 0.84, y: 0.22 },
    { x: 0.16, y: 0.78 }, { x: 0.84, y: 0.78 },
  ];
  const center = { x: 0.5, y: 0.5 };
  const pulses = [];
  function spawnPulse() {
    const member = members[Math.floor(Math.random() * members.length)];
    pulses.push({ member, t: 0, speed: 0.005 + Math.random() * 0.005, outward: Math.random() > 0.4, hue: 45 + Math.random() * 15 });
  }
  setInterval(spawnPulse, 400);
  const particles = Array.from({ length: 30 }, () => ({
    x: Math.random(), y: Math.random(), vx: (Math.random() - 0.5) * 0.0002, vy: (Math.random() - 0.5) * 0.0002,
    size: 1 + Math.random() * 1.5, alpha: 0.1 + Math.random() * 0.15,
  }));
  function draw() {
    const w = W / devicePixelRatio; const h = H / devicePixelRatio;
    ctx.clearRect(0, 0, w, h);
    const cx = center.x * w; const cy = center.y * h;
    members.forEach(m => {
      ctx.beginPath(); ctx.moveTo(cx, cy); ctx.lineTo(m.x * w, m.y * h);
      ctx.strokeStyle = 'rgba(255,219,0,0.08)'; ctx.lineWidth = 1.5; ctx.stroke();
    });
    for (let i = 0; i < members.length; i++) {
      for (let j = i + 1; j < members.length; j++) {
        ctx.beginPath(); ctx.moveTo(members[i].x * w, members[i].y * h); ctx.lineTo(members[j].x * w, members[j].y * h);
        ctx.strokeStyle = 'rgba(255,255,255,0.025)'; ctx.lineWidth = 0.8; ctx.stroke();
      }
    }
    for (let i = pulses.length - 1; i >= 0; i--) {
      const p = pulses[i]; p.t += p.speed;
      if (p.t > 1) { pulses.splice(i, 1); continue; }
      const progress = p.outward ? p.t : 1 - p.t;
      const mx = p.member.x * w; const my = p.member.y * h;
      const px = cx + (mx - cx) * progress; const py = cy + (my - cy) * progress;
      const alpha = Math.sin(p.t * Math.PI) * 0.8;
      const glow = ctx.createRadialGradient(px, py, 0, px, py, 20);
      glow.addColorStop(0, `hsla(${p.hue}, 100%, 70%, ${alpha * 0.5})`);
      glow.addColorStop(0.5, `hsla(${p.hue}, 100%, 60%, ${alpha * 0.15})`);
      glow.addColorStop(1, `hsla(${p.hue}, 100%, 50%, 0)`);
      ctx.fillStyle = glow; ctx.beginPath(); ctx.arc(px, py, 20, 0, Math.PI * 2); ctx.fill();
      ctx.beginPath(); ctx.arc(px, py, 3, 0, Math.PI * 2);
      ctx.fillStyle = `hsla(${p.hue}, 100%, 85%, ${alpha})`; ctx.fill();
    }
    particles.forEach(p => {
      p.x += p.vx; p.y += p.vy;
      if (p.x < 0 || p.x > 1) p.vx *= -1; if (p.y < 0 || p.y > 1) p.vy *= -1;
      ctx.beginPath(); ctx.arc(p.x * w, p.y * h, p.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255,219,0,${p.alpha})`; ctx.fill();
    });
    if (running) requestAnimationFrame(draw);
  }
  const section = canvas.closest('.section');
  let running = false;
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting && !running) { running = true; requestAnimationFrame(draw); }
      else if (!entry.isIntersecting) { running = false; }
    });
  }, { threshold: 0.2 });
  observer.observe(section);
}

