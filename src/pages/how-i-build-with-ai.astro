---
import Layout from '../layouts/Layout.astro'
---

<Layout title="How I Build with AI — UX Design Meets AI Agents | Pablo Suzarte" description="From idea to live site in one conversation. A UX designer's method for orchestrating AI agents to design, build, and deploy." lang="en">

  <!-- NAV -->
  <header class="page-nav">
    <div class="page-nav__inner">
      <a href="/" class="page-nav__back">&larr; Portfolio</a>
      <a href="/" class="page-nav__logo">PS</a>
      <span class="page-nav__title">How I Build with AI</span>
    </div>
  </header>

  <!-- ========================================
       HERO
       ======================================== -->
  <section class="hero">
    <div class="hero__bg">
      <div class="blob blob--1"></div>
      <div class="blob blob--2"></div>
      <div class="blob blob--3"></div>
    </div>
    <div class="hero__content">
      <div class="hero__intro reveal">
        <img class="hero__avatar" src="https://journeyteams.vercel.app/screenshots/web/pablo2.jpg" alt="Pablo Suzarte" />
        <div class="hero__intro-text">
          <p class="hero__name">Pablo Suzarte</p>
          <p class="hero__role">Senior UX Designer, IKEA Global</p>
        </div>
      </div>
      <p class="eyebrow reveal reveal-d1">How I Build with AI</p>
      <h1 class="hero__headline reveal reveal-d2">From idea to live site.<br />One conversation.</h1>
      <p class="hero__subtitle reveal reveal-d3">I use AI agents as creative partners to design, build, and deploy full projects. This is how I work every day, and this page was built the same way.</p>
      <div class="hero__logos reveal reveal-d4">
        <div class="ai-badge">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M17.3041 3.541h-3.6718l6.696 16.918H24Zm-10.6082 0L0 20.459h3.7442l1.3693-3.5527h7.0052l1.3693 3.5528h3.7442L10.5363 3.5409Zm-.3712 10.2232 2.2914-5.9456 2.2914 5.9456Z"/></svg>
          <span>Powered by Claude</span>
        </div>
      </div>
      <a href="#tutorials" class="btn-primary reveal reveal-d5">
        Start with Tutorial 0
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </section>

  <!-- ========================================
       STATS BAR
       ======================================== -->
  <div class="stats-bar">
    <div class="container">
      <div class="stats-grid">
        <div class="reveal">
          <div class="stat__number">5+</div>
          <div class="stat__label">Projects shipped</div>
        </div>
        <div class="reveal reveal-d1">
          <div class="stat__number">80+</div>
          <div class="stat__label">Co-workers impacted</div>
        </div>
        <div class="reveal reveal-d2">
          <div class="stat__number">14</div>
          <div class="stat__label">Slides built in one session</div>
        </div>
        <div class="reveal reveal-d3">
          <div class="stat__number">&lt; 2min</div>
          <div class="stat__label">Idea to deploy</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ========================================
       TUTORIALS
       ======================================== -->
  <section class="tutorials-section" id="tutorials">
    <div class="container">
      <div class="tutorials-header reveal">
        <p class="tutorials-eyebrow">AI School</p>
        <h2 class="tutorials-title">Start learning</h2>
        <p class="tutorials-subtitle">Step-by-step tutorials for building with AI — from complete beginner to orchestrating agents. No experience needed.</p>
      </div>
      <div class="tutorials-grid">
        <a href="/workshop/power-setup" class="tutorial-card tutorial-card--featured reveal reveal-d1">
          <div class="tutorial-card__badge">Start Here</div>
          <div class="tutorial-card__num">Tutorial 0</div>
          <h3 class="tutorial-card__title">Supercharge Your Setup</h3>
          <p class="tutorial-card__desc">Claude Code out of the box has a fundamental memory problem. This tutorial installs 7 tools that fix it — and turn Claude into a real orchestration machine. Takes 30 minutes. Do this before anything else.</p>
          <div class="tutorial-card__meta">
            <span>30 min</span>
            <span>·</span>
            <span>Complete Beginner</span>
            <span>·</span>
            <span>Setup Guide</span>
          </div>
          <div class="tutorial-card__arrow">Read tutorial &rarr;</div>
        </a>
        <a href="/workshop/claude-code-101" class="tutorial-card reveal reveal-d2">
          <div class="tutorial-card__num">Tutorial 1</div>
          <h3 class="tutorial-card__title">Claude Code 101</h3>
          <p class="tutorial-card__desc">From asking a chatbot to orchestrating an agent that understands your world. A slow, practical journey through shared memory, orientation, evidence, permissions, roles, and continuity.</p>
          <div class="tutorial-card__meta">
            <span>3–4 hours</span>
            <span>·</span>
            <span>Zero to Orchestrator</span>
            <span>·</span>
            <span>Workshop</span>
          </div>
          <div class="tutorial-card__arrow">Read tutorial &rarr;</div>
        </a>
      </div>
    </div>
  </section>

  <!-- ========================================
       01 - THE SETUP
       ======================================== -->
  <section id="setup">
    <div class="container">
      <div class="section-label reveal">01</div>
      <h2 class="section-title reveal reveal-d1">Set up your project in 3 steps</h2>
      <div class="card-grid card-grid--3">
        <div class="card reveal reveal-d1">
          <h3 class="card__title">Create the folder</h3>
          <p class="card__text">Every project starts with a clean folder. This becomes your workspace, your repo, and your deployment source.</p>
        </div>
        <div class="card reveal reveal-d2">
          <h3 class="card__title">Add project intelligence</h3>
          <p class="card__text"><span class="card__code">CLAUDE.md</span> tells the AI who you are, what you are building, and how to behave. <span class="card__code">SKILL.md</span>, <span class="card__code">AGENTS.md</span>, and memory files give it depth.</p>
        </div>
        <div class="card reveal reveal-d3">
          <h3 class="card__title">Open the terminal</h3>
          <p class="card__text">Run Claude Code in your project folder. The AI reads your files, understands your intent, and starts building.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================
       02 - PROJECT INTELLIGENCE
       ======================================== -->
  <section>
    <div class="container">
      <div class="section-label reveal">02</div>
      <h2 class="section-title reveal reveal-d1">Teach the AI your project</h2>
      <div class="card-grid card-grid--2">
        <div class="card reveal reveal-d1">
          <span class="card__code">CLAUDE.md</span>
          <h3 class="card__title">The main briefing</h3>
          <p class="card__text">Rules, structure, tone, what is locked, what is open. The single source of truth for every conversation.</p>
        </div>
        <div class="card reveal reveal-d2">
          <span class="card__code">SKILL.md</span>
          <h3 class="card__title">Deep context</h3>
          <p class="card__text">Strategy, audience, evidence, assets. Everything the AI needs to make informed decisions about your project.</p>
        </div>
        <div class="card reveal reveal-d3">
          <h3 class="card__title">Memory System</h3>
          <p class="card__text">Persistent files that help the AI remember across conversations. User preferences, feedback, project state.</p>
        </div>
        <div class="card reveal reveal-d4">
          <h3 class="card__title">Agents</h3>
          <p class="card__text">Specialized sub-agents for different tasks. Visual design, build, motion, quality review. Each with its own tools and focus.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================
       03 - THE WORKFLOW
       ======================================== -->
  <section>
    <div class="container">
      <div class="section-label reveal">03</div>
      <h2 class="section-title reveal reveal-d1">Build, preview, iterate, ship</h2>
      <div class="timeline">
        <div class="timeline__step reveal reveal-d1">
          <div class="timeline__number">1</div>
          <h3 class="timeline__title">Describe your vision</h3>
          <p class="timeline__text">Tell the AI what you want. Be specific about the feeling, not just the features.</p>
        </div>
        <div class="timeline__step reveal reveal-d2">
          <div class="timeline__number">2</div>
          <h3 class="timeline__title">Watch it build</h3>
          <p class="timeline__text">Open a local preview. The AI writes HTML, CSS, JS in real time. You see every change instantly.</p>
        </div>
        <div class="timeline__step reveal reveal-d3">
          <div class="timeline__number">3</div>
          <h3 class="timeline__title">Guide with feedback</h3>
          <p class="timeline__text">Screenshot what you see. Say what to fix. The AI reads your files before every edit.</p>
        </div>
        <div class="timeline__step reveal reveal-d4">
          <div class="timeline__number">4</div>
          <h3 class="timeline__title">Commit and push</h3>
          <p class="timeline__text">The AI commits to GitHub with clear messages. Push triggers automatic deployment to Vercel.</p>
        </div>
        <div class="timeline__step reveal reveal-d5">
          <div class="timeline__number">5</div>
          <h3 class="timeline__title">Live in minutes</h3>
          <p class="timeline__text">Your site is live. Custom domain, SSL, CDN. From idea to production in one session.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================
       04 - AGENT ORCHESTRATION
       ======================================== -->
  <section>
    <div class="container">
      <div class="section-label reveal">04</div>
      <h2 class="section-title reveal reveal-d1">Multiple agents, one vision</h2>
      <p class="section-description reveal reveal-d2">Complex projects use specialized agents working in parallel. A build agent writes code while a visual designer reviews composition. A motion engineer handles animations while a quality reviewer checks everything.</p>
      <div class="card-grid card-grid--3">
        <div class="card reveal reveal-d2">
          <h3 class="card__title">Parallel execution</h3>
          <p class="card__text">Launch multiple agents at once for independent tasks. They work simultaneously without blocking each other.</p>
        </div>
        <div class="card reveal reveal-d3">
          <h3 class="card__title">Specialized roles</h3>
          <p class="card__text">Each agent has its own tools and expertise. Build, design, motion, quality. Focus creates better output.</p>
        </div>
        <div class="card reveal reveal-d4">
          <h3 class="card__title">Shared context</h3>
          <p class="card__text">All agents read the same project files and follow the same rules. Consistency without coordination overhead.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================
       05 - REAL PROJECTS
       ======================================== -->
  <section>
    <div class="container">
      <div class="section-label reveal">05</div>
      <h2 class="section-title reveal reveal-d1">Everything on this site was built this way</h2>
      <div class="card-grid card-grid--3">
        <a href="https://journeyteams.vercel.app/" target="_blank" rel="noopener noreferrer" class="card card--link reveal reveal-d1">
          <h3 class="card__title">Journey Teams</h3>
          <p class="card__text">A 14-slide scroll presentation for IKEA Digital Sharing Days. Built in one session with constellation animations, photo galleries, and live data.</p>
          <span class="card__link">
            View project
            <svg class="card__link-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
        <div class="card reveal reveal-d2">
          <h3 class="card__title">This Portfolio</h3>
          <p class="card__text">The site you are on right now. Astro, multi-language, AI-generated content, deployed on Vercel.</p>
        </div>
        <a href="/ai-projects" class="card card--link reveal reveal-d3">
          <h3 class="card__title">More projects</h3>
          <p class="card__text">AI Project Brain Lab, La Mami, and more. All built with the same method.</p>
          <span class="card__link">
            Explore all
            <svg class="card__link-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ========================================
       CTA
       ======================================== -->
  <section class="cta">
    <div class="container">
      <h2 class="cta__title reveal">Want to build like this?</h2>
      <p class="cta__subtitle reveal reveal-d1">The method is simple. The results speak for themselves.</p>
      <div class="cta__buttons reveal reveal-d2">
        <a href="/ai-projects" class="btn-primary">
          See my AI projects
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/" class="btn-secondary">&larr; Back to portfolio</a>
      </div>
    </div>
  </section>

  <!-- ========================================
       FOOTER
       ======================================== -->
  <footer class="page-footer">
    <div class="container">
      <p class="page-footer__text">Built with AI by <a href="/">Pablo Suzarte</a></p>
    </div>
  </footer>

  <script>
    /* Intersection Observer for entrance animations */
    (function () {
      const revealElements = document.querySelectorAll('.reveal');
      if (!revealElements.length) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.15,
          rootMargin: '0px 0px -40px 0px',
        }
      );

      revealElements.forEach((el) => observer.observe(el));
    })();
  </script>
</Layout>

<style>
  /* ========================================
     GRAIN TEXTURE OVERLAY
     ======================================== */
  :global(body)::after {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 128px 128px;
  }

  /* ========================================
     TUTORIALS SECTION
     ======================================== */
  .tutorials-section {
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--accent) 3%, var(--bg));
  }

  .tutorials-header {
    margin-bottom: 3rem;
  }

  .tutorials-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .tutorials-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    color: var(--text);
    margin-bottom: 0.75rem;
    line-height: 1.1;
  }

  .tutorials-subtitle {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.6;
    max-width: 560px;
  }

  .tutorials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .tutorial-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
    position: relative;
  }

  .tutorial-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .tutorial-card--featured {
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    background: color-mix(in srgb, var(--accent) 5%, var(--surface));
  }

  .tutorial-card--featured:hover {
    border-color: var(--accent);
  }

  .tutorial-card__badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #000;
    background: var(--accent);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    width: fit-content;
  }

  .tutorial-card__num {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .tutorial-card__title {
    font-size: 1.4rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--text);
    line-height: 1.2;
  }

  .tutorial-card__desc {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.7;
    flex: 1;
  }

  .tutorial-card__meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--muted);
    flex-wrap: wrap;
    align-items: center;
  }

  .tutorial-card__arrow {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent);
    margin-top: 0.25rem;
  }

  @media (max-width: 768px) {
    .tutorials-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ========================================
     GLOBAL FONT
     ======================================== */
  :global(body) {
    font-family: var(--font-sans);
  }

  /* ========================================
     LAYOUT
     ======================================== */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  section {
    padding: 120px 0;
    position: relative;
  }

  @media (max-width: 768px) {
    section {
      padding: 80px 0;
    }
  }

  /* ========================================
     NAV
     ======================================== */
  .page-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    border-bottom: 1px solid var(--border);
  }

  .page-nav__inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0.9rem 2rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .page-nav__back {
    color: var(--muted);
    font-size: 0.85rem;
    font-weight: 500;
    font-family: var(--font-sans);
    text-decoration: none;
    transition: color 0.2s;
  }

  .page-nav__back:hover {
    color: var(--text);
  }

  .page-nav__logo {
    font-weight: 800;
    font-size: 1.1rem;
    letter-spacing: -0.04em;
    color: var(--text);
    font-family: var(--font-sans);
    text-decoration: none;
  }

  .page-nav__title {
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-left: auto;
    font-family: var(--font-sans);
  }

  /* ========================================
     TYPOGRAPHY
     ======================================== */
  .eyebrow {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
    font-family: var(--font-sans);
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    font-size: 14px;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 20px;
    font-family: var(--font-sans);
  }

  .section-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    color: var(--text);
    line-height: 1.15;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
    font-family: var(--font-display);
  }

  .section-description {
    font-size: 17px;
    color: var(--muted);
    line-height: 1.7;
    max-width: 640px;
    font-family: var(--font-sans);
  }

  /* ========================================
     ENTRANCE ANIMATIONS
     ======================================== */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-d1 { transition-delay: 0.08s; }
  .reveal-d2 { transition-delay: 0.16s; }
  .reveal-d3 { transition-delay: 0.24s; }
  .reveal-d4 { transition-delay: 0.32s; }
  .reveal-d5 { transition-delay: 0.40s; }

  /* ========================================
     HERO SECTION
     ======================================== */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    padding: 60px 0;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.4;
    will-change: transform;
  }

  .blob--1 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 60%, #7c3aed) 0%, transparent 70%);
    top: 10%;
    left: 15%;
    animation: blobFloat1 14s ease-in-out infinite;
  }

  .blob--2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, color-mix(in srgb, var(--surface-3) 80%, var(--accent)) 0%, transparent 70%);
    top: 40%;
    right: 10%;
    animation: blobFloat2 18s ease-in-out infinite;
  }

  .blob--3 {
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
    bottom: 10%;
    left: 40%;
    opacity: 0.15;
    animation: blobFloat3 16s ease-in-out infinite;
  }

  @keyframes blobFloat1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(40px, -30px) scale(1.05); }
    66% { transform: translate(-20px, 20px) scale(0.95); }
  }

  @keyframes blobFloat2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-50px, 20px) scale(1.08); }
    66% { transform: translate(30px, -40px) scale(0.92); }
  }

  @keyframes blobFloat3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, 30px) scale(1.1); }
    66% { transform: translate(-40px, -10px) scale(0.9); }
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 720px;
    padding: 0 24px;
  }

  .hero__intro {
    display: flex;
