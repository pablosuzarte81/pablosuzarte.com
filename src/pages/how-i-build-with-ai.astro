    <div style="max-width:900px;margin:0 auto;padding:0.9rem 2rem;display:flex;align-items:center;gap:1.5rem;">
      <a href="/" style="color:#a1a1aa;font-size:0.85rem;font-weight:500;">&larr; Portfolio</a>
      <a href="/" style="font-weight:800;font-size:1.1rem;letter-spacing:-0.04em;color:#e4e4e7;">PS</a>
      <span style="color:#71717a;font-size:0.8rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;margin-left:auto;">How I Build with AI</span>
