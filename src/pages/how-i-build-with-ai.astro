<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>How I Build with AI | Pablo Suzarte</title>
  <meta name="description" content="From idea to live site in one conversation. I use AI agents to design, build, and deploy full projects." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style is:inline>
    /* ========================================
       RESET & BASE
       ======================================== */
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      font-family: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
      background: #0a0a0b;
      color: #e4e4e7;
      line-height: 1.6;
      overflow-x: hidden;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      max-width: 100%;
      display: block;
    }

    /* ========================================
       GRAIN TEXTURE OVERLAY
       ======================================== */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 9999;
      pointer-events: none;
      opacity: 0.035;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 128px 128px;
    }

    /* ========================================
       LAYOUT
       ======================================== */
    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px;
    }

    section {
      padding: 120px 0;
      position: relative;
    }

    @media (max-width: 768px) {
      section {
        padding: 80px 0;
      }
    }

    /* ========================================
       TYPOGRAPHY
       ======================================== */
    .eyebrow {
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #a78bfa;
      margin-bottom: 16px;
    }

    .section-label {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 1px solid rgba(167, 139, 250, 0.3);
      font-size: 14px;
      font-weight: 700;
      color: #a78bfa;
      margin-bottom: 20px;
    }

    .section-title {
      font-size: clamp(28px, 4vw, 40px);
      font-weight: 800;
      color: #fafafa;
      line-height: 1.15;
      margin-bottom: 20px;
      letter-spacing: -0.02em;
    }

    .section-description {
      font-size: 17px;
      color: #a1a1aa;
      line-height: 1.7;
      max-width: 640px;
    }

    /* ========================================
       ENTRANCE ANIMATIONS
       ======================================== */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-d1 { transition-delay: 0.08s; }
    .reveal-d2 { transition-delay: 0.16s; }
    .reveal-d3 { transition-delay: 0.24s; }
    .reveal-d4 { transition-delay: 0.32s; }
    .reveal-d5 { transition-delay: 0.40s; }

    /* ========================================
       HERO SECTION
       ======================================== */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      position: relative;
      overflow: hidden;
      padding: 60px 0;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      overflow: hidden;
    }

    .blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(100px);
      opacity: 0.4;
      will-change: transform;
    }

    .blob-1 {
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, #7c3aed 0%, transparent 70%);
      top: 10%;
      left: 15%;
      animation: blobFloat1 14s ease-in-out infinite;
    }

    .blob-2 {
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, #2563eb 0%, transparent 70%);
      top: 40%;
      right: 10%;
      animation: blobFloat2 18s ease-in-out infinite;
    }

    .blob-3 {
      width: 350px;
      height: 350px;
      background: radial-gradient(circle, #eab308 0%, transparent 70%);
      bottom: 10%;
      left: 40%;
      opacity: 0.2;
      animation: blobFloat3 16s ease-in-out infinite;
    }

    @keyframes blobFloat1 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(40px, -30px) scale(1.05); }
      66% { transform: translate(-20px, 20px) scale(0.95); }
    }

    @keyframes blobFloat2 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(-50px, 20px) scale(1.08); }
      66% { transform: translate(30px, -40px) scale(0.92); }
    }

    @keyframes blobFloat3 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(30px, 30px) scale(1.1); }
      66% { transform: translate(-40px, -10px) scale(0.9); }
    }

    .hero-content {
      position: relative;
      z-index: 1;
      max-width: 720px;
    }

    .hero .eyebrow {
      margin-bottom: 24px;
    }

    .hero-headline {
      font-size: clamp(36px, 6vw, 64px);
      font-weight: 800;
      color: #fafafa;
      line-height: 1.08;
      letter-spacing: -0.03em;
      margin-bottom: 24px;
    }

    .hero-subtitle {
      font-size: clamp(16px, 2vw, 19px);
      color: #a1a1aa;
      line-height: 1.7;
      margin-bottom: 40px;
      max-width: 560px;
      margin-left: auto;
      margin-right: auto;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 32px;
      background: #7c3aed;
      color: #fff;
      font-family: inherit;
      font-size: 15px;
      font-weight: 600;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      transition: background 0.2s, transform 0.2s;
    }

    .btn-primary:hover {
      background: #6d28d9;
      transform: translateY(-1px);
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 32px;
      background: transparent;
      color: #e4e4e7;
      font-family: inherit;
      font-size: 15px;
      font-weight: 600;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 12px;
      cursor: pointer;
      transition: border-color 0.2s, transform 0.2s, background 0.2s;
    }

    .btn-secondary:hover {
      border-color: rgba(255, 255, 255, 0.3);
      background: rgba(255, 255, 255, 0.04);
      transform: translateY(-1px);
    }

    /* ========================================
       STATS BAR
       ======================================== */
    .stats-bar {
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      padding: 48px 0;
      background: rgba(255, 255, 255, 0.015);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
      text-align: center;
    }

    .stat-number {
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 800;
      color: #fafafa;
      letter-spacing: -0.02em;
      line-height: 1.1;
    }

    .stat-label {
      font-size: 14px;
      color: #71717a;
      margin-top: 6px;
      font-weight: 500;
    }

    @media (max-width: 600px) {
      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 32px 16px;
      }
    }

    /* ========================================
       CARDS
       ======================================== */
    .card-grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-top: 48px;
    }

    .card-grid-2x2 {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
      margin-top: 48px;
    }

    @media (max-width: 768px) {
      .card-grid-3,
      .card-grid-2x2 {
        grid-template-columns: 1fr;
      }
    }

    .card {
      background: rgba(255, 255, 255, 0.025);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 32px 28px;
      transition: border-color 0.25s, transform 0.25s, background 0.25s;
    }

    .card:hover {
      border-color: rgba(255, 255, 255, 0.18);
      transform: translateY(-2px);
      background: rgba(255, 255, 255, 0.04);
    }

    .card-title {
      font-size: 17px;
      font-weight: 700;
      color: #fafafa;
      margin-bottom: 10px;
    }

    .card-text {
      font-size: 15px;
      color: #a1a1aa;
      line-height: 1.65;
    }

    .card-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 16px;
      font-size: 14px;
      font-weight: 600;
      color: #a78bfa;
      transition: gap 0.2s;
    }

    .card:hover .card-link {
      gap: 10px;
    }

    .card-link-arrow {
      transition: transform 0.2s;
    }

    .card:hover .card-link-arrow {
      transform: translateX(2px);
    }

    .card-code {
      font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
      font-size: 14px;
      color: #c4b5fd;
      background: rgba(167, 139, 250, 0.08);
      padding: 2px 8px;
      border-radius: 6px;
      display: inline-block;
      margin-bottom: 8px;
    }

    /* ========================================
       TIMELINE / STEPS
       ======================================== */
    .timeline {
      margin-top: 48px;
      position: relative;
      padding-left: 60px;
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: 17px;
      top: 0;
      bottom: 0;
      width: 1px;
      background: linear-gradient(to bottom, rgba(167, 139, 250, 0.3), rgba(167, 139, 250, 0.05));
    }

    .timeline-step {
      position: relative;
      padding-bottom: 48px;
    }

    .timeline-step:last-child {
      padding-bottom: 0;
    }

    .step-number {
      position: absolute;
      left: -60px;
      top: 0;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 1px solid rgba(167, 139, 250, 0.3);
      background: #0a0a0b;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 700;
      color: #a78bfa;
      z-index: 1;
    }

    .step-title {
      font-size: 17px;
      font-weight: 700;
      color: #fafafa;
      margin-bottom: 8px;
    }

    .step-text {
      font-size: 15px;
      color: #a1a1aa;
      line-height: 1.65;
      max-width: 520px;
    }

    /* ========================================
       CTA SECTION
       ======================================== */
    .cta-section {
      text-align: center;
      padding: 140px 0;
    }

    .cta-title {
      font-size: clamp(28px, 4.5vw, 44px);
      font-weight: 800;
      color: #fafafa;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
    }

    .cta-subtitle {
      font-size: 17px;
      color: #a1a1aa;
      margin-bottom: 40px;
    }

    .cta-buttons {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* ========================================
       FOOTER
       ======================================== */
    .footer {
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      padding: 32px 0;
      text-align: center;
    }

    .footer-text {
      font-size: 13px;
      color: #52525b;
    }

    .footer-text a {
      color: #71717a;
      transition: color 0.2s;
    }

    .footer-text a:hover {
      color: #a1a1aa;
    }
  </style>
</head>
<body>

  <!-- ========================================
       HERO
       ======================================== -->
  <section class="hero">
    <div class="hero-bg">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
    </div>
    <div class="hero-content">
      <p class="eyebrow reveal">How I Build with AI</p>
      <h1 class="hero-headline reveal reveal-d1">From idea to live site.<br />One conversation.</h1>
      <p class="hero-subtitle reveal reveal-d2">I use AI agents to design, build, and deploy full projects. No templates. No boilerplate. Just vision and conversation.</p>
      <a href="#setup" class="btn-primary reveal reveal-d3">
        Get Started
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </section>

  <!-- ========================================
       STATS BAR
       ======================================== -->
  <div class="stats-bar">
    <div class="container">
      <div class="stats-grid">
        <div class="reveal">
          <div class="stat-number">5+</div>
          <div class="stat-label">Projects shipped</div>
        </div>
        <div class="reveal reveal-d1">
          <div class="stat-number">80+</div>
          <div class="stat-label">Co-workers impacted</div>
        </div>
        <div class="reveal reveal-d2">
          <div class="stat-number">14</div>
          <div class="stat-label">Slides built in one session</div>
        </div>
        <div class="reveal reveal-d3">
          <div class="stat-number">&lt; 2min</div>
          <div class="stat-label">Idea to deploy</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ========================================
       01 — THE SETUP
       ======================================== -->
  <section id="setup">
    <div class="container">
      <div class="section-label reveal">01</div>
      <h2 class="section-title reveal reveal-d1">Set up your project in 3 steps</h2>
      <div class="card-grid-3">
        <div class="card reveal reveal-d1">
          <h3 class="card-title">Create the folder</h3>
          <p class="card-text">Every project starts with a clean folder. This becomes your workspace, your repo, and your deployment source.</p>
        </div>
        <div class="card reveal reveal-d2">
          <h3 class="card-title">Add project intelligence</h3>
          <p class="card-text"><span class="card-code">CLAUDE.md</span> tells the AI who you are, what you are building, and how to behave. <span class="card-code">SKILL.md</span>, <span class="card-code">AGENTS.md</span>, and memory files give it depth.</p>
        </div>
        <div class="card reveal reveal-d3">
          <h3 class="card-title">Open the terminal</h3>
          <p class="card-text">Run Claude Code in your project folder. The AI reads your files, understands your intent, and starts building.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================
       02 — PROJECT INTELLIGENCE
       ======================================== -->
  <section>
    <div class="container">
      <div class="section-label reveal">02</div>
      <h2 class="section-title reveal reveal-d1">Teach the AI your project</h2>
      <div class="card-grid-2x2">
        <div class="card reveal reveal-d1">
          <span class="card-code">CLAUDE.md</span>
          <h3 class="card-title">The main briefing</h3>
          <p class="card-text">Rules, structure, tone, what is locked, what is open. The single source of truth for every conversation.</p>
        </div>
        <div class="card reveal reveal-d2">
          <span class="card-code">SKILL.md</span>
          <h3 class="card-title">Deep context</h3>
          <p class="card-text">Strategy, audience, evidence, assets. Everything the AI needs to make informed decisions about your project.</p>
        </div>
        <div class="card reveal reveal-d3">
          <h3 class="card-title">Memory System</h3>
          <p class="card-text">Persistent files that help the AI remember across conversations. User preferences, feedback, project state.</p>
        </div>
        <div class="card reveal reveal-d4">
          <h3 class="card-title">Agents</h3>
          <p class="card-text">Specialized sub-agents for different tasks. Visual design, build, motion, quality review. Each with its own tools and focus.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================
       03 — THE WORKFLOW
       ======================================== -->
  <section>
    <div class="container">
      <div class="section-label reveal">03</div>
      <h2 class="section-title reveal reveal-d1">Build, preview, iterate, ship</h2>
      <div class="timeline">
        <div class="timeline-step reveal reveal-d1">
          <div class="step-number">1</div>
          <h3 class="step-title">Describe your vision</h3>
          <p class="step-text">Tell the AI what you want. Be specific about the feeling, not just the features.</p>
        </div>
        <div class="timeline-step reveal reveal-d2">
          <div class="step-number">2</div>
          <h3 class="step-title">Watch it build</h3>
          <p class="step-text">Open a local preview. The AI writes HTML, CSS, JS in real time. You see every change instantly.</p>
        </div>
        <div class="timeline-step reveal reveal-d3">
          <div class="step-number">3</div>
          <h3 class="step-title">Guide with feedback</h3>
          <p class="step-text">Screenshot what you see. Say what to fix. The AI reads your files before every edit.</p>
        </div>
        <div class="timeline-step reveal reveal-d4">
          <div class="step-number">4</div>
          <h3 class="step-title">Commit and push</h3>
          <p class="step-text">The AI commits to GitHub with clear messages. Push triggers automatic deployment to Vercel.</p>
        </div>
        <div class="timeline-step reveal reveal-d5">
          <div class="step-number">5</div>
          <h3 class="step-title">Live in minutes</h3>
          <p class="step-text">Your site is live. Custom domain, SSL, CDN. From idea to production in one session.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================
       04 — AGENT ORCHESTRATION
       ======================================== -->
  <section>
    <div class="container">
      <div class="section-label reveal">04</div>
      <h2 class="section-title reveal reveal-d1">Multiple agents, one vision</h2>
      <p class="section-description reveal reveal-d2">Complex projects use specialized agents working in parallel. A build agent writes code while a visual designer reviews composition. A motion engineer handles animations while a quality reviewer checks everything.</p>
      <div class="card-grid-3">
        <div class="card reveal reveal-d2">
          <h3 class="card-title">Parallel execution</h3>
          <p class="card-text">Launch multiple agents at once for independent tasks. They work simultaneously without blocking each other.</p>
        </div>
        <div class="card reveal reveal-d3">
          <h3 class="card-title">Specialized roles</h3>
          <p class="card-text">Each agent has its own tools and expertise. Build, design, motion, quality. Focus creates better output.</p>
        </div>
        <div class="card reveal reveal-d4">
          <h3 class="card-title">Shared context</h3>
          <p class="card-text">All agents read the same project files and follow the same rules. Consistency without coordination overhead.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================
       05 — REAL PROJECTS
       ======================================== -->
  <section>
    <div class="container">
      <div class="section-label reveal">05</div>
      <h2 class="section-title reveal reveal-d1">Everything on this site was built this way</h2>
      <div class="card-grid-3">
        <a href="/journey-teams" class="card reveal reveal-d1" style="display: block;">
          <h3 class="card-title">Journey Teams</h3>
          <p class="card-text">A 14-slide scroll presentation for IKEA Digital Sharing Days. Built in one session with constellation animations, photo galleries, and live data.</p>
          <span class="card-link">
            View project
            <svg class="card-link-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
        <div class="card reveal reveal-d2">
          <h3 class="card-title">This Portfolio</h3>
          <p class="card-text">The site you are on right now. Astro, multi-language, AI-generated content, deployed on Vercel.</p>
        </div>
        <a href="/ai-projects" class="card reveal reveal-d3" style="display: block;">
          <h3 class="card-title">More projects</h3>
          <p class="card-text">AI Project Brain Lab, La Mami, and more. All built with the same method.</p>
          <span class="card-link">
            Explore all
            <svg class="card-link-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ========================================
       CTA
       ======================================== -->
  <section class="cta-section">
    <div class="container">
      <h2 class="cta-title reveal">Want to build like this?</h2>
      <p class="cta-subtitle reveal reveal-d1">The method is simple. The results speak for themselves.</p>
      <div class="cta-buttons reveal reveal-d2">
        <a href="/ai-projects" class="btn-primary">
          See my AI projects
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/" class="btn-secondary">Get in touch</a>
      </div>
    </div>
  </section>

  <!-- ========================================
       FOOTER
       ======================================== -->
  <footer class="footer">
    <div class="container">
      <p class="footer-text">Built with AI by <a href="/">Pablo Suzarte</a></p>
    </div>
  </footer>

  <script is:inline>
    /* ========================================
       INTERSECTION OBSERVER — ENTRANCE ANIMATIONS
       ======================================== */
    (function () {
      const revealElements = document.querySelectorAll('.reveal');

      if (!revealElements.length) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.15,
          rootMargin: '0px 0px -40px 0px',
        }
      );

      revealElements.forEach((el) => observer.observe(el));
    })();
  </script>

</body>
</html>
