---
import Layout from '../layouts/Layout.astro'
import type { T, Locale } from '../i18n/translations'
import { posts } from '../data/blog'

interface Props {
  t: T
  lang: Locale
}

const { t, lang } = Astro.props

const langLinks = [
  { code: 'en', label: 'EN', href: '/' },
  { code: 'sv', label: 'SV', href: '/sv/' },
  { code: 'es', label: 'ES', href: '/es/' },
]

const randomStyles = ['brutalist', 'neon', 'vaporwave', 'paper', 'ocean']
---

<Layout title={t.meta.title} description={t.meta.description} lang={lang}>
  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <a href="#hero" class="nav-logo">PS</a>
      <ul class="nav-links">
        <li><a href="#about"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 0 0-16 0"/></svg>{t.nav.about}</a></li>
        <li><a href="/me-and-ai"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>Me &amp; AI</a></li>
        <li><a href="#experience"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>{t.nav.experience}</a></li>
        <li><a href="#skills"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>{t.nav.skills}</a></li>
        <li><a href="#writing"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.85 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>{t.nav.writing}</a></li>
        <li><a href="#contact"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>{t.nav.contact}</a></li>
      </ul>
      <div class="nav-controls">
        <button
          type="button"
          class="a11y-nav-btn"
          id="a11yNavTrigger"
          aria-label="Accessibility settings"
          aria-expanded="false"
          aria-controls="a11yPanel"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="4.5" r="2.5"/>
            <path d="m4.5 9 3-1h9l3 1"/>
            <path d="m7.5 8 1 8.5 3.5 4"/>
            <path d="m16.5 8-1 8.5-3.5 4"/>
          </svg>
        </button>
        <button
          type="button"
          class="style-toggle danger-btn"
          data-action="danger"
          aria-label="Do not press"
        >
          <span>Do not Press!</span>
        </button>
        <button
          type="button"
          class="style-toggle reset-btn"
          data-action="reset"
          aria-label="Reset style"
          style="display:none"
        >
          <span>Reset</span>
        </button>
        <button
          type="button"
          class="menu-btn"
          id="menuBtn"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobileMenu"
        >
          <span class="menu-btn-bar"></span>
          <span class="menu-btn-bar"></span>
          <span class="menu-btn-bar"></span>
        </button>
      </div>
    </div>
  </nav>

  <!-- MOBILE MENU -->
  <div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Navigation menu" aria-hidden="true">
    <div class="mobile-menu-inner">
      <ul class="mobile-nav-links">
        <li><a href="#about"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 0 0-16 0"/></svg>{t.nav.about}</a></li>
        <li><a href="/me-and-ai"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>Me &amp; AI</a></li>
        <li><a href="#experience"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>{t.nav.experience}</a></li>
        <li><a href="#skills"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>{t.nav.skills}</a></li>
        <li><a href="#writing"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.85 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>{t.nav.writing}</a></li>
        <li><a href="#contact"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>{t.nav.contact}</a></li>
      </ul>
      <hr class="mobile-menu-divider" />
      <div class="mobile-menu-extras">
        <button type="button" class="mobile-menu-btn" data-action="danger">
          <span>Do not Press!</span>
        </button>
        <button type="button" class="mobile-menu-btn mobile-menu-btn--reset" data-action="reset" style="display:none">
          <span>Reset</span>
        </button>
      </div>
      <hr class="mobile-menu-divider" />
      <div class="mobile-lang-switcher">
        {
          langLinks.map((l) => (
            <a
              href={l.href}
              class:list={['mobile-lang-link', { 'mobile-lang-link--active': l.code === lang }]}
            >
              {l.label}
            </a>
          ))
        }
      </div>
      <hr class="mobile-menu-divider" />
      <button type="button" class="mobile-menu-btn" id="mobileA11yBtn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="4.5" r="2.5"/>
          <path d="m4.5 9 3-1h9l3 1"/>
          <path d="m7.5 8 1 8.5 3.5 4"/>
          <path d="m16.5 8-1 8.5-3.5 4"/>
        </svg>
        <span>Accessibility settings</span>
      </button>
    </div>
  </div>
  <div class="mobile-menu-backdrop" id="mobileMenuBackdrop" aria-hidden="true"></div>

  <!-- ACCESSIBILITY SETTINGS -->
  <div
    class="a11y-panel"
    id="a11yPanel"
    role="dialog"
    aria-label="Accessibility settings"
    aria-hidden="true"
  >
    <div class="a11y-panel-header">
      <h2 class="a11y-panel-title">Accessibility</h2>
      <button type="button" class="a11y-close" id="a11yClose" aria-label="Close accessibility settings">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <p class="a11y-panel-intro">This site is an ongoing accessibility experiment. These controls let you adapt the experience to your needs.</p>

    <div class="a11y-controls">
      <!-- Font Size -->
      <div class="a11y-control">
        <div class="a11y-control-label">
          <span class="a11y-control-title">Text size</span>
          <span class="a11y-control-desc">Increase font size across the site</span>
        </div>
        <div class="a11y-font-buttons" role="radiogroup" aria-label="Text size">
          <button type="button" class="a11y-font-btn" data-font="default" aria-pressed="true">A</button>
          <button type="button" class="a11y-font-btn" data-font="large" aria-pressed="false"><span style="font-size:1.15em">A</span></button>
          <button type="button" class="a11y-font-btn" data-font="xl" aria-pressed="false"><span style="font-size:1.35em">A</span></button>
        </div>
      </div>

      <!-- Static Mode -->
      <div class="a11y-control">
        <div class="a11y-control-label">
          <span class="a11y-control-title">Static mode</span>
          <span class="a11y-control-desc">Stop all animations and transitions</span>
        </div>
        <button
          type="button"
          class="a11y-toggle"
          id="a11yStaticToggle"
          role="switch"
          aria-checked="false"
          aria-label="Static mode"
        >
          <span class="a11y-toggle-track">
            <span class="a11y-toggle-thumb"></span>
          </span>
        </button>
      </div>
    </div>

    <div class="a11y-standards">
      <h3 class="a11y-standards-title">Standards</h3>
      <ul class="a11y-standards-list">
        <li><strong>WCAG 2.2 AA</strong> — target compliance level</li>
        <li><strong>Semantic HTML</strong> — heading hierarchy, landmarks, ARIA where needed</li>
        <li><strong>Keyboard navigable</strong> — all interactive elements accessible via keyboard</li>
        <li><strong>Motion safe</strong> — respects <code>prefers-reduced-motion</code> + manual toggle</li>
        <li><strong>Scalable text</strong> — content reflows at increased font sizes</li>
        <li><strong>Colour contrast</strong> — minimum 4.5:1 for body text (WCAG AA)</li>
      </ul>
      <p class="a11y-standards-note">Found an issue? <a href="mailto:pablosu@gmail.com">Let me know</a> — accessibility is a practice, not a checkbox.</p>
    </div>
  </div>
  <div class="a11y-backdrop" id="a11yBackdrop" aria-hidden="true"></div>

  <!-- HERO -->
  <section id="hero" class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <div class="hero-left">
        <p class="hero-eyebrow">{t.hero.eyebrow}</p>
        <h1 class="hero-name">Pablo Suzarte</h1>
        <h2 class="hero-title">
          {
            t.hero.title.split('\n').map((line, i) => (
              <>
                {line}
                {i === 0 && <br />}
              </>
            ))
          }
        </h2>
        <p class="hero-support">{t.hero.tagline}</p>
        <div class="hero-ctas">
          <a href="/me-and-ai" class="btn-primary">{t.hero.cta1}</a>
          <a
            href="https://www.linkedin.com/in/pablosuzarte/"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary"
          >
            {t.hero.cta2}
          </a>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-photo-wrap">
          <img src="/pablo_profile_photo.png" alt="Pablo Suzarte" class="hero-photo" loading="eager" />
        </div>
      </div>
    </div>
    <div class="scroll-hint">
      <span>{t.hero.scroll}</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="section">
    <div class="container section-grid">
      <div class="section-label">
        <span class="label-num">{t.about.label}</span>
        <h2 class="section-title">{t.about.title}</h2>
        <div class="accent-line"></div>
      </div>
      <div class="section-body">
        <p>{t.about.p1}</p>
        <p>{t.about.p2}</p>
        <p>{t.about.p3}</p>
        <div class="about-badges">
          <div class="badge">
            <span class="badge-num">{t.about.badge1Num}</span>
            <span class="badge-label">{t.about.badge1Label}</span>
          </div>
          <div class="badge">
            <span class="badge-num">{t.about.badge2Num}</span>
            <span class="badge-label">{t.about.badge2Label}</span>
          </div>
          <div class="badge">
            <span class="badge-num">{t.about.badge3Num}</span>
            <span class="badge-label">{t.about.badge3Label}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ME & AI SUMMARY -->
  <section id="me-ai" class="section section-alt">
    <div class="container section-grid">
      <div class="section-label">
        <span class="label-num">02</span>
        <h2 class="section-title">Me &amp; AI</h2>
        <div class="accent-line"></div>
      </div>
      <div class="section-body">
        <p>Most people prompt a chatbot. I orchestrate agents to handle complex, multi-step tasks. The difference is not the tool. It is the environment you design around it.</p>

        <div class="me-ai-highlights">
          <div class="me-ai-highlight">
            <span class="me-ai-highlight__num">8</span>
            <span class="me-ai-highlight__label">Project Intelligence Principles that guide every collaboration</span>
          </div>
          <div class="me-ai-highlight">
            <span class="me-ai-highlight__num">3</span>
            <span class="me-ai-highlight__label">Live products built solo with AI as the only collaborator</span>
          </div>
          <div class="me-ai-highlight">
            <span class="me-ai-highlight__num">1</span>
            <span class="me-ai-highlight__label">Hands-on workshop teaching teams to go from prompting to orchestrating</span>
          </div>
        </div>

        <div class="me-ai-tools">
          <p class="me-ai-tools__label">I orchestrate with</p>
          <div class="me-ai-tools__icons">
            <div class="me-ai-tool" title="Claude &amp; Claude Code">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="var(--accent)" aria-hidden="true">
                <path d="m4.7144 15.9555 4.7174-2.6471.079-.2307-.079-.1275h-.2307l-.7893-.0486-2.6956-.0729-2.3375-.0971-2.2646-.1214-.5707-.1215-.5343-.7042.0546-.3522.4797-.3218.686.0608 1.5179.1032 2.2767.1578 1.6514.0972 2.4468.255h.3886l.0546-.1579-.1336-.0971-.1032-.0972L6.973 9.8356l-2.55-1.6879-1.3356-.9714-.7225-.4918-.3643-.4614-.1578-1.0078.6557-.7225.8803.0607.2246.0607.8925.686 1.9064 1.4754 2.4893 1.8336.3643.3035.1457-.1032.0182-.0728-.164-.2733-1.3539-2.4467-1.445-2.4893-.6435-1.032-.17-.6194c-.0607-.255-.1032-.4674-.1032-.7285L6.287.1335 6.6997 0l.9957.1336.419.3642.6192 1.4147 1.0018 2.2282 1.5543 3.0296.4553.8985.2429.8318.091.255h.1579v-.1457l.1275-1.706.2368-2.0947.2307-2.6957.0789-.7589.3764-.9107.7468-.4918.5828.2793.4797.686-.0668.4433-.2853 1.8517-.5586 2.9021-.3643 1.9429h.2125l.2429-.2429.9835-1.3053 1.6514-2.0643.7286-.8196.85-.9046.5464-.4311h1.0321l.759 1.1293-.34 1.1657-1.0625 1.3478-.8804 1.1414-1.2628 1.7-.7893 1.36.0729.1093.1882-.0183 2.8535-.607 1.5421-.2794 1.8396-.3157.8318.3886.091.3946-.3278.8075-1.967.4857-2.3072.4614-3.4364.8136-.0425.0304.0486.0607 1.5482.1457.6618.0364h1.621l3.0175.2247.7892.522.4736.6376-.079.4857-1.2142.6193-1.6393-.3886-3.825-.9107-1.3113-.3279h-.1822v.1093l1.0929 1.0686 2.0035 1.8092 2.5075 2.3314.1275.5768-.3218.4554-.34-.0486-2.2039-1.6575-.85-.7468-1.9246-1.621h-.1275v.17l.4432.6496 2.3436 3.5214.1214 1.0807-.17.3521-.6071.2125-.6679-.1214-1.3721-1.9246L14.38 17.959l-1.1414-1.9428-.1397.079-.674 7.2552-.3156.3703-.7286.2793-.6071-.4614-.3218-.7468.3218-1.4753.3886-1.9246.3157-1.53.2853-1.9004.17-.6314-.0121-.0425-.1397.0182-1.4328 1.9672-2.1796 2.9446-1.7243 1.8456-.4128.164-.7164-.3704.0667-.6618.4008-.5889 2.386-3.0357 1.4389-1.882.929-1.0868-.0062-.1579h-.0546l-6.3385 4.1164-1.1293.1457-.4857-.4554.0608-.7467.2307-.2429 1.9064-1.3114Z"/>
              </svg>
              <span>Claude</span>
            </div>
            <div class="me-ai-tool" title="ChatGPT &amp; Codex">
              <svg viewBox="0 0 256 260" width="28" height="28" fill="currentColor" aria-hidden="true">
                <path d="M239.184 106.203a64.716 64.716 0 0 0-5.576-53.103C219.452 28.459 191 15.784 163.213 21.74A65.586 65.586 0 0 0 52.096 45.22a64.716 64.716 0 0 0-43.23 31.36 65.586 65.586 0 0 0 8.031 76.74 64.716 64.716 0 0 0 5.525 53.102c14.174 24.65 42.644 37.324 70.446 31.36a65.586 65.586 0 0 0 111.117-23.56 64.716 64.716 0 0 0 43.23-31.36 65.586 65.586 0 0 0-8.031-76.66Zm-97.56 136.338a48.397 48.397 0 0 1-31.105-11.255l1.535-.87 51.67-29.825a8.595 8.595 0 0 0 4.247-7.367v-72.85l21.845 12.636c.218.111.37.32.409.563v60.367c-.056 26.818-21.783 48.545-48.601 48.6ZM37.158 197.93a48.345 48.345 0 0 1-5.781-32.589l1.534.921 51.722 29.826a8.339 8.339 0 0 0 8.441 0l63.181-36.425v25.221a.717.717 0 0 1-.358.665l-52.335 30.184c-23.257 13.398-52.97 5.431-66.404-17.803ZM23.549 85.38a48.499 48.499 0 0 1 25.58-21.333v59.39a8.288 8.288 0 0 0 4.195 7.316l62.874 36.272-21.845 12.636a.718.718 0 0 1-.767 0L41.353 149.48c-23.211-13.454-31.171-43.144-17.804-64.1Zm180.465 41.695-63.08-36.63L162.78 77.81a.718.718 0 0 1 .768 0l52.233 30.184a48.652 48.652 0 0 1-7.316 87.635v-61.391a8.544 8.544 0 0 0-4.45-7.862Zm21.742-32.69-1.535-.922-51.619-30.081a8.39 8.39 0 0 0-8.492 0L100.981 99.64V74.42a.716.716 0 0 1 .307-.665l52.233-30.133a48.652 48.652 0 0 1 72.236 50.391v.372ZM88.061 139.098l-21.845-12.585a.716.716 0 0 1-.358-.665V65.685a48.652 48.652 0 0 1 79.757-37.346l-1.535.87-51.67 29.825a8.595 8.595 0 0 0-4.246 7.367l-.103 72.697Zm11.868-25.58L128.067 97.3l28.188 16.218v32.434l-28.086 16.218-28.24-16.218v-32.434Z"/>
              </svg>
              <span>ChatGPT</span>
            </div>
            <div class="me-ai-tool" title="Gemini">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="url(#gemGradHome)" aria-hidden="true">
                <path d="M11.04 19.32Q12 21.51 12 24q0-2.49.93-4.68.96-2.19 2.58-3.81t3.81-2.55Q21.51 12 24 12q-2.49 0-4.68-.93a12.3 12.3 0 0 1-3.81-2.58 12.3 12.3 0 0 1-2.58-3.81Q12 2.49 12 0q0 2.49-.96 4.68-.93 2.19-2.55 3.81a12.3 12.3 0 0 1-3.81 2.58Q2.49 12 0 12q2.49 0 4.68.96 2.19.93 3.81 2.55t2.55 3.81"/>
                <defs><linearGradient id="gemGradHome" x1="0" y1="0" x2="24" y2="24"><stop stop-color="#4285F4"/><stop offset=".5" stop-color="#886FBF"/><stop offset="1" stop-color="#D96570"/></linearGradient></defs>
              </svg>
              <span>Gemini</span>
            </div>
            <div class="me-ai-tool" title="GitHub Copilot">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true">
