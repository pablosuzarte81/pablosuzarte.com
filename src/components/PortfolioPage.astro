  <script is:inline>
    (() => {
      // ── STYLE RANDOMISER (supports multiple button instances) ──
      const root = document.documentElement
      const storageKey = 'pablo-site-style'
      const styles = ['brutalist', 'neon', 'vaporwave', 'paper', 'ocean', 'barbie', 'hacker', 'sunset', 'retro', 'inverted', 'ikea', 'win95', 'spotify', 'netflix', 'terminal']
      const dangerBtns = document.querySelectorAll('[data-action="danger"]')
      const resetBtns = document.querySelectorAll('[data-action="reset"]')

      function setStyle(name) {
        root.removeAttribute('data-style')
        if (name && name !== 'default') {
          root.setAttribute('data-style', name)
          resetBtns.forEach(b => b.style.display = '')
          dangerBtns.forEach(b => { const s = b.querySelector('span'); if (s) s.textContent = 'Again!' })
        } else {
          resetBtns.forEach(b => b.style.display = 'none')
          dangerBtns.forEach(b => { const s = b.querySelector('span'); if (s) s.textContent = 'Do not Press!' })
        }
        localStorage.setItem(storageKey, name || 'default')
      }

      const saved = localStorage.getItem(storageKey)
      if (saved && saved !== 'default') setStyle(saved)

      dangerBtns.forEach(btn => btn.addEventListener('click', () => {
        const current = root.getAttribute('data-style') || ''
        const available = styles.filter(s => s !== current)
        setStyle(available[Math.floor(Math.random() * available.length)])
      }))
      resetBtns.forEach(btn => btn.addEventListener('click', () => setStyle('default')))

      // ── MOBILE MENU ──
      const menuBtn = document.getElementById('menuBtn')
      const mobileMenu = document.getElementById('mobileMenu')
      const menuBackdrop = document.getElementById('mobileMenuBackdrop')
      const mobileA11yBtn = document.getElementById('mobileA11yBtn')
      if (!menuBtn || !mobileMenu) return

      const mobileLinks = mobileMenu.querySelectorAll('.mobile-nav-links a')
      const focusableEls = mobileMenu.querySelectorAll('a, button:not([style*="display:none"])')

      function openMenu() {
        mobileMenu.classList.add('is-open')
        mobileMenu.setAttribute('aria-hidden', 'false')
        menuBackdrop.classList.add('is-open')
        menuBtn.setAttribute('aria-expanded', 'true')
        document.body.style.overflow = 'hidden'
        if (mobileLinks[0]) mobileLinks[0].focus()
      }

      function closeMenu() {
        mobileMenu.classList.remove('is-open')
        mobileMenu.setAttribute('aria-hidden', 'true')
        menuBackdrop.classList.remove('is-open')
        menuBtn.setAttribute('aria-expanded', 'false')
        document.body.style.overflow = ''
        menuBtn.focus()
      }

      menuBtn.addEventListener('click', () => {
        mobileMenu.classList.contains('is-open') ? closeMenu() : openMenu()
      })
      menuBackdrop.addEventListener('click', closeMenu)

      // Close on link click + smooth scroll
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          closeMenu()
        })
      })

      // Mobile a11y button → close menu, then open a11y panel
      if (mobileA11yBtn) {
        mobileA11yBtn.addEventListener('click', () => {
          closeMenu()
          setTimeout(() => {
            const a11yTrigger = document.getElementById('a11yNavTrigger')
            if (a11yTrigger) a11yTrigger.click()
          }, 100)
        })
      }

      // Escape to close
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileMenu.classList.contains('is-open')) closeMenu()
      })

      // Focus trap
      mobileMenu.addEventListener('keydown', (e) => {
        if (e.key !== 'Tab') return
        const focusable = [...mobileMenu.querySelectorAll('a, button:not([style*="display:none"])')]
        if (!focusable.length) return
        const first = focusable[0]
        const last = focusable[focusable.length - 1]
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault(); last.focus()
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault(); first.focus()
        }
      })

      // Sync active state on mobile nav links
      const navObserver = new MutationObserver(() => {
        const activeDesktop = document.querySelector('.nav-links a[data-active]')
        if (!activeDesktop) return
        const activeHref = activeDesktop.getAttribute('href')
        mobileLinks.forEach(link => {
          if (link.getAttribute('href') === activeHref) {
            link.setAttribute('data-active', '')
          } else {
            link.removeAttribute('data-active')
          }
        })
      })
      document.querySelectorAll('.nav-links a').forEach(a => {
        navObserver.observe(a, { attributes: true, attributeFilter: ['data-active'] })
      })
    })()
  </script>

  <script is:inline>
    (() => {
      // ── ACCESSIBILITY PANEL ──
      const root = document.documentElement
      const trigger = document.getElementById('a11yNavTrigger')
      const panel = document.getElementById('a11yPanel')
      const backdrop = document.getElementById('a11yBackdrop')
      const closeBtn = document.getElementById('a11yClose')
      if (!trigger || !panel) return

      function openPanel() {
        panel.classList.add('is-open')
        panel.setAttribute('aria-hidden', 'false')
        backdrop.classList.add('is-open')
        trigger.setAttribute('aria-expanded', 'true')
        closeBtn.focus()
      }

      function closePanel() {
        panel.classList.remove('is-open')
        panel.setAttribute('aria-hidden', 'true')
        backdrop.classList.remove('is-open')
        trigger.setAttribute('aria-expanded', 'false')
        trigger.focus()
      }

      trigger.addEventListener('click', openPanel)
      closeBtn.addEventListener('click', closePanel)
      backdrop.addEventListener('click', closePanel)
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && panel.classList.contains('is-open')) closePanel()
      })

      // ── Font size control ──
      const fontKey = 'pablo-a11y-font'
      const fontBtns = panel.querySelectorAll('.a11y-font-btn')

      function setFont(size) {
        root.removeAttribute('data-font')
        if (size === 'large') root.setAttribute('data-font', 'large')
        if (size === 'xl') root.setAttribute('data-font', 'xl')
        fontBtns.forEach(btn => {
          btn.setAttribute('aria-pressed', btn.dataset.font === size ? 'true' : 'false')
        })
        localStorage.setItem(fontKey, size)
      }

      setFont(localStorage.getItem(fontKey) || 'default')
      fontBtns.forEach(btn => {
        btn.addEventListener('click', () => setFont(btn.dataset.font))
      })

      // ── Static mode ──
      const staticKey = 'pablo-a11y-static'
      const staticToggle = document.getElementById('a11yStaticToggle')

      function setStatic(on) {
        if (on) {
          root.setAttribute('data-static', '')
          staticToggle.setAttribute('aria-checked', 'true')
        } else {
          root.removeAttribute('data-static')
          staticToggle.setAttribute('aria-checked', 'false')
        }
        localStorage.setItem(staticKey, on ? 'true' : 'false')
      }

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      const storedStatic = localStorage.getItem(staticKey)
      setStatic(storedStatic ? storedStatic === 'true' : prefersReduced)

      staticToggle.addEventListener('click', () => {
        const next = staticToggle.getAttribute('aria-checked') !== 'true'
        setStatic(next)
      })
    })()
  </script>

  <script is:inline>
    (() => {
      // ── NAV: scroll-triggered background opacity + active section ──
      const nav = document.querySelector('nav')
      const navLinks = document.querySelectorAll('.nav-links a[href^="#"]')

      // Nav scroll state
      if (nav) {
        const updateNav = () => {
          if (window.scrollY > 40) {
            nav.setAttribute('data-scrolled', '')
          } else {
            nav.removeAttribute('data-scrolled')
          }
        }
        updateNav()
        window.addEventListener('scroll', updateNav, { passive: true })
      }

      // Active nav link via IntersectionObserver
      const sections = document.querySelectorAll('section[id]')
      if (sections.length && navLinks.length) {
        const sectionMap = {}
        sections.forEach((s) => { sectionMap[s.id] = s })

        const setActive = (id) => {
          navLinks.forEach((a) => {
            const href = a.getAttribute('href')
            if (href === '#' + id) {
              a.setAttribute('data-active', '')
            } else {
              a.removeAttribute('data-active')
            }
          })
        }

        // Use IntersectionObserver with a generous rootMargin so the
        // active link updates while the section is in the middle of the viewport
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                setActive(entry.target.id)
              }
            })
          },
          { rootMargin: '-20% 0px -60% 0px', threshold: 0 }
        )

        sections.forEach((s) => observer.observe(s))
      }

      // ── SECTION REVEAL: fade + slide up on scroll entry ──
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      if (!prefersReduced) {
        const revealEls = document.querySelectorAll(
          '.section-label, .section-body, .timeline-item, .skills-card, .badge, .project-card, .writing-card, .toolkit-card, .principle-card, .parallel-row, .contact-inner > *'
        )

        revealEls.forEach((el, i) => {
          el.style.opacity = '0'
          el.style.transform = 'translateY(18px)'
          el.style.transition = 'opacity 0.5s ease-out, transform 0.5s ease-out'
        })

        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                // Stagger siblings within the same parent
                const siblings = Array.from(
                  entry.target.parentElement
                    ? entry.target.parentElement.querySelectorAll(
                        ':scope > .timeline-item, :scope > .skills-card, :scope > .badge, :scope > *'
                      )
                    : []
                )
                const index = siblings.indexOf(entry.target)
                const delay = Math.min(index * 60, 300)

                setTimeout(() => {
                  entry.target.style.opacity = '1'
                  entry.target.style.transform = 'translateY(0)'
                }, delay)

                revealObserver.unobserve(entry.target)
              }
            })
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
        )

        revealEls.forEach((el) => revealObserver.observe(el))
      }
    })()
  </script>
</Layout>

