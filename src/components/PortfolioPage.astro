    color: #ff4444;
    background: rgba(255, 60, 60, 0.12);
    transform: translateY(-1px) scale(1.02);
  }

  .reset-btn {
    color: var(--muted);
    border-color: var(--border);
  }

  .reset-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-1px);
  }

  /* ── LANGUAGE SWITCHER ── */
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.2rem 0.25rem;
  }

  .lang-link {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--muted);
    text-decoration: none;
    padding: 0.3rem 0.5rem;
    border-radius: 4px;
    transition:
      color 0.2s,
      background 0.2s;
    min-width: 32px;
    text-align: center;
  }

  .lang-link:hover {
    color: var(--text);
    background: var(--surface-2);
  }

  .lang-link--active {
    color: var(--accent);
    background: var(--surface-2);
  }

  /* ── HAMBURGER BUTTON ── */
  .menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: none;
    background: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
  }
  .menu-btn-bar {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--muted-light);
    border-radius: 1px;
    transition: transform 0.3s ease, opacity 0.3s ease;
    position: absolute;
  }
  .menu-btn-bar:nth-child(1) { transform: translateY(-6px); }
  .menu-btn-bar:nth-child(2) { transform: translateY(0); }
  .menu-btn-bar:nth-child(3) { transform: translateY(6px); }
  .menu-btn { position: relative; }

  .menu-btn[aria-expanded="true"] .menu-btn-bar:nth-child(1) {
    transform: translateY(0) rotate(45deg);
    background: var(--accent);
  }
  .menu-btn[aria-expanded="true"] .menu-btn-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .menu-btn[aria-expanded="true"] .menu-btn-bar:nth-child(3) {
    transform: translateY(0) rotate(-45deg);
    background: var(--accent);
  }

  /* ── MOBILE MENU ── */
  .mobile-menu {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(320px, 85vw);
    z-index: 200;
    background: var(--bg);
    border-left: 1px solid var(--border);
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    overflow-y: auto;
    box-shadow: -8px 0 40px rgba(0, 0, 0, 0.4);
  }
  .mobile-menu.is-open {
    transform: translateX(0);
  }
  .mobile-menu-inner {
    padding: 80px 1.25rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .mobile-nav-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .mobile-nav-links a {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    min-height: 52px;
    padding: 0.75rem 1rem;
    color: var(--text);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    border-left: 3px solid transparent;
    border-radius: 0 8px 8px 0;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .mobile-nav-links .nav-icon {
    width: 18px;
    height: 18px;
    opacity: 0.5;
  }
  .mobile-nav-links a:hover .nav-icon,
  .mobile-nav-links a[data-active] .nav-icon {
    opacity: 1;
  }
  .mobile-nav-links a:hover,
  .mobile-nav-links a:focus-visible {
    background: var(--surface);
    border-left-color: var(--accent);
    color: var(--accent);
  }
  .mobile-nav-links a[data-active] {
    border-left-color: var(--accent);
    color: var(--accent);
    background: var(--surface);
  }
  .mobile-menu-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0.5rem 0;
  }
  .mobile-menu-extras {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .mobile-menu-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 48px;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: transparent;
    color: var(--text);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
    width: 100%;
    text-align: left;
  }
  .mobile-menu-btn:hover,
  .mobile-menu-btn:focus-visible {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--surface);
  }
  .mobile-menu-btn[data-action="danger"] {
    border-color: rgba(255, 60, 60, 0.3);
    color: #ff6b6b;
  }
  .mobile-menu-btn[data-action="danger"]:hover {
    border-color: #ff6b6b;
    color: #ff4444;
    background: rgba(255, 60, 60, 0.06);
  }
  .mobile-menu-btn--reset {
    color: var(--muted);
  }

  .mobile-lang-switcher {
    display: flex;
    gap: 0.5rem;
  }
  .mobile-lang-link {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .mobile-lang-link:hover {
    color: var(--text);
    border-color: var(--text);
  }
  .mobile-lang-link--active {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--surface);
  }

  .mobile-menu-backdrop {
    position: fixed;
    inset: 0;
    z-index: 199;
    background: rgba(0, 0, 0, 0.5);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }
  .mobile-menu-backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── LAYOUT ── */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section {
    padding: 7rem 0;
  }

  .section-alt {
    background: var(--surface);
  }

  .section-grid {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* ── SECTION LABELS ── */
  .section-label {
    position: sticky;
    top: 100px;
  }

  .section-label.centered {
    position: static;
    margin-bottom: 3.5rem;
  }

  .label-num {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .accent-line {
    width: 32px;
    height: 2px;
    background: var(--accent);
    border-radius: 1px;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 80% 60% at 50% 0%,
        rgba(100, 255, 218, 0.04) 0%,
        transparent 70%
      ),
      radial-gradient(
        ellipse 40% 40% at 80% 80%,
        rgba(100, 200, 255, 0.03) 0%,
        transparent 60%
      );
    pointer-events: none;
  }

  .hero-content {
    padding-top: 64px;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4rem;
  }

  .hero-left {
    flex: 1;
  }

  .hero-right {
    flex-shrink: 0;
    animation: fadeIn 0.8s 0.5s ease both;
  }

  .hero-photo-wrap {
    width: 300px;
    height: 300px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 0 40px var(--accent-glow));
  }

  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .hero-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.75rem;
    animation: fadeUp 0.5s ease both;
  }

  .hero-name {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--text) 30%, var(--muted-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
    animation: fadeUp 0.5s 0.08s ease both;
  }

  .hero-title {
    font-size: clamp(1.35rem, 2.8vw, 1.9rem);
    font-weight: 400;
    color: var(--accent);
    line-height: 1.25;
    margin-bottom: 1.75rem;
    animation: fadeUp 0.5s 0.16s ease both;
  }

  .hero-support {
    font-size: 1rem;
    color: var(--muted-light);
    max-width: 480px;
    line-height: 1.6;
    margin-bottom: 2.5rem;
    animation: fadeUp 0.5s 0.24s ease both;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    animation: fadeUp 0.5s 0.32s ease both;
  }

  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--muted);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    animation: fadeIn 1s 1s ease both;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--muted), transparent);
    animation: scrollPulse 2s 1.5s ease-in-out infinite;
  }

  .future-role-hero {
    padding: 0 0 5rem;
  }

  .future-role-panel {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 1.25rem;
    align-items: start;
    margin-bottom: 1.25rem;
  }

  .future-role-copy,
  .future-role-card,
  .future-role-metric {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 10px;
  }

  .future-role-copy {
    padding: 1.75rem;
  }

  .future-role-title {
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin: 0.35rem 0 1rem;
  }

  .future-role-text {
    color: var(--muted-light);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 60ch;
    margin-bottom: 1rem;
  }

  .future-role-stack {
    display: grid;
    gap: 1rem;
  }

  .future-role-card {
    padding: 1.5rem;
  }

  .future-role-card h3 {
    color: var(--text);
    font-size: 1.05rem;
    margin: 0.35rem 0 0.55rem;
  }

  .future-role-card p:last-child {
    color: var(--muted-light);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .future-role-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .future-role-metric {
    padding: 1.1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .future-role-metric strong {
    color: var(--accent);
    font-size: 1.2rem;
    font-weight: 700;
  }

  .future-role-metric span {
    color: var(--muted-light);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  /* ── BUTTONS ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    background: var(--accent);
    color: var(--bg);
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: 6px;
    text-decoration: none;
    transition:
      background 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
    letter-spacing: 0.01em;
  }

  .btn-primary:hover {
    background: #8fffea;
    transform: translateY(-2px);
    box-shadow: 0 10px 32px var(--accent-glow);
  }

  .btn-primary:active {
    transform: translateY(0);
    box-shadow: 0 4px 12px var(--accent-glow);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    border: 1px solid var(--border);
    color: var(--muted-light);
    font-weight: 500;
    font-size: 0.9rem;
    border-radius: 6px;
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(100, 255, 218, 0.1);
  }

  .btn-secondary:active {
    transform: translateY(0);
  }

  .btn-large {
    padding: 1rem 2.5rem;
    font-size: 1rem;
  }

  /* Contact CTA gets a stronger glow at rest — it is the page's primary exit action */
  .contact-section .btn-large {
    box-shadow: 0 0 0 0 var(--accent-glow);
  }

  .contact-section .btn-large:hover {
    box-shadow: 0 12px 40px var(--accent-glow), 0 0 0 1px rgba(100, 255, 218, 0.3);
    transform: translateY(-3px);
  }

  /* ── ABOUT ── */
  .section-body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .section-body p {
    color: var(--muted-light);
    font-size: 1rem;
  }

  .about-badges {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .badge {
    display: flex;
    flex-direction: column;
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    min-width: 100px;
  }

  .badge-num {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .badge-label {
    font-size: 0.75rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ── TIMELINE ── */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 1.5rem;
    padding-bottom: 3rem;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 0.35rem;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    box-shadow: 0 0 0 3px var(--accent-dim);
  }

  .timeline-line {
    width: 1px;
    flex: 1;
    background: var(--border);
    margin-top: 0.5rem;
  }

  .timeline-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
  }

  .timeline-card:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2), 0 0 16px var(--accent-glow);
    transform: translateX(4px);
  }

  /* Dot brightens when its card is hovered — uses sibling combinator via the item wrapper */
  .timeline-item:hover .timeline-dot {
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-dim), 0 0 10px var(--accent-glow);
    transition:
      box-shadow 0.25s ease,
      background 0.25s ease;
  }

  .timeline-dot {
    transition:
      box-shadow 0.25s ease,
      background 0.25s ease;
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .job-company {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.2rem;
  }

  .job-role {
    font-size: 0.875rem;
    color: var(--accent);
    font-weight: 500;
  }

  .job-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
  }

  .job-period {
    font-size: 0.8rem;
    color: var(--muted-light);
    white-space: nowrap;
  }

  .job-location {
    font-size: 0.75rem;
    color: var(--muted);
  }

  .job-highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .job-highlights li {
    font-size: 0.875rem;
    color: var(--muted-light);
    padding-left: 1rem;
    position: relative;
  }

  .job-highlights li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.7rem;
    top: 0.15em;
  }

  .timeline-link {
    display: inline-flex;
    align-items: center;
    margin-top: 1rem;
    padding: 0.55rem 1.1rem;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent);
    background: rgba(100, 255, 218, 0.06);
    border: 1px solid rgba(100, 255, 218, 0.15);
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }
  .timeline-link:hover {
    background: rgba(100, 255, 218, 0.12);
    border-color: var(--accent);
  }

  /* ── SKILLS ── */
  .skills-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .skills-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .skills-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(255,255,255,0.02) 0%, transparent 50%);
    pointer-events: none;
  }

  .skills-card:hover {
    transform: translateY(-3px);
    border-color: rgba(155,149,178,0.3);
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
  }

  .skills-card--highlight {
    border-color: rgba(217,119,87,0.3);
    background: linear-gradient(135deg, var(--surface) 0%, rgba(217,119,87,0.04) 100%);
  }

  .skills-card--highlight::before {
    background: linear-gradient(135deg, rgba(217,119,87,0.03) 0%, transparent 60%);
  }

  .skills-card--highlight:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 32px rgba(217,119,87,0.1), 0 4px 16px rgba(0,0,0,0.2);
  }

  .skills-card__header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .skills-card__number {
    font-size: 0.7rem;
    font-weight: 700;
    font-family: var(--font-sans, 'Manrope', sans-serif);
    color: var(--muted);
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  .skills-card--highlight .skills-card__number {
    color: var(--accent);
  }

  .skills-card__title {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text);
    margin: 0;
  }

  .skills-card--highlight .skills-card__title {
    color: var(--accent);
  }

  .skills-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .skills-card__item {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(155,149,178,0.06);
    font-size: 0.85rem;
    color: var(--muted-light);
    transition: color 0.2s ease;
  }

  .skills-card__item:last-child {
    border-bottom: none;
  }

  .skills-card:hover .skills-card__item {
    color: var(--text);
  }

  .skills-card__dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--muted);
    flex-shrink: 0;
    transition: background 0.2s ease;
  }

  .skills-card--highlight .skills-card__dot {
    background: var(--accent);
    opacity: 0.6;
  }

  .skills-card:hover .skills-card__dot {
    background: var(--accent);
    opacity: 1;
  }

  /* ── EDUCATION ── */
  .edu-certs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .edu-block h3 {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 1rem;
  }

  .edu-item {
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .edu-item:last-child {
    border-bottom: none;
  }

  .edu-school {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }

  .edu-degree {
    font-size: 0.8rem;
    color: var(--muted-light);
  }

  .edu-year {
    font-size: 0.75rem;
    color: var(--muted);
  }

  /* ── WORK ── */
  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .work-grid--single {
    grid-template-columns: 1fr;
    max-width: 680px;
    margin: 0 auto;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    transition:
      border-color 0.3s ease,
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.3),
      0 0 0 1px var(--accent-dim),
      0 0 24px var(--accent-glow);
  }

  .project-card-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--surface);
  }

  .project-card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--surface-2) 0%, var(--bg) 100%);
    padding: 2rem;
  }

  .project-card-placeholder-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--accent);
    text-align: center;
    opacity: 0.6;
    letter-spacing: 0.02em;
  }

  .project-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .project-card:hover .project-card-img {
    transform: scale(1.04);
  }

  .project-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .project-card-meta {
    font-size: 0.75rem;
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-card-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
  }

  .project-card-tagline {
    font-size: 0.875rem;
    color: var(--muted-light);
    line-height: 1.6;
  }

  .project-card-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }

  .project-metric-badge {
    font-size: 0.75rem;
    color: var(--muted-light);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.2rem 0.75rem;
  }

  .project-metric-badge strong {
    color: var(--accent);
  }

  .project-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--accent);
    font-weight: 600;
    margin-top: auto;
    padding-top: 0.75rem;
  }

  .cta-arrow {
    display: inline-block;
    transition: transform 0.25s ease;
  }

  .project-card:hover .cta-arrow {
    transform: translateX(5px);
  }

  /* ── AI & EDUCATION — hidden, styles commented out for perf ──
