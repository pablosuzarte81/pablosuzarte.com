  ── end AI & EDUCATION styles */

  /* ── AI MINDSET ── */
  .mindset-intro {
    font-size: 1.15rem;
    line-height: 1.65;
    color: var(--text);
    max-width: 640px;
    margin-bottom: 2.5rem;
  }

  .mindset-block {
    margin-bottom: 3rem;
  }

  .mindset-heading {
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--accent);
    margin-bottom: 1rem;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
  }

  .mindset-body {
    font-size: 1rem;
    line-height: 1.65;
    color: rgba(226, 232, 240, 0.8);
    max-width: 600px;
    margin-bottom: 1.5rem;
  }

  .toolkit-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .toolkit-card {
    padding: 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: border-color 0.2s;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .toolkit-card:hover {
    border-color: rgba(100, 255, 218, 0.25);
  }

  .toolkit-logo {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .toolkit-logo--claude {
    background: rgba(217, 119, 87, 0.1);
    border-color: rgba(217, 119, 87, 0.2);
  }

  .toolkit-logo--openai {
    color: #10a37f;
    background: rgba(16, 163, 127, 0.08);
    border-color: rgba(16, 163, 127, 0.18);
  }

  .toolkit-logo--gemini {
    background: rgba(66, 133, 244, 0.08);
    border-color: rgba(66, 133, 244, 0.18);
  }

  .toolkit-logo--copilot {
    color: #8b949e;
    background: rgba(139, 148, 158, 0.08);
    border-color: rgba(139, 148, 158, 0.18);
  }

  .toolkit-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.3rem;
  }

  .toolkit-use {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.45;
  }

  .principles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.6rem;
  }

  .principle-card {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 1.1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    transition: border-color 0.2s;
  }

  .principle-card:hover {
    border-color: rgba(100, 255, 218, 0.2);
  }

  .principle-num {
    font-size: 0.7rem;
    font-weight: 800;
    color: var(--accent);
    background: rgba(100, 255, 218, 0.08);
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .principle-name {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.2rem;
  }

  .principle-desc {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.45;
  }

  .parallels-grid {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .parallel-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    align-items: center;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
  }

  .parallel-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 0.25rem;
  }

  .parallel-sd p,
  .parallel-pi p {
    font-size: 0.85rem;
    color: rgba(226, 232, 240, 0.8);
    line-height: 1.4;
    margin: 0;
  }

  .parallel-arrow {
    font-size: 1.25rem;
    color: var(--accent);
    opacity: 0.4;
    font-weight: 800;
  }

  .mindset-vision {
    padding: 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    border-left: 3px solid var(--accent);
  }

  .vision-list {
    list-style: none;
    padding: 0;
    margin-bottom: 1.5rem;
  }

  .vision-list li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.6rem;
    font-size: 0.95rem;
    color: rgba(226, 232, 240, 0.85);
    line-height: 1.5;
  }

  .vision-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .vision-list li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.7rem;
    top: 0.15em;
  }

  /* ── WRITING ── */
  .writing-intro {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  .writing-grid {
    display: grid;
    gap: 1.25rem;
  }
  .writing-card {
    display: block;
    text-decoration: none;
    padding: 1.75rem 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    transition: border-color 0.25s, transform 0.25s;
  }
  .writing-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .writing-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }
  .writing-card-tag {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(100, 255, 218, 0.06);
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
  }
  .writing-card-title {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.15;
    margin-bottom: 0.4rem;
  }
  .writing-card-subtitle {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.5;
    margin-bottom: 1rem;
  }
  .writing-card-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
    color: var(--muted);
    margin-bottom: 0.75rem;
  }
  .writing-card-cta {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent);
  }

  /* ── ACCESSIBILITY PANEL ── */
  .a11y-nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .a11y-nav-btn:hover,
  .a11y-nav-btn:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
    background: rgba(100, 255, 218, 0.06);
  }
  .a11y-nav-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .a11y-backdrop {
    position: fixed;
    inset: 0;
    z-index: 299;
    background: rgba(0, 0, 0, 0.5);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }
  .a11y-backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .a11y-panel {
    position: fixed;
    right: -380px;
    top: 0;
    bottom: 0;
    z-index: 300;
    width: 360px;
    max-width: 90vw;
    background: var(--bg);
    border-left: 1px solid var(--border);
    padding: 1.75rem 1.5rem 2rem;
    overflow-y: auto;
    transition: right 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: -8px 0 40px rgba(0, 0, 0, 0.4);
  }
  .a11y-panel.is-open {
    right: 0;
  }

  .a11y-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .a11y-panel-title {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.02em;
  }
  .a11y-close {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 6px;
    transition: color 0.2s;
  }
  .a11y-close:hover,
  .a11y-close:focus-visible {
    color: var(--text);
  }
  .a11y-close:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .a11y-panel-intro {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }

  .a11y-controls {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .a11y-control {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .a11y-control-title {
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text);
  }
  .a11y-control-desc {
    display: block;
    font-size: 0.72rem;
    color: var(--muted);
    margin-top: 0.15rem;
  }

  /* Font size buttons */
  .a11y-font-buttons {
    display: flex;
    gap: 0.35rem;
    flex-shrink: 0;
  }
  .a11y-font-btn {
    width: 38px;
    height: 38px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
  }
  .a11y-font-btn:hover {
    border-color: var(--accent);
    color: var(--text);
  }
  .a11y-font-btn[aria-pressed="true"] {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }
  .a11y-font-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Toggle switch */
  .a11y-toggle {
    flex-shrink: 0;
    background: none;
    border: none;
    cursor: pointer;
    padding: 2px;
    border-radius: 999px;
  }
  .a11y-toggle:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .a11y-toggle-track {
    display: flex;
    align-items: center;
    width: 44px;
    height: 26px;
    border-radius: 13px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: 2px;
    transition: background 0.2s, border-color 0.2s;
    pointer-events: none;
  }
  .a11y-toggle[aria-checked="true"] .a11y-toggle-track {
    background: var(--accent);
    border-color: var(--accent);
  }
  .a11y-toggle-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--muted);
    transition: transform 0.2s, background 0.2s;
  }
  .a11y-toggle[aria-checked="true"] .a11y-toggle-thumb {
    transform: translateX(18px);
    background: var(--bg);
  }

  /* Standards */
  .a11y-standards {
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .a11y-standards-title {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .a11y-standards-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
  }
  .a11y-standards-list li {
    font-size: 0.8rem;
    color: var(--muted-light);
    line-height: 1.5;
    padding: 0.4rem 0;
    border-bottom: 1px solid rgba(148, 163, 184, 0.08);
  }
  .a11y-standards-list li strong {
    color: var(--text);
    font-weight: 700;
  }
  .a11y-standards-list li code {
    font-size: 0.72rem;
    background: var(--surface);
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    color: var(--accent);
  }
  .a11y-standards-note {
    font-size: 0.75rem;
    color: var(--muted);
    line-height: 1.5;
  }
  .a11y-standards-note a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ── CONTACT ── */
  .contact-section {
    background: var(--surface);
    text-align: center;
  }

  .contact-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .contact-heading {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text);
  }

  .contact-sub {
    font-size: 1rem;
    color: var(--muted-light);
    max-width: 440px;
    text-align: center;
  }

  .contact-email-link {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: var(--muted);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
  }

  .contact-email-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

