---
import Layout from '../layouts/Layout.astro'
import type { T, Locale } from '../i18n/translations'
import { projects } from '../data/projects'
import { Image } from 'astro:assets'
import profilePhoto from '../assets/pablo_profile_photo.png'

interface Props {
  t: T
  lang: Locale
}

const { t, lang } = Astro.props

const langLinks = [
  { code: 'en', label: 'EN', href: '/' },
  { code: 'sv', label: 'SV', href: '/sv/' },
  { code: 'es', label: 'ES', href: '/es/' },
]

const styleLabel = {
  en: 'Switch the lens',
  sv: 'Byt perspektiv',
  es: 'Cambiar el lente',
}[lang]
---

<Layout title={t.meta.title} description={t.meta.description} lang={lang}>
  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <a href="#hero" class="nav-logo">PS</a>
      <ul class="nav-links">
        <li><a href="#about">{t.nav.about}</a></li>
        <li><a href="#work">{t.nav.work}</a></li>
        <li><a href="#experience">{t.nav.experience}</a></li>
        <li><a href="#skills">{t.nav.skills}</a></li>
        <li><a href="#contact">{t.nav.contact}</a></li>
        <li><a href="/playground/chat" class="nav-highlight">{t.nav.playground}</a></li>
      </ul>
      <div class="nav-controls">
        <button
          type="button"
          class="style-toggle"
          data-style-toggle
          aria-pressed="false"
          aria-label={styleLabel}
        >
          <span>{styleLabel}</span>
          <strong data-style-toggle-label>Alternate</strong>
        </button>
        <div class="lang-switcher">
          {
            langLinks.map((l) => (
              <a
                href={l.href}
                class:list={['lang-link', { 'lang-link--active': l.code === lang }]}
              >
                {l.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section id="hero" class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <div class="hero-left">
        <p class="hero-greeting">{t.hero.greeting}</p>
        <h1 class="hero-name">Pablo Suzarte</h1>
        <h2 class="hero-title">{t.hero.title}</h2>
        <p class="hero-tagline">
          {
            t.hero.tagline.split('\n').map((line, i) => (
              <>
                {line}
                {i === 0 && <br />}
              </>
            ))
          }
        </p>
        <div class="hero-ctas">
          <a href="#work" class="btn-primary">{t.hero.cta1}</a>
          <a
            href="https://www.linkedin.com/in/pablosuzarte/"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary"
          >
            {t.hero.cta2}
          </a>
        </div>
        <div class="hero-meta">
          <span>{t.hero.location}</span>
          <span>·</span>
          <span>{t.hero.currentRole}</span>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-photo-wrap">
          <Image
            src={profilePhoto}
            alt="Pablo Suzarte"
            class="hero-photo"
            format="webp"
            quality={85}
            loading="eager"
          />
        </div>
      </div>
    </div>
    <div class="scroll-hint">
      <span>{t.hero.scroll}</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="section">
    <div class="container section-grid">
      <div class="section-label">
        <span class="label-num">{t.about.label}</span>
        <h2 class="section-title">{t.about.title}</h2>
        <div class="accent-line"></div>
      </div>
      <div class="section-body">
        <p>{t.about.p1}</p>
        <p>{t.about.p2}</p>
        <p>{t.about.p3}</p>
        <div class="about-badges">
          <div class="badge">
            <span class="badge-num">{t.about.badge1Num}</span>
            <span class="badge-label">{t.about.badge1Label}</span>
          </div>
          <div class="badge">
            <span class="badge-num">{t.about.badge2Num}</span>
            <span class="badge-label">{t.about.badge2Label}</span>
          </div>
          <div class="badge">
            <span class="badge-num">{t.about.badge3Num}</span>
            <span class="badge-label">{t.about.badge3Label}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WORK -->
  <section id="work" class="section section-alt">
    <div class="container">
      <div class="section-label centered">
        <span class="label-num">{t.work.label}</span>
        <h2 class="section-title">{t.work.title}</h2>
        <div class="accent-line"></div>
      </div>
      <div class:list={['work-grid', { 'work-grid--single': projects.filter((p) => p.showInWork !== false).length === 1 }]}>
        {
          projects.filter((p) => p.showInWork !== false).map((project) => (
            <a href={project.workCardUrl ?? `/projects/${project.slug}`} class="project-card">
              <div class="project-card-cover">
                {project.coverImage ? (
                  <img
                    src={project.coverImage}
                    alt={project.title}
                    loading="lazy"
                    class="project-card-img"
                  />
                ) : (
                  <div class="project-card-placeholder">
                    <span class="project-card-placeholder-title">{project.title}</span>
                  </div>
                )}
              </div>
              <div class="project-card-body">
                <p class="project-card-meta">
                  {project.company} · {project.role}
                </p>
                <h3 class="project-card-title">{project.title}</h3>
                <p class="project-card-tagline">{project.tagline}</p>
                <div class="project-card-metrics">
                  {project.heroMetrics.slice(0, 3).map((m) => (
                    <span class="project-metric-badge">
                      <strong>{m.value}</strong> {m.label}
                    </span>
                  ))}
                </div>
                <span class="project-card-cta">{t.work.cta}<span class="cta-arrow" aria-hidden="true">→</span></span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section id="experience" class="section">
    <div class="container">
      <div class="section-label centered">
        <span class="label-num">{t.experience.label}</span>
        <h2 class="section-title">{t.experience.title}</h2>
        <div class="accent-line"></div>
      </div>
      <div class="timeline">
        {
          t.experience.items.map((job, i) => (
            <div class="timeline-item">
              <div class="timeline-marker">
                <div class="timeline-dot" />
                {i < t.experience.items.length - 1 && <div class="timeline-line" />}
              </div>
              <div class="timeline-card">
                <div class="timeline-header">
                  <div>
                    <h3 class="job-company">{job.company}</h3>
                    <p class="job-role">{job.role}</p>
                  </div>
                  <div class="job-meta">
                    <span class="job-period">{job.period}</span>
                    <span class="job-location">{job.location}</span>
                  </div>
                </div>
                <ul class="job-highlights">
                  {job.highlights.map((h) => (
                    <li>{h}</li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- SKILLS -->
  <section id="skills" class="section section-alt">
    <div class="container section-grid">
      <div class="section-label">
        <span class="label-num">{t.skills.label}</span>
        <h2 class="section-title">{t.skills.title}</h2>
        <div class="accent-line"></div>
      </div>
      <div class="section-body">
        <div class="skills-grid">
          {t.skills.items.map((skill) => <span class="skill-pill">{skill}</span>)}
        </div>
        <div class="edu-certs">
          <div class="edu-block">
            <h3>{t.skills.education}</h3>
            <div class="edu-item">
              <p class="edu-school">{t.skills.universityName}</p>
              <p class="edu-degree">{t.skills.universityDegree}</p>
              <p class="edu-year">{t.skills.universityYears}</p>
            </div>
          </div>
          <div class="edu-block">
            <h3>{t.skills.certifications}</h3>
            <div class="edu-item">
              <p class="edu-school">{t.skills.cert1Name}</p>
              <p class="edu-degree">{t.skills.cert1Detail}</p>
            </div>
            <div class="edu-item">
              <p class="edu-school">{t.skills.cert2Name}</p>
              <p class="edu-degree">{t.skills.cert2Detail}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="section contact-section">
    <div class="container contact-inner">
      <span class="label-num">{t.contact.label}</span>
      <h2 class="contact-heading">{t.contact.heading}</h2>
      <p class="contact-sub">
        {
          t.contact.sub.split('\n').map((line, i) => (
            <>
              {line}
              {i === 0 && <br />}
            </>
          ))
        }
      </p>
      <a
        href="https://www.linkedin.com/in/pablosuzarte/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary btn-large"
      >
        {t.contact.cta}
      </a>
      <a href="mailto:pablosu@gmail.com" class="contact-email-link">
        {t.contact.email}
      </a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="container footer-inner">
      <span>{t.footer.copyright}</span>
      <span>{t.footer.built}</span>
    </div>
  </footer>

  <script is:inline>
    (() => {
      const root = document.documentElement
      const toggle = document.querySelector('[data-style-toggle]')
      const label = document.querySelector('[data-style-toggle-label]')
      const storageKey = 'pablo-site-style'

      if (!toggle || !label) return

      const setStyle = (value) => {
        const style = value === 'brutalist' ? 'brutalist' : 'default'

        if (style === 'brutalist') {
          root.setAttribute('data-style', 'brutalist')
          toggle.setAttribute('aria-pressed', 'true')
          label.textContent = 'Modern'
        } else {
          root.removeAttribute('data-style')
          toggle.setAttribute('aria-pressed', 'false')
          label.textContent = 'Alternate'
        }
      }

      setStyle(localStorage.getItem(storageKey) || 'default')

      toggle.addEventListener('click', () => {
        const next = root.getAttribute('data-style') === 'brutalist' ? 'default' : 'brutalist'
        localStorage.setItem(storageKey, next)
        setStyle(next)
      })
    })()
  </script>

  <script is:inline>
    (() => {
      // ── NAV: scroll-triggered background opacity + active section ──
      const nav = document.querySelector('nav')
      const navLinks = document.querySelectorAll('.nav-links a[href^="#"]')

      // Nav scroll state
      if (nav) {
        const updateNav = () => {
          if (window.scrollY > 40) {
            nav.setAttribute('data-scrolled', '')
          } else {
            nav.removeAttribute('data-scrolled')
          }
        }
        updateNav()
        window.addEventListener('scroll', updateNav, { passive: true })
      }

      // Active nav link via IntersectionObserver
      const sections = document.querySelectorAll('section[id]')
      if (sections.length && navLinks.length) {
        const sectionMap = {}
        sections.forEach((s) => { sectionMap[s.id] = s })

        const setActive = (id) => {
          navLinks.forEach((a) => {
            const href = a.getAttribute('href')
            if (href === '#' + id) {
              a.setAttribute('data-active', '')
            } else {
              a.removeAttribute('data-active')
            }
          })
        }

        // Use IntersectionObserver with a generous rootMargin so the
        // active link updates while the section is in the middle of the viewport
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                setActive(entry.target.id)
              }
            })
          },
          { rootMargin: '-20% 0px -60% 0px', threshold: 0 }
        )

        sections.forEach((s) => observer.observe(s))
      }

      // ── SECTION REVEAL: fade + slide up on scroll entry ──
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      if (!prefersReduced) {
        const revealEls = document.querySelectorAll(
          '.section-label, .section-body, .timeline-item, .skill-pill, .badge, .project-card, .contact-inner > *'
        )

        revealEls.forEach((el, i) => {
          el.style.opacity = '0'
          el.style.transform = 'translateY(18px)'
          el.style.transition = 'opacity 0.5s ease-out, transform 0.5s ease-out'
        })

        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                // Stagger siblings within the same parent
                const siblings = Array.from(
                  entry.target.parentElement
                    ? entry.target.parentElement.querySelectorAll(
                        ':scope > .timeline-item, :scope > .skill-pill, :scope > .badge, :scope > *'
                      )
                    : []
                )
                const index = siblings.indexOf(entry.target)
                const delay = Math.min(index * 60, 300)

                setTimeout(() => {
                  entry.target.style.opacity = '1'
                  entry.target.style.transform = 'translateY(0)'
                }, delay)

                revealObserver.unobserve(entry.target)
              }
            })
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
        )

        revealEls.forEach((el) => revealObserver.observe(el))
      }
    })()
  </script>
</Layout>

<style>
  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(8, 8, 15, 0.75);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition:
      background 0.3s ease,
      border-color 0.3s ease;
  }

  nav[data-scrolled] {
    background: rgba(8, 8, 15, 0.92);
    border-bottom-color: var(--border);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .nav-logo {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.05em;
    flex-shrink: 0;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .nav-logo:hover {
    opacity: 0.75;
    transform: scale(0.96);
  }

  .nav-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 2rem;
    flex: 1;
    justify-content: center;
  }

  .nav-links a {
    color: var(--muted-light);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s ease;
    position: relative;
  }

  /* Underline indicator that grows from left on hover and stays for active */
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--accent);
    transition: width 0.25s ease-out;
  }

  .nav-links a:hover {
    color: var(--accent);
  }

  .nav-links a:hover::after,
  .nav-links a[data-active]::after {
    width: 100%;
  }

  .nav-links a[data-active] {
    color: var(--accent);
  }

  .nav-highlight {
    color: var(--accent) !important;
    border: 1px solid var(--accent-dim);
    padding: 0.3rem 0.75rem;
    border-radius: 6px;
    background: rgba(100, 255, 218, 0.05);
  }

  .nav-highlight:hover {
    background: rgba(100, 255, 218, 0.1) !important;
    box-shadow: 0 0 10px var(--accent-glow);
  }

  .style-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: rgba(15, 15, 28, 0.9);
    color: var(--muted-light);
    font: inherit;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      border-color 0.2s,
      color 0.2s,
      transform 0.2s,
      background 0.2s;
  }

  .style-toggle strong {
    color: var(--accent);
    font-weight: 700;
  }

  .style-toggle:hover {
    color: var(--text);
    border-color: var(--accent);
    transform: translateY(-1px);
  }

  /* ── LANGUAGE SWITCHER ── */
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.2rem 0.25rem;
  }

  .lang-link {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--muted);
    text-decoration: none;
    padding: 0.3rem 0.5rem;
    border-radius: 4px;
    transition:
      color 0.2s,
      background 0.2s;
    min-width: 32px;
    text-align: center;
  }

  .lang-link:hover {
    color: var(--text);
    background: var(--surface-2);
  }

  .lang-link--active {
    color: var(--accent);
    background: var(--surface-2);
  }

  /* ── LAYOUT ── */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section {
    padding: 7rem 0;
  }

  .section-alt {
    background: var(--surface);
  }

  .section-grid {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* ── SECTION LABELS ── */
  .section-label {
    position: sticky;
    top: 100px;
  }

  .section-label.centered {
    position: static;
    margin-bottom: 3.5rem;
  }

  .label-num {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .accent-line {
    width: 32px;
    height: 2px;
    background: var(--accent);
    border-radius: 1px;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 80% 60% at 50% 0%,
        rgba(100, 255, 218, 0.04) 0%,
        transparent 70%
      ),
      radial-gradient(
        ellipse 40% 40% at 80% 80%,
        rgba(100, 200, 255, 0.03) 0%,
        transparent 60%
      );
    pointer-events: none;
  }

  .hero-content {
    padding-top: 64px;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4rem;
  }

  .hero-left {
    flex: 1;
  }

  .hero-right {
    flex-shrink: 0;
    animation: fadeIn 0.8s 0.5s ease both;
  }

  .hero-photo-wrap {
    width: 280px;
    height: 280px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 0 40px var(--accent-glow));
  }

  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .hero-greeting {
    font-size: 1rem;
    color: var(--accent);
    font-weight: 500;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
    animation: fadeUp 0.6s ease both;
  }

  .hero-name {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #e2e8f0 30%, #94a3b8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.75rem;
    animation: fadeUp 0.6s 0.1s ease both;
  }

  .hero-title {
    font-size: clamp(1.2rem, 2.5vw, 1.75rem);
    font-weight: 400;
    color: var(--accent);
    margin-bottom: 1.5rem;
    animation: fadeUp 0.6s 0.2s ease both;
  }

  .hero-tagline {
    font-size: 1.05rem;
    color: var(--muted-light);
    max-width: 520px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    animation: fadeUp 0.6s 0.3s ease both;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    animation: fadeUp 0.6s 0.4s ease both;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--muted);
    font-size: 0.875rem;
    animation: fadeUp 0.6s 0.5s ease both;
  }

  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--muted);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    animation: fadeIn 1s 1s ease both;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--muted), transparent);
    animation: scrollPulse 2s 1.5s ease-in-out infinite;
  }

  /* ── BUTTONS ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    background: var(--accent);
    color: var(--bg);
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: 6px;
    text-decoration: none;
    transition:
      background 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
    letter-spacing: 0.01em;
  }

  .btn-primary:hover {
    background: #8fffea;
    transform: translateY(-2px);
    box-shadow: 0 10px 32px var(--accent-glow);
  }

  .btn-primary:active {
    transform: translateY(0);
