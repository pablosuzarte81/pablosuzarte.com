---
import '../styles/global.css'
import Analytics from '@vercel/analytics/astro'

interface Props {
  title?: string
  description?: string
  lang?: string
  ogType?: string
  ogImage?: string
  articleDate?: string
  extraHead?: string
  noTracking?: boolean
}

const {
  title = 'Pablo Suzarte — Senior UX Designer & AI Collaboration Specialist',
  description = 'Senior Product UX Designer — 15+ years in service design, journey orchestration, and AI collaboration. Based in Malmö, Sweden. Currently at IKEA Global.',
  lang = 'en',
  ogType = 'website',
  ogImage = '/pablo_profile_photo.png',
  articleDate,
  noTracking = false,
} = Astro.props

const canonicalUrl = new URL(Astro.url.pathname, 'https://pablosuzarte.com').href
const ogImageUrl = new URL(ogImage, 'https://pablosuzarte.com').href
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Pablo Suzarte" />
    <title>{title}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang — i18n alternates -->
    <link rel="alternate" hreflang="en" href="https://pablosuzarte.com/" />
    <link rel="alternate" hreflang="sv" href="https://pablosuzarte.com/sv/" />
    <link rel="alternate" hreflang="es" href="https://pablosuzarte.com/es/" />
    <link rel="alternate" hreflang="x-default" href="https://pablosuzarte.com/" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={lang === 'sv' ? 'sv_SE' : lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:site_name" content="Pablo Suzarte" />
    {articleDate && <meta property="article:published_time" content={articleDate} />}
    {articleDate && <meta property="article:author" content="Pablo Suzarte" />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Geo targeting -->
    <meta name="geo.region" content="SE-M" />
    <meta name="geo.placename" content="Malmö" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Pablo Suzarte",
        "jobTitle": "Senior Product UX Designer",
        "url": "https://pablosuzarte.com",
        "sameAs": [
          "https://www.linkedin.com/in/pablosuzarte/"
        ],
        "knowsAbout": [
          "UX Design",
          "Service Design",
          "User Research",
          "Journey Mapping",
          "Journey Orchestration",
          "Experience Strategy",
          "AI-Assisted Design",
          "AI Orchestration",
          "Project Intelligence",
          "Human-AI Collaboration"
        ],
        "worksFor": {
          "@type": "Organization",
          "name": "IKEA Global"
        },
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Malmö",
          "addressRegion": "Skåne",
          "addressCountry": "SE"
        },
        "description": "Senior Product UX Designer with 15+ years of experience. Designs environments where humans and AI think together."
      }
    </script>
    <Analytics />
  </head>
  <body>
    <slot />

    {!noTracking && (
      <script is:inline>
      (function() {
        if (window.location.pathname.startsWith('/dashboard')) return;

        var vid = localStorage.getItem('_vid');
        if (!vid) {
          vid = crypto.randomUUID();
          localStorage.setItem('_vid', vid);
        }

        var path = window.location.pathname;
        var ref = document.referrer || 'direct';
        var ua = navigator.userAgent;
        var device = /Mobi|Android/i.test(ua) ? 'mobile' : /Tablet|iPad/i.test(ua) ? 'tablet' : 'desktop';

        function send(type, data) {
          var payload = JSON.stringify({ type: type, path: path, data: data, vid: vid, device: device, ref: ref });
          if (navigator.sendBeacon) {
            navigator.sendBeacon('/api/analytics/', payload);
          } else {
            fetch('/api/analytics/', { method: 'POST', body: payload, keepalive: true });
          }
        }

        // Page view
        send('pageview', {});

        // Scroll depth milestones
        var scrollFired = {};
        var milestones = [25, 50, 75, 100];
        function checkScroll() {
          var docH = document.documentElement.scrollHeight - window.innerHeight;
          if (docH <= 0) return;
          var pct = Math.round((window.scrollY / docH) * 100);
          for (var i = 0; i < milestones.length; i++) {
            var m = milestones[i];
            if (pct >= m && !scrollFired[m]) {
              scrollFired[m] = true;
              send('scroll', { depth: m });
              if (typeof window.va === 'function') window.va('event', { name: 'scroll_depth', data: { depth: m, path: path } });
            }
          }
        }
        window.addEventListener('scroll', checkScroll, { passive: true });

        // Time on page milestones
        var timeMilestones = [30, 60, 120, 300];
        var startTime = Date.now();
        var timeIdx = 0;
        var timeTimer = setInterval(function() {
          if (timeIdx >= timeMilestones.length) { clearInterval(timeTimer); return; }
          var elapsed = Math.round((Date.now() - startTime) / 1000);
          if (elapsed >= timeMilestones[timeIdx]) {
            send('engage', { seconds: timeMilestones[timeIdx] });
            if (typeof window.va === 'function') window.va('event', { name: 'time_on_page', data: { seconds: timeMilestones[timeIdx], path: path } });
            timeIdx++;
          }
        }, 5000);
      })();
      </script>
    )}
  </body>
</html>
